smod RFC-5246-CORE is
  protecting RUN-SCENARIO .
  protecting TLS-INITIAL-SYSTEM .
  protecting TLS-ALL-VALUES .
  protecting SET{BehaviorDVSpec} .

  --- tester(...) and target(...) are scenario-run roles, not protocol configuration.
  --- Pass them at reduction time.
  op initConf1 : -> TLSConfiguration .
  eq initConf1 = iversion(N1 . CI, TLS-12)
                 iversion(N2 . SI, TLS-12)
                 icipherSuites(N1 . CI, TLS-ECDHE-ECDSA-WITH-AES-128-GCM-SHA256)
                 icipherSuites(N2 . SI, TLS-ECDHE-ECDSA-WITH-AES-128-GCM-SHA256)
                 icompressions(N1 . CI, no-compression)
                 icompressions(N2 . SI, no-compression)
                 icertificates(N1 . CI, makeCertificate(N1 . CI, ecdsa, {ecdsa,sha256}, ecdsa))
                 icertificates(N2 . SI, makeCertificate(N2 . SI, ecdsa, {ecdsa,sha256}, ecdsa))
                 ipublicKeys(N1 . CI, makePubKey(CA, ecdsa))
                 ipublicKeys(N2 . SI, makePubKey(CA, ecdsa))
                 iprivateKeys(N1 . CI, makePrvKey(N1 . CI, ecdsa))
                 iprivateKeys(N2 . SI, makePrvKey(N2 . SI, ecdsa))
                 icertificateRequest(N2 . SI)
                 icertificateTypes(N2 . SI, ecdsa-sign)
                 icertificateAlgos(N2 . SI, {ecdsa,sha256})
                 isupported-groups(N1 . CI, secp256r1)
                 isupported-groups(N2 . SI, secp256r1)
                 isignature-algorithms(N1 . CI, {ecdsa,sha256})
                 isignature-algorithms(N2 . SI, {ecdsa,sha256}) .

  op initConfResume : -> TLSConfiguration .
  eq initConfResume = initConf1
                      ireconnect(N1 . CI)
                      ireconnect(N2 . SI) .

  op initConfSecureRenegotiation : -> TLSConfiguration .
  eq initConfSecureRenegotiation = initConf1
                                   isecureRenegotiation(N1 . CI)
                                   isecureRenegotiation(N2 . SI) .

  op initialCWA : -> ConfWithAction .
  eq initialCWA = {system | nil : nil} .

  op behaviorDeviationSpecification1 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification1 =
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[server-hello])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[certificate])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[server-key-exchange])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[certificate-request])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[server-hello-done])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[client-key-exchange])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[certificate-verify])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[finished])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[encrypted-extension])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[hello-retry-request])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[new-session-ticket])},
     {'scen1, ruleLabel('buildClientHelloV2), setM(#handshakeType, mv[key-update-request])} .

  op scenarioProperty1 : -> ScenarioProperty .
  eq scenarioProperty1 = (anyStep *) ; ruleLabel('scen1) ; (anyStep *) ; (N1 . CI . @errorLog = av[unexpected-message]) .

  op behaviorDeviationSpecification2 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification2 =
     {'scen2, ruleLabel('buildClientHelloV2), setM(#contentType, mv[change-cipher-spec])},
     {'scen2, ruleLabel('buildClientHelloV2), setM(#contentType, mv[alert])},
     {'scen2, ruleLabel('buildClientHelloV2), setM(#contentType, mv[application-data])} .

  op scenarioProperty2 : -> ScenarioProperty .
  eq scenarioProperty2 = (anyStep *) ; ruleLabel('scen2) ; (anyStep *) ; (N1 . CI . @errorLog = av[unexpected-message]) .

  op behaviorDeviationSpecification3 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification3 =
     {'scen3, ruleLabel('buildClientHelloV2), setM(#compressions, mv[zlib-compression])} .

  op scenarioProperty3 : -> ScenarioProperty .
  eq scenarioProperty3 = (anyStep *) ; ruleLabel('scen3) ; (anyStep *) ; (N1 . CI . @errorLog = av[illegal-parameter]) .

