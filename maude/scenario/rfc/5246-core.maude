  --- scen8 disabled: RFC 5246 Section 7.4.1.4.1 defines a TLS 1.2
  --- fallback when signature_algorithms is omitted.  In that case, the
  --- client is treated as using the SHA-1 signature/hash pair for each
  --- certificate type, so removing the extension is not itself a fatal
  --- ClientHello error in the current TLS 1.2 model.
  --- op behaviorDeviationSpecification8 : -> Set{BehaviorDVSpec} .
  --- eq behaviorDeviationSpecification8 =
  ---    {'scen8, ruleLabel('buildClientHelloV2), remove(#signature-algorithms)} .

  --- op scenarioProperty8 : -> ScenarioProperty .
  --- eq scenarioProperty8 = (anyStep *) ; ruleLabel('scen8) ; (anyStep *) ; (N1 . CI . @errorLog = av[handshake-failure]) .

