smod RFC-HRR is
  protecting RUN-SCENARIO .
  protecting TLS-INITIAL-SYSTEM .
  protecting TLS-ALL-VALUES .
  protecting SET{BehaviorDVSpec} .

  --- tester(...) and target(...) are scenario-run roles, not protocol configuration.
  --- Pass them at reduction time.
  op initConf : -> TLSConfiguration .
  eq initConf = iversion(N1 . CI, TLS-13)
                 iversion(N2 . SI, TLS-13)
                 icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                 icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
                 icompressions(N1 . CI, no-compression)
                 icompressions(N2 . SI, no-compression)
                 icertificates(N1 . CI, makeCertificate(N1 . CI, ecdsa, {ecdsa,sha256}, ecdsa))
                 icertificates(N2 . SI, makeCertificate(N2 . SI, ecdsa, {ecdsa,sha256}, ecdsa))
                 ipublicKeys(N1 . CI, makePubKey(CA, ecdsa))
                 ipublicKeys(N2 . SI, makePubKey(CA, ecdsa))
                 iprivateKeys(N1 . CI, makePrvKey(N1 . CI, ecdsa))
                 iprivateKeys(N2 . SI, makePrvKey(N2 . SI, ecdsa))
                 isupported-versions(N1 . CI, (TLS-13 nil))
                 isupported-versions(N2 . SI, (TLS-13 nil))
                 isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                 isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                 isupported-groups(N1 . CI, (secp256r1 secp521r1 nil))
                 isupported-groups(N2 . SI, (secp521r1 nil))
                 ikey-shares(N1 . CI, (secp256r1))
                 ikey-shares(N2 . SI, (secp521r1 nil)) .

  op initialCWA : -> ConfWithAction .
  eq initialCWA = {system | nil : nil} .

  op behaviorDeviationSpecification1 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification1 =
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{rsa,sha}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{rsa,sha224}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{rsa,sha256}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{rsa,sha384}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{rsa,sha512}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{rsa,md5}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{ecdsa,sha}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{ecdsa,sha224}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{ecdsa,sha256}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{ecdsa,sha384}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{ecdsa,sha512}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{dsa,sha}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{dsa,sha224}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{dsa,sha256}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{dsa,sha384}])},
     {'scen1, ruleLabel('buildHelloRetryRequestV3), add(#signature-algorithms, mv[{dsa,sha512}])} .

  op scenarioProperty1 : -> ScenarioProperty .
  eq scenarioProperty1 = (anyStep *) ; ruleLabel('scen1) ; (anyStep *) ; (N2 . SI . @errorLog = av[handshake-failure]) .
  op behaviorDeviationSpecification2 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification2 =
     {'scen2, ruleLabel('buildHelloRetryRequestV3), add(#supported-groups, mv[ffdhe2048])},
     {'scen2, ruleLabel('buildHelloRetryRequestV3), add(#supported-groups, mv[ffdhe3072])},
     {'scen2, ruleLabel('buildHelloRetryRequestV3), add(#supported-groups, mv[ffdhe4096])},
