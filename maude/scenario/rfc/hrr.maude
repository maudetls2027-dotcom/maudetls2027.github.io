     {'scen2, ruleLabel('buildHelloRetryRequestV3), add(#supported-groups, mv[secp521r1])} .

  op scenarioProperty2 : -> ScenarioProperty .
  eq scenarioProperty2 = (anyStep *) ; ruleLabel('scen2) ; (anyStep *) ; (N2 . SI . @errorLog = av[handshake-failure]) .
  op behaviorDeviationSpecification3 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification3 =
