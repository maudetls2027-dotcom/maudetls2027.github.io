     {'scen5, ruleLabel('buildClientHelloV3) and appliedNode(client) and featureMap(@reconnectInProgress |-> av[true]), add(#psk-key-exchange-mode, mv[psk-ke])},
     {'scen5, ruleLabel('buildClientHelloV3) and appliedNode(client) and featureMap(@reconnectInProgress |-> av[true]), add(#psk-key-exchange-mode, mv[psk-dhe-ke])} .

