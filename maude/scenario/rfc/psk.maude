smod RFC-PSK is
  protecting RUN-SCENARIO .
  protecting TLS-INITIAL-SYSTEM .
  protecting TLS-ALL-VALUES .
  protecting SET{BehaviorDVSpec} .

  --- tester(...) and target(...) are scenario-run roles, not protocol configuration.
  --- Pass them at reduction time.
  op initConf-psk-dhe : -> TLSConfiguration .
  eq initConf-psk-dhe =
                   iversion(N1 . CI, TLS-13)
                   iversion(N2 . SI, TLS-13)
                   icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                   icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
                   icompressions(N1 . CI, no-compression)
                   icompressions(N2 . SI, no-compression)
                   icertificates(N1 . CI, makeCertificate(N1 . CI, ecdsa, {ecdsa,sha256}, ecdsa))
                   icertificates(N2 . SI, makeCertificate(N2 . SI, ecdsa, {ecdsa,sha256}, ecdsa))
                   ipublicKeys(N1 . CI, makePubKey(CA, ecdsa))
                   ipublicKeys(N2 . SI, makePubKey(CA, ecdsa))
                   iprivateKeys(N1 . CI, makePrvKey(N1 . CI, ecdsa))
                   iprivateKeys(N2 . SI, makePrvKey(N2 . SI, ecdsa))
                   isupported-versions(N1 . CI, (TLS-13 nil))
                   isupported-versions(N2 . SI, (TLS-13 nil))
                   isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                   isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                   isupported-groups(N1 . CI, (secp256r1 nil))
                   isupported-groups(N2 . SI, (secp256r1 nil))
                   icertificateRequest(N2 . SI)
                   ikey-shares(N1 . CI, (secp256r1 nil))
                   ikey-shares(N2 . SI, (secp256r1 nil))
                   ipsk-key-exchange-modes(N1 . CI, (psk-dhe-ke nil))
                   ipsk-key-exchange-modes(N2 . SI, (psk-dhe-ke nil))
                   inewSessionTicketReq(N2 . SI)
                   inewSessionTicketWait(N1 . CI)
                   ireconnect(N1 . CI)
                   ireconnect(N2 . SI) .

  op initConf-psk-dhe-hrr : -> TLSConfiguration .
  eq initConf-psk-dhe-hrr =
                   iversion(N1 . CI, TLS-13)
                   iversion(N2 . SI, TLS-13)
                   icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                   icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
                   icompressions(N1 . CI, no-compression)
                   icompressions(N2 . SI, no-compression)
                   icertificates(N1 . CI, makeCertificate(N1 . CI, ecdsa, {ecdsa,sha256}, ecdsa))
                   icertificates(N2 . SI, makeCertificate(N2 . SI, ecdsa, {ecdsa,sha256}, ecdsa))
                   ipublicKeys(N1 . CI, makePubKey(CA, ecdsa))
                   ipublicKeys(N2 . SI, makePubKey(CA, ecdsa))
                   iprivateKeys(N1 . CI, makePrvKey(N1 . CI, ecdsa))
                   iprivateKeys(N2 . SI, makePrvKey(N2 . SI, ecdsa))
                   isupported-versions(N1 . CI, (TLS-13 nil))
                   isupported-versions(N2 . SI, (TLS-13 nil))
                   isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                   isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                   isupported-groups(N1 . CI, (secp521r1 secp256r1 nil))
                   isupported-groups(N2 . SI, (secp256r1 nil))
                   icertificateRequest(N2 . SI)
                   ikey-shares(N1 . CI, (secp521r1 nil))
                   ikey-shares(N2 . SI, (secp256r1 nil))
                   ipsk-key-exchange-modes(N1 . CI, (psk-dhe-ke nil))
                   ipsk-key-exchange-modes(N2 . SI, (psk-dhe-ke nil))
                   inewSessionTicketReq(N2 . SI)
                   inewSessionTicketWait(N1 . CI)
                   ireconnect(N1 . CI)
                   ireconnect(N2 . SI) .

  op initConf-psk-ke : -> TLSConfiguration .
  eq initConf-psk-ke =
                   iversion(N1 . CI, TLS-13)
                   iversion(N2 . SI, TLS-13)
                   icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                   icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
                   icompressions(N1 . CI, no-compression)
                   icompressions(N2 . SI, no-compression)
                   icertificates(N1 . CI, makeCertificate(N1 . CI, ecdsa, {ecdsa,sha256}, ecdsa))
                   icertificates(N2 . SI, makeCertificate(N2 . SI, ecdsa, {ecdsa,sha256}, ecdsa))
                   ipublicKeys(N1 . CI, makePubKey(CA, ecdsa))
                   ipublicKeys(N2 . SI, makePubKey(CA, ecdsa))
                   iprivateKeys(N1 . CI, makePrvKey(N1 . CI, ecdsa))
                   iprivateKeys(N2 . SI, makePrvKey(N2 . SI, ecdsa))
                   isupported-versions(N1 . CI, (TLS-13 nil))
                   isupported-versions(N2 . SI, (TLS-13 nil))
                   isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                   isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                   isupported-groups(N1 . CI, (secp256r1 nil))
                   isupported-groups(N2 . SI, (secp256r1 nil))
                   icertificateRequest(N2 . SI)
                   ikey-shares(N1 . CI, (secp256r1 nil))
                   ikey-shares(N2 . SI, (secp256r1 nil))
                   ipsk-key-exchange-modes(N1 . CI, (psk-ke nil))
                   ipsk-key-exchange-modes(N2 . SI, (psk-ke nil))
                   inewSessionTicketReq(N2 . SI)
                   inewSessionTicketWait(N1 . CI)
                   ireconnect(N1 . CI)
                   ireconnect(N2 . SI) .

  -----------------------
  --- PSK-DHE-KE Mode ---
  -----------------------
  --- In order to use PSKs, clients MUST also send a "psk_key_exchange_modes" extension.
  --- A client MUST provide a "psk_key_exchange_modes" extension if it offers a "pre_shared_key" extension. If clients offer
  --- "pre_shared_key" without a "psk_key_exchange_modes" extension, servers MUST abort the handshake.

  op initialCWA : -> ConfWithAction .
  eq initialCWA = {system | nil : nil} .

  op behaviorDeviationSpecification1 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification1 =
     {'scen1, ruleLabel('buildClientHelloV3) and appliedNode(client) and featureMap(@reconnectInProgress |-> av[true]), remove(#psk-key-exchange-mode)} .
     
  op scenarioProperty1 : -> ScenarioProperty .
  eq scenarioProperty1 = (anyStep *) ; ruleLabel('scen1) ; (anyStep *) ; (N1 . CI . @errorLog = av[missing-extension]) .



  op behaviorDeviationSpecification2 : -> Set{BehaviorDVSpec} .
  eq behaviorDeviationSpecification2 =
     {'scen2, ruleLabel('buildClientHelloV3) and appliedNode(client) and featureMap(@reconnectInProgress |-> av[true]), remove(#key-shares)} .

