  eq applyMsg(compressionsLen(SZ) MC, setM(#compressionsLen, mv[SZ'])) = compressionsLen(SZ') MC .
  eq applyMsg(certificates(CERTL) MC, setM(#certificate-list, emptyCertificateList)) = certificates(nil) MC .
  eq applyMsg(certificates(CERTL) MC, setM(#certificate-list, mv[CERTL'])) = certificates(CERTL') MC .
  eq applyMsg(certificatesLen(SZ) MC, setM(#certificate-list-len, mv[SZ'])) = certificatesLen(SZ') MC .
  eq applyMsg(certificates(CERTL) MC, setM(#certificateTypes, mv[CERTL'])) = certificates(CERTL') MC .
  eq applyMsg(certificatesLen(SZ) MC, setM(#certificateTypesLen, mv[SZ'])) = certificatesLen(SZ') MC .
  eq applyMsg(certificateTypes(CTL) MC, setM(#certificateTypes, mv[CTL'])) = certificateTypes(CTL') MC .
