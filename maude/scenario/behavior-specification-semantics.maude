  eq applyMsg(extensions(signature-algorithms(SAL) signature-algorithms-len(SZ) EXT) MC, remove(#signature-algorithms)) = extensions(EXT) MC .
  eq applyMsg(extensions(signature-algorithms(SAL) EXT) MC, remove(#signature-algorithms)) = extensions(EXT) MC .
  eq applyMsg(extensions(signature-algorithms-len(SZ) EXT) MC, remove(#signature-algorithms-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(signature-algorithms-cert(SAL) signature-algorithms-cert-len(SZ) EXT) MC, remove(#signature-algorithms-cert)) = extensions(EXT) MC .
  eq applyMsg(extensions(signature-algorithms-cert(SAL) EXT) MC, remove(#signature-algorithms-cert)) = extensions(EXT) MC .
  eq applyMsg(extensions(signature-algorithms-cert-len(SZ) EXT) MC, remove(#signature-algorithms-cert-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(key-shares(KSL) key-shares-len(SZ) EXT) MC, remove(#key-shares)) = extensions(EXT) MC .
  eq applyMsg(extensions(key-shares(KSL) EXT) MC, remove(#key-shares)) = extensions(EXT) MC .
  eq applyMsg(extensions(key-shares(NG) key-shares-len(SZ) EXT) MC, remove(#key-shares-groups)) = extensions(EXT) MC .
  eq applyMsg(extensions(key-shares(NG) EXT) MC, remove(#key-shares-groups)) = extensions(EXT) MC .
  eq applyMsg(extensions(key-shares(NG) EXT) MC, remove(#key-shares)) = extensions(EXT) MC .
  eq applyMsg(extensions(key-shares-len(SZ) EXT) MC, remove(#key-shares-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(supported-groups(NGL) supported-groups-len(SZ) EXT) MC, remove(#supported-groups)) = extensions(EXT) MC .
  eq applyMsg(extensions(supported-groups(NGL) EXT) MC, remove(#supported-groups)) = extensions(EXT) MC .
  eq applyMsg(extensions(supported-groups-len(SZ) EXT) MC, remove(#supported-groups-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(psk-key-exchange-mode(PKML) psk-key-exchange-mode-len(SZ) EXT) MC, remove(#psk-key-exchange-mode)) = extensions(EXT) MC .
  eq applyMsg(extensions(psk-key-exchange-mode(PKML) EXT) MC, remove(#psk-key-exchange-mode)) = extensions(EXT) MC .
  eq applyMsg(extensions(psk-key-exchange-mode-len(SZ) EXT) MC, remove(#psk-key-exchange-mode-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(pre-shared-key(N) pre-shared-key-len(SZ) EXT) MC, remove(#selected-identifier)) = extensions(EXT) MC .
  eq applyMsg(extensions(pre-shared-key(N) EXT) MC, remove(#selected-identifier)) = extensions(EXT) MC .
  eq applyMsg(extensions(pre-shared-key(TICKETL, BINDERL) pre-shared-key-len(SZ) EXT) MC, remove(#pre-shared-key)) = extensions(EXT) MC .
  eq applyMsg(extensions(pre-shared-key(TICKETL, BINDERL) EXT) MC, remove(#pre-shared-key)) = extensions(EXT) MC .
  eq applyMsg(extensions(pre-shared-key-len(SZ) EXT) MC, remove(#pre-shared-key-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(early-data early-data-len(SZ) EXT) MC, remove(#early-data)) = extensions(EXT) MC .
  eq applyMsg(extensions(early-data EXT) MC, remove(#early-data)) = extensions(EXT) MC .
  eq applyMsg(extensions(early-data-len(SZ) EXT) MC, remove(#early-data-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(post-handshake post-handshake-len(SZ) EXT) MC, remove(#post-handshake)) = extensions(EXT) MC .
  eq applyMsg(extensions(post-handshake EXT) MC, remove(#post-handshake)) = extensions(EXT) MC .
  eq applyMsg(extensions(post-handshake-len(SZ) EXT) MC, remove(#post-handshake-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(renegotiation-info(NONCE?, NONCE?') EXT) MC, remove(#renegotiation-info)) = extensions(EXT) MC .
  eq applyMsg(extensions(renegotiation-info-len(SZ) EXT) MC, remove(#renegotiation-info-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(cks cks-len(SZ) EXT) MC, remove(#cks)) = extensions(EXT) MC .
  eq applyMsg(extensions(cks EXT) MC, remove(#cks)) = extensions(EXT) MC .
  eq applyMsg(extensions(cks-len(SZ) EXT) MC, remove(#cks-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(cookie(NONCE?) cookie-len(SZ) EXT) MC, remove(#cookie)) = extensions(EXT) MC .
  eq applyMsg(extensions(cookie(NONCE?) EXT) MC, remove(#cookie)) = extensions(EXT) MC .
  eq applyMsg(extensions(cookie cookie-len(SZ) EXT) MC, remove(#cookie)) = extensions(EXT) MC .
  eq applyMsg(extensions(cookie EXT) MC, remove(#cookie)) = extensions(EXT) MC .
  eq applyMsg(extensions(cookie-len(SZ) EXT) MC, remove(#cookie-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(unknown-extension unknown-extension-len(SZ) EXT) MC, remove(#unknown-extension)) = extensions(EXT) MC .
  eq applyMsg(extensions(unknown-extension EXT) MC, remove(#unknown-extension)) = extensions(EXT) MC .
  eq applyMsg(extensions(unknown-extension-len(SZ) EXT) MC, remove(#unknown-extension-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(oid-filters(OFL) oid-filters-len(SZ) EXT) MC, remove(#oid-filters)) = extensions(EXT) MC .
  eq applyMsg(extensions(oid-filters(OFL) EXT) MC, remove(#oid-filters)) = extensions(EXT) MC .
  eq applyMsg(extensions(oid-filters oid-filters-len(SZ) EXT) MC, remove(#oid-filters)) = extensions(EXT) MC .
  eq applyMsg(extensions(oid-filters EXT) MC, remove(#oid-filters)) = extensions(EXT) MC .
  eq applyMsg(extensions(oid-filters-len(SZ) EXT) MC, remove(#oid-filters-len)) = extensions(EXT) MC .
  eq applyMsg(extensions(status-request-v2 status-request-v2-len(SZ) EXT) MC, remove(#status-request-v2)) = extensions(EXT) MC .
  eq applyMsg(extensions(status-request-v2 EXT) MC, remove(#status-request-v2)) = extensions(EXT) MC .
  eq applyMsg(extensions(status-request-v2-len(SZ) EXT) MC, remove(#status-request-v2-len)) = extensions(EXT) MC .

  eq applyMsg(MC encrypt(KEY, MC'), BMOD) = MC encrypt(KEY, applyMsg(MC', BMOD)) [owise] .
  eq applyMsg(MC, BMOD) = MC [owise] .

  --------------------------
  --- Field Modification ---
  --------------------------
  op applyObject : Object BehaviorModification -> Object .
  eq applyObject(< TI : TLS | cipherSuites : CSL >, setF(@cipherSuites, av[CSL']))
   = < TI : TLS | cipherSuites : CSL' > .
  eq applyObject(< TI : TLS | compressions : CML >, setF(@compressions, av[CML']))
   = < TI : TLS | compressions : CML' > .
  eq applyObject(< TI : TLS | extensions : supported-versions(PVL) EXT >, setF(@supportedVersions, av[PVL']))
   = < TI : TLS | extensions : supported-versions(PVL') EXT > .
  eq applyObject(< TI : TLS | extensions : signature-algorithms(SAL) EXT >, setF(@signatureAlgorithms, av[SAL']))
   = < TI : TLS | extensions : signature-algorithms(SAL') EXT > .
  eq applyObject(< TI : TLS | extensions : key-shares(KSL) EXT >, setF(@keyShares, av[KSL']))
   = < TI : TLS | extensions : key-shares(KSL') EXT > .
  eq applyObject(< TI : TLS | extensions : supported-groups(NGL) EXT >, setF(@supportedGroups, av[NGL']))
   = < TI : TLS | extensions : supported-groups(NGL') EXT > .
  eq applyObject(< TI : TLS | extensions : psk-key-exchange-mode(PKML) EXT >, setF(@pskKeyExchangeModes, av[PKML']))
   = < TI : TLS | extensions : psk-key-exchange-mode(PKML') EXT > .
  eq applyObject(< TI : TLS | pskDHEMode : PKML >, setF(@pskDHEMode, av[PKML']))
   = < TI : TLS | pskDHEMode : PKML' > .
  eq applyObject(< TI : TLS | extensions : EXT >, setF(@extensions, av[EXT']))
   = < TI : TLS | extensions : EXT' > .
  eq applyObject(< TI : TLS | sessionId : NONCE? >, setF(@sessionId, av[NONCE?']))
   = < TI : TLS | sessionId : NONCE?' > .
  eq applyObject(< TI : TLS | sessionState : SESS >, setF(@sessionState, av[SESS']))
   = < TI : TLS | sessionState : SESS' > .
  eq applyObject(< TI : TLS | selectedVersion : PV >, setF(@selectedVersion, av[PV']))
   = < TI : TLS | selectedVersion : PV' > .
  eq applyObject(< TI : TLS | selectedCipherSuite : CS >, setF(@selectedCipherSuite, av[CS']))
   = < TI : TLS | selectedCipherSuite : CS' > .
  eq applyObject(< TI : TLS | selectedCompression : CM >, setF(@selectedCompression, av[CM']))
   = < TI : TLS | selectedCompression : CM' > .
  eq applyObject(< TI : TLS | selectedExtensions : supported-versions(PVL) EXT >, setF(@selectedSupportedVersions, av[PVL']))
   = < TI : TLS | selectedExtensions : supported-versions(PVL') EXT > .
  eq applyObject(< TI : TLS | selectedExtensions : signature-algorithms(SAL) EXT >, setF(@selectedSignatureAlgorithms, av[SAL']))
   = < TI : TLS | selectedExtensions : signature-algorithms(SAL') EXT > .
  eq applyObject(< TI : TLS | selectedExtensions : key-shares(KSL) EXT >, setF(@selectedKeyShares, av[KSL']))
   = < TI : TLS | selectedExtensions : key-shares(KSL') EXT > .
  eq applyObject(< TI : TLS | selectedExtensions : supported-groups(NGL) EXT >, setF(@selectedSupportedGroups, av[NGL']))
   = < TI : TLS | selectedExtensions : supported-groups(NGL') EXT > .
  eq applyObject(< TI : TLS | selectedExtensions : psk-key-exchange-mode(PKML) EXT >, setF(@selectedPskKeyExchangeModes, av[PKML']))
   = < TI : TLS | selectedExtensions : psk-key-exchange-mode(PKML') EXT > .
  eq applyObject(< TI : TLS | keyExchangeGroup : NG >, setF(@keyExchangeGroup, av[NG']))
   = < TI : TLS | keyExchangeGroup : NG' > .
  eq applyObject(< TI : TLS | sharedSecret : NONCE? >, setF(@sharedSecret, av[NONCE?']))
   = < TI : TLS | sharedSecret : NONCE?' > .
  eq applyObject(< TI : TLS | certificateType : CTL >, setF(@certificateType, av[CTL']))
   = < TI : TLS | certificateType : CTL' > .
  eq applyObject(< TI : TLS | certificateAlgo : SAL >, setF(@certificateAlgo, av[SAL']))
   = < TI : TLS | certificateAlgo : SAL' > .
  eq applyObject(< TI : TLS | keyUpdateReq : B >, setF(@keyUpdateReq, av[B']))
   = < TI : TLS | keyUpdateReq : B' > .
  eq applyObject(< TI : TLS | keyUpdateReqType : B >, setF(@keyUpdateReqType, av[B']))
   = < TI : TLS | keyUpdateReqType : B' > .
  eq applyObject(< TI : TLS | keyUpdateWait : B >, setF(@keyUpdateWait, av[B']))
   = < TI : TLS | keyUpdateWait : B' > .
  eq applyObject(< TI : TLS | errorLog : AD >, setF(@errorLog, av[AD']))
   = < TI : TLS | errorLog : AD' > .
  eq applyObject(< TI : TLS | reconnect : B >, setF(@reconnect, av[B']))
   = < TI : TLS | reconnect : B' > .
  eq applyObject(< TI : TLS | reconnectInProgress : B >, setF(@reconnectInProgress, av[B']))
   = < TI : TLS | reconnectInProgress : B' > .
  eq applyObject(< TI : TLS | sessionResumption : B >, setF(@sessionResumption, av[B']))
   = < TI : TLS | sessionResumption : B' > .
  eq applyObject(< TI : TLS | secureRenegotiation : B >, setF(@secureRenegotiation, av[B']))
   = < TI : TLS | secureRenegotiation : B' > .
  eq applyObject(< TI : Client | clientState : CST >, setF(@clientState, av[CST']))
   = < TI : Client | clientState : CST' > .
  eq applyObject(< TI : Client | certificateRequested : B >, setF(@certificateRequested, av[B']))
   = < TI : Client | certificateRequested : B' > .
  eq applyObject(< TI : Client | newSessionTicketWait : B >, setF(@newSessionTicketWait, av[B']))
   = < TI : Client | newSessionTicketWait : B' > .
  eq applyObject(< TI : Client | earlyDataReq : B >, setF(@earlyDataReq, av[B']))
   = < TI : Client | earlyDataReq : B' > .
  eq applyObject(< TI : Client | postClientAuthReq : B >, setF(@postClientAuthReq, av[B']))
   = < TI : Client | postClientAuthReq : B' > .
  eq applyObject(< TI : Client | clientRenegotiation : B >, setF(@clientRenegotiation, av[B']))
   = < TI : Client | clientRenegotiation : B' > .
  eq applyObject(< TI : Server | serverState : SST >, setF(@serverState, av[SST']))
   = < TI : Server | serverState : SST' > .
  eq applyObject(< TI : Server | clientCertificateReq : B >, setF(@clientCertificateReq, av[B']))
   = < TI : Server | clientCertificateReq : B' > .
  eq applyObject(< TI : Server | newSessionTicketReq : B >, setF(@newSessionTicketReq, av[B']))
   = < TI : Server | newSessionTicketReq : B' > .
  eq applyObject(< TI : Server | earlyDataWait : B >, setF(@earlyDataWait, av[B']))
   = < TI : Server | earlyDataWait : B' > .
  eq applyObject(< TI : Server | postClientAuthRequested : B >, setF(@postClientAuthRequested, av[B']))
   = < TI : Server | postClientAuthRequested : B' > .
  eq applyObject(OBJ, BMOD) = OBJ [owise] .
endom

omod BEHAVIOR-DEVIATION-SPECIFICATION-SEMANTICS is
  protecting BEHAVIOR-DEVIATION-SPECIFICATION .
  protecting ALL-TARGET-RULES .
  protecting SET-RULE-LABELS .
  protecting ADD-RULE-CONDITIONS .
  protecting APPLY-RULE-MODIFICATION  .
  protecting SET{BehaviorDVSpec} .
  protecting OBJECT-WITH-ACTION .
  protecting LINK-OBJECT .
  protecting COMMON-AUX-OPERATOR .
  protecting META-LEVEL .

  var BS : BehaviorDVSpec .
  var BSS : Set{BehaviorDVSpec} .
  var PV : ProtocolVersion .
  var LABEL : Qid .
  var AP : ActionProposition .
  var BMODS : Set{BehaviorModification} .

  op deviateRules : Set{BehaviorDVSpec} -> RuleSet .
  op deviateRules : ProtocolVersion Set{BehaviorDVSpec} -> RuleSet .
  eq deviateRules((BS, BSS)) = deviateRule(BS) deviateRules(BSS) .
  eq deviateRules(empty) = none .
  eq deviateRules(PV, (BS, BSS)) = deviateRule(PV, BS) deviateRules(PV, BSS) .
  eq deviateRules(PV, empty) = none .

  op deviateRule : BehaviorDVSpec -> RuleSet .
  op deviateRule : ProtocolVersion BehaviorDVSpec -> RuleSet .
  eq deviateRule({LABEL, AP, BMODS})
   = setLabels(LABEL, addGuard(AP, applyRules(BMODS, allTargetRules))) .
  eq deviateRule(PV, {LABEL, AP, BMODS})
   = setLabels(LABEL, addGuard(AP, applyRules(BMODS, allTargetRules(PV)))) .
endom
