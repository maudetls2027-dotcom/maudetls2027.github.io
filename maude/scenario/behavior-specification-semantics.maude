   = extensions(status-request-v2-len(SZ') EXT) MC .

  eq applyMsg(cipherSuites(CSL) MC, add(#cipherSuites, mv[CSL'])) = cipherSuites(CSL CSL') MC .
  eq applyMsg(compressions(CML) MC, add(#compressions, mv[CML'])) = compressions(CML CML') MC .
  eq applyMsg(certificates(CERTL) MC, add(#certificate-list, mv[CERTL'])) = certificates(CERTL CERTL') MC .
