mod ALL-TARGET-RULES is
  protecting META-LEVEL .
  protecting PROTOCOL-VERSION .

  vars MID RID : Qid .
  var PV : ProtocolVersion .
  var RULE : Rule .
  var RULES : RuleSet .
  vars T1 T2 : Term .
  var AS : AttrSet .
  var COND : Condition .

  op allTargetRules : -> RuleSet .
  op allTargetRules : ProtocolVersion -> RuleSet .
  op allTargetRulesV2 : -> RuleSet .
  op allTargetRulesV3 : -> RuleSet .

  eq allTargetRules = allTargetRulesV2 allTargetRulesV3 .
  eq allTargetRules(TLS-12) = allTargetRulesV2 .
  eq allTargetRules(TLS-13) = allTargetRulesV3 .
  eq allTargetRules(PV) = none [owise] .

  eq allTargetRulesV2 =
    ruleTerm('BUILD-CLIENT-HELLO-V2, 'buildClientHelloV2)
    ruleTerm('BUILD-SERVER-HELLO-V2, 'buildServerHelloV2)
    ruleTerm('BUILD-SERVER-CERTIFICATE-V2, 'buildServerCertificateV2)
    ruleTerm('BUILD-SERVER-KEY-EXCHANGE-V2, 'buildServerKeyExchangeV2)
    ruleTerm('BUILD-SERVER-CERTIFICATE-REQUEST-V2, 'buildCertificateRequestV2)
    ruleTerm('BUILD-SERVER-HELLO-DONE-V2, 'buildServerHelloDoneV2)
    ruleTerm('BUILD-CLIENT-CERTIFICATE-V2, 'buildClientCertificateV2)
    ruleTerm('BUILD-CLIENT-KEY-EXCHANGE-V2, 'buildClientKeyExchangeV2)
    ruleTerm('BUILD-CLIENT-CERTIFICATE-VERIFY-V2, 'buildClientCertificateVerifyV2)
    ruleTerm('BUILD-CLIENT-CHANGE-CIPHER-SPEC-V2, 'buildClientChangeCipherSpecV2)
    ruleTerm('BUILD-SERVER-CHANGE-CIPHER-SPEC-V2, 'buildServerChangeCipherSpecV2)
    ruleTerm('BUILD-CLIENT-FINISHED-V2, 'buildClientFinishedV2)
    ruleTerm('BUILD-SERVER-FINISHED-V2, 'buildServerFinishedV2)
    ruleTerm('PROCESS-CLIENT-HELLO-V2, 'processClientHelloV2)
    ruleTerm('PROCESS-SERVER-HELLO-V2, 'processServerHelloV2)
    ruleTerm('PROCESS-SERVER-CERTIFICATE-V2, 'processServerCertificateV2)
    ruleTerm('PROCESS-SERVER-KEY-EXCHANGE-V2, 'processServerKeyExchangeV2)
    ruleTerm('PROCESS-SERVER-CERTIFICATE-REQUEST-V2, 'processCertificateRequestV2)
    ruleTerm('PROCESS-SERVER-HELLO-DONE-V2, 'processServerHelloDoneV2)
    ruleTerm('PROCESS-CLIENT-CERTIFICATE-V2, 'processClientCertificateV2)
    ruleTerm('PROCESS-CLIENT-KEY-EXCHANGE-V2, 'processClientKeyExchangeV2)
    ruleTerm('PROCESS-CLIENT-CERTIFICATE-VERIFY-V2, 'processCertificateVerifyV2)
    ruleTerm('PROCESS-CLIENT-CHANGE-CIPHER-SPEC-V2, 'processClientChangeCipherSpecV2)
    ruleTerm('PROCESS-SERVER-CHANGE-CIPHER-SPEC-V2, 'processServerChangeCipherSpecV2)
    ruleTerm('PROCESS-CLIENT-FINISHED-V2, 'processClientFinishedV2)
    ruleTerm('PROCESS-SERVER-FINISHED-V2, 'processServerFinishedV2) .

  eq allTargetRulesV3 =
    ruleTerm('BUILD-CLIENT-HELLO-V3, 'buildClientHelloV3)
    ruleTerm('BUILD-SECOND-CLIENT-HELLO-V3, 'buildSecondClientHelloV3)
    ruleTerm('BUILD-EARLY-DATA-V3, 'buildEarlyDataV3)
    ruleTerm('BUILD-END-OF-EARLY-DATA-V3, 'buildEndOfEarlyDataV3)
    ruleTerm('BUILD-CLIENT-CERTIFICATE-V3, 'buildClientCertificateV3)
    ruleTerm('BUILD-CLIENT-CERTIFICATE-VERIFY-V3, 'buildClientCertificateVerifyV3)
    ruleTerm('BUILD-CLIENT-FINISHED-V3, 'buildClientFinishedV3)
    ruleTerm('BUILD-CLIENT-KEY-UPDATE-REQUEST-V3, 'buildClientKeyUpdateRequestV3)
    ruleTerm('BUILD-CLIENT-KEY-UPDATE-RESPONSE-V3, 'buildClientKeyUpdateResponseV3)
    ruleTerm('BUILD-HELLO-RETRY-REQUEST-V3, 'buildHelloRetryRequestV3)
    ruleTerm('BUILD-SERVER-HELLO-V3, 'buildServerHelloV3)
    ruleTerm('BUILD-SERVER-ENCRYPTED-EXTENSIONS-V3, 'buildEncryptedExtensionV3)
    ruleTerm('BUILD-SERVER-CERTIFICATE-REQUEST-V3, 'buildCertificateRequestV3)
    ruleTerm('BUILD-SERVER-CERTIFICATE-V3, 'buildServerCertificateV3)
    ruleTerm('BUILD-SERVER-CERTIFICATE-VERIFY-V3, 'buildServerCertificateVerifyV3)
    ruleTerm('BUILD-SERVER-FINISHED-V3, 'buildServerFinishedV3)
    ruleTerm('BUILD-NEW-SESSION-TICKET-V3, 'buildNewSessionTicketV3)
    ruleTerm('BUILD-POST-CLIENT-AUTHENTICATION-V3, 'buildPostClientAuthenticationV3)
    ruleTerm('BUILD-SERVER-KEY-UPDATE-REQUEST-V3, 'buildServerKeyUpdateRequestV3)
    ruleTerm('BUILD-SERVER-KEY-UPDATE-RESPONSE-V3, 'buildServerKeyUpdateResponseV3)
    ruleTerm('PROCESS-CLIENT-HELLO-V3, 'processClientHelloV3)
    ruleTerm('PROCESS-EARLY-DATA-V3, 'processEarlyDataV3)
    ruleTerm('PROCESS-EARLY-DATA-V3, 'discardEarlyDataV3)
    ruleTerm('PROCESS-END-OF-EARLY-DATA-V3, 'processEndOfEarlyDataV3)
    ruleTerm('PROCESS-HELLO-RETRY-REQUEST, 'processHelloRetryRequestV3)
    ruleTerm('PROCESS-SERVER-HELLO-V3, 'processServerHelloV3)
    ruleTerm('PROCESS-SERVER-ENCRYPTED-EXTENSION-V3, 'processEncryptedExtensionV3)
    ruleTerm('PROCESS-SERVER-CERTIFICATE-REQUEST-V3, 'processCertificateRequestV3)
    ruleTerm('PROCESS-SERVER-CERTIFICATE-V3, 'processServerCertificateV3)
    ruleTerm('PROCESS-SERVER-CERTIFICATE-VERIFY-V3, 'processServerCertificateVerifyV3)
    ruleTerm('PROCESS-SERVER-FINISHED-V3, 'processServerFinishedV3)
    ruleTerm('PROCESS-NEW-SESSION-TICKET, 'processNewSessionTicketV3)
    ruleTerm('PROCESS-POST-CLIENT-AUTHENTICATION-V3, 'processPostClientAuthenticationV3)
    ruleTerm('PROCESS-SERVER-KEY-UPDATE-REQUEST-V3, 'processServerKeyUpdateRequestV3)
    ruleTerm('PROCESS-SERVER-KEY-UPDATE-RESPONSE-V3, 'processServerKeyUpdateResponseV3)
    ruleTerm('PROCESS-CLIENT-CERTIFICATE-V3, 'processClientCertificateV3)
    ruleTerm('PROCESS-CLIENT-CERTIFICATE-VERIFY-V3, 'processClientCertificateVerifyV3)
    ruleTerm('PROCESS-CLIENT-FINISHED-V3, 'processClientFinishedV3)
    ruleTerm('PROCESS-CLIENT-KEY-UPDATE-REQUEST-V3, 'processClientKeyUpdateRequestV3)
    ruleTerm('PROCESS-CLIENT-KEY-UPDATE-RESPONSE-V3, 'processClientKeyUpdateResponseV3) .

  op ruleTerm : Qid Qid -> Rule .
 ceq ruleTerm(MID, RID) = RULE
  if (RULE RULES) := upRls(MID, true)
  /\ checkLabel(RULE, RID) .

  op checkLabel : Rule Qid -> Bool .
  eq checkLabel(rl T1 => T2 [label(RID) AS] ., RID) = true .
  eq checkLabel(crl T1 => T2 if COND [label(RID) AS] ., RID) = true .
  eq checkLabel(RULE, RID) = false [owise] .
endm

omod SET-RULE-LABELS is
  protecting META-LEVEL .
  protecting QID .

  vars LABEL RID : Qid .
  vars T1 T2 : Term .
  vars RULE RULE' : Rule .
  var RULES : RuleSet .
  vars AS AS' : AttrSet .
  var COND : Condition .
  var QL : QidList .

  op setLabels : Qid RuleSet -> RuleSet .
  eq setLabels(LABEL, RULE RULES)
   = setLabel(LABEL, RULE) setLabels(LABEL, RULES) .
  eq setLabels(LABEL, none) = none .

  op setLabel : Qid Rule -> Rule .
  eq setLabel(LABEL, rl T1 => T2 [AS] .)
   = (rl T1 => T2 [setRuleAttrs(LABEL, AS)] .) .
  eq setLabel(LABEL, crl T1 => T2 if COND [AS] .)
   = (crl T1 => T2 if COND [setRuleAttrs(LABEL, AS)] .) .

  op setRuleAttrs : Qid AttrSet -> AttrSet .
  eq setRuleAttrs(LABEL, AS) = label(LABEL) dropRuleLabelAttrs(AS) .

  op dropRuleLabelAttrs : AttrSet -> AttrSet .
  eq dropRuleLabelAttrs(label(RID) AS) = dropRuleLabelAttrs(AS) .
  eq dropRuleLabelAttrs(print(QL) AS) = dropRuleLabelAttrs(AS) .
  eq dropRuleLabelAttrs(AS) = AS [owise] .
endom

omod ADD-RULE-CONDITIONS is
  protecting ACTION-PROPOSITION-EVALUATION .
  protecting META-LEVEL .

  var AP : ActionProposition .
  var RI : RuleInfo .
  vars RID : Qid .
  vars T1 T2 : Term .
  var RULE : Rule .
  var RULES : RuleSet .
  var COND : Condition .
  var AS : AttrSet .

  op addGuard : ActionProposition RuleSet -> RuleSet .
  eq addGuard(AP, RULE RULES) = addGuardRule(AP, RULE) addGuard(AP, RULES) .
  eq addGuard(AP, none) = none .

  op addGuardRule : ActionProposition Rule -> Rule .
  eq addGuardRule(AP, rl T1 => T2 [label(RID) AS] .)
   = (crl T1 => T2 if actionGuard(AP, targetRuleInfo(RID), T1) [label(RID) AS] .) .
  eq addGuardRule(AP, crl T1 => T2 if COND [label(RID) AS] .)
   = (crl T1 => T2 if actionGuard(AP, targetRuleInfo(RID), T1) /\ COND [label(RID) AS] .) .
  eq addGuardRule(AP, RULE) = RULE [owise] .

  op actionGuard : ActionProposition RuleInfo Term -> Condition .
  eq actionGuard(AP, RI, T1) = ('satisfies[upTerm(AP), upTerm(RI), T1] = 'true.Bool) .

  op targetRuleInfo : Qid -> RuleInfo .
  eq targetRuleInfo('buildClientHelloV2) = {'buildClientHelloV2, send, client} .
  eq targetRuleInfo('buildClientCertificateV2) = {'buildClientCertificateV2, send, client} .
  eq targetRuleInfo('buildClientKeyExchangeV2) = {'buildClientKeyExchangeV2, send, client} .
  eq targetRuleInfo('buildClientCertificateVerifyV2) = {'buildClientCertificateVerifyV2, send, client} .
  eq targetRuleInfo('buildClientChangeCipherSpecV2) = {'buildClientChangeCipherSpecV2, send, client} .
  eq targetRuleInfo('buildClientFinishedV2) = {'buildClientFinishedV2, send, client} .
  eq targetRuleInfo('processServerHelloV2) = {'processServerHelloV2, receive, client} .
  eq targetRuleInfo('processServerCertificateV2) = {'processServerCertificateV2, receive, client} .
  eq targetRuleInfo('processServerKeyExchangeV2) = {'processServerKeyExchangeV2, receive, client} .
  eq targetRuleInfo('processCertificateRequestV2) = {'processCertificateRequestV2, receive, client} .
  eq targetRuleInfo('processServerHelloDoneV2) = {'processServerHelloDoneV2, receive, client} .
  eq targetRuleInfo('processServerChangeCipherSpecV2) = {'processServerChangeCipherSpecV2, receive, client} .
  eq targetRuleInfo('processServerFinishedV2) = {'processServerFinishedV2, receive, client} .

  eq targetRuleInfo('buildServerHelloV2) = {'buildServerHelloV2, send, server} .
  eq targetRuleInfo('buildServerCertificateV2) = {'buildServerCertificateV2, send, server} .
  eq targetRuleInfo('buildServerKeyExchangeV2) = {'buildServerKeyExchangeV2, send, server} .
  eq targetRuleInfo('buildCertificateRequestV2) = {'buildCertificateRequestV2, send, server} .
  eq targetRuleInfo('buildServerHelloDoneV2) = {'buildServerHelloDoneV2, send, server} .
  eq targetRuleInfo('buildServerChangeCipherSpecV2) = {'buildServerChangeCipherSpecV2, send, server} .
  eq targetRuleInfo('buildServerFinishedV2) = {'buildServerFinishedV2, send, server} .
  eq targetRuleInfo('processClientHelloV2) = {'processClientHelloV2, receive, server} .
  eq targetRuleInfo('processClientCertificateV2) = {'processClientCertificateV2, receive, server} .
  eq targetRuleInfo('processClientKeyExchangeV2) = {'processClientKeyExchangeV2, receive, server} .
  eq targetRuleInfo('processCertificateVerifyV2) = {'processCertificateVerifyV2, receive, server} .
  eq targetRuleInfo('processClientChangeCipherSpecV2) = {'processClientChangeCipherSpecV2, receive, server} .
  eq targetRuleInfo('processClientFinishedV2) = {'processClientFinishedV2, receive, server} .

  eq targetRuleInfo('buildClientHelloV3) = {'buildClientHelloV3, send, client} .
  eq targetRuleInfo('buildSecondClientHelloV3) = {'buildSecondClientHelloV3, send, client} .
  eq targetRuleInfo('buildEarlyDataV3) = {'buildEarlyDataV3, send, client} .
  eq targetRuleInfo('buildEndOfEarlyDataV3) = {'buildEndOfEarlyDataV3, send, client} .
  eq targetRuleInfo('buildClientCertificateV3) = {'buildClientCertificateV3, send, client} .
  eq targetRuleInfo('buildClientCertificateVerifyV3) = {'buildClientCertificateVerifyV3, send, client} .
  eq targetRuleInfo('buildClientFinishedV3) = {'buildClientFinishedV3, send, client} .
  eq targetRuleInfo('buildClientKeyUpdateRequestV3) = {'buildClientKeyUpdateRequestV3, send, client} .
  eq targetRuleInfo('buildClientKeyUpdateResponseV3) = {'buildClientKeyUpdateResponseV3, send, client} .
  eq targetRuleInfo('processHelloRetryRequestV3) = {'processHelloRetryRequestV3, receive, client} .
  eq targetRuleInfo('processServerHelloV3) = {'processServerHelloV3, receive, client} .
  eq targetRuleInfo('processEncryptedExtensionV3) = {'processEncryptedExtensionV3, receive, client} .
  eq targetRuleInfo('processCertificateRequestV3) = {'processCertificateRequestV3, receive, client} .
  eq targetRuleInfo('processServerCertificateV3) = {'processServerCertificateV3, receive, client} .
  eq targetRuleInfo('processServerCertificateVerifyV3) = {'processServerCertificateVerifyV3, receive, client} .
  eq targetRuleInfo('processServerFinishedV3) = {'processServerFinishedV3, receive, client} .
  eq targetRuleInfo('processNewSessionTicketV3) = {'processNewSessionTicketV3, receive, client} .
  eq targetRuleInfo('processPostClientAuthenticationV3) = {'processPostClientAuthenticationV3, receive, client} .
  eq targetRuleInfo('processServerKeyUpdateRequestV3) = {'processServerKeyUpdateRequestV3, receive, client} .
  eq targetRuleInfo('processServerKeyUpdateResponseV3) = {'processServerKeyUpdateResponseV3, receive, client} .

  eq targetRuleInfo('buildHelloRetryRequestV3) = {'buildHelloRetryRequestV3, send, server} .
  eq targetRuleInfo('buildServerHelloV3) = {'buildServerHelloV3, send, server} .
  eq targetRuleInfo('buildEncryptedExtensionV3) = {'buildEncryptedExtensionV3, send, server} .
  eq targetRuleInfo('buildCertificateRequestV3) = {'buildCertificateRequestV3, send, server} .
  eq targetRuleInfo('buildServerCertificateV3) = {'buildServerCertificateV3, send, server} .
  eq targetRuleInfo('buildServerCertificateVerifyV3) = {'buildServerCertificateVerifyV3, send, server} .
  eq targetRuleInfo('buildServerFinishedV3) = {'buildServerFinishedV3, send, server} .
  eq targetRuleInfo('buildNewSessionTicketV3) = {'buildNewSessionTicketV3, send, server} .
  eq targetRuleInfo('buildPostClientAuthenticationV3) = {'buildPostClientAuthenticationV3, send, server} .
  eq targetRuleInfo('buildServerKeyUpdateRequestV3) = {'buildServerKeyUpdateRequestV3, send, server} .
  eq targetRuleInfo('buildServerKeyUpdateResponseV3) = {'buildServerKeyUpdateResponseV3, send, server} .
  eq targetRuleInfo('processClientHelloV3) = {'processClientHelloV3, receive, server} .
  eq targetRuleInfo('processEarlyDataV3) = {'processEarlyDataV3, receive, server} .
  eq targetRuleInfo('discardEarlyDataV3) = {'discardEarlyDataV3, receive, server} .
  eq targetRuleInfo('processEndOfEarlyDataV3) = {'processEndOfEarlyDataV3, receive, server} .
  eq targetRuleInfo('processClientCertificateV3) = {'processClientCertificateV3, receive, server} .
  eq targetRuleInfo('processClientCertificateVerifyV3) = {'processClientCertificateVerifyV3, receive, server} .
  eq targetRuleInfo('processClientFinishedV3) = {'processClientFinishedV3, receive, server} .
  eq targetRuleInfo('processClientKeyUpdateRequestV3) = {'processClientKeyUpdateRequestV3, receive, server} .
  eq targetRuleInfo('processClientKeyUpdateResponseV3) = {'processClientKeyUpdateResponseV3, receive, server} .
endom

omod APPLY-RULE-MODIFICATION is
  protecting BEHAVIOR-DEVIATION-SPECIFICATION .
  protecting BEHAVIOR-MODIFICATION .
  protecting SET{BehaviorDVSpec} .
  protecting OBJECT-WITH-ACTION .
  protecting LINK-OBJECT .
  protecting COMMON-AUX-OPERATOR .
  protecting META-LEVEL .

  vars BS BS' : BehaviorDVSpec .
  var BSS : Set{BehaviorDVSpec} .
  vars LABEL MID RID : Qid .
  var AP : ActionProposition .
  vars BMOD BMOD' : BehaviorModification .
  var BMODS : Set{BehaviorModification} .
  var RLABEL : RFCLabel .

  vars RULE RULE' : Rule .
  vars RULES RULES' : RuleSet .
  vars T1 T2 T3 T4 LABELT : Term .
  vars COND COND' : Condition .
  var AS : AttrSet .
  var S : Sort .

  vars CONF CONF' : Configuration .
  var OBJ : Object .
  var ACT : FormalAction .
  vars TI TI' : TId .
  var MSGS : List{TLSMsg} .
  vars MC MC' EMC EMC' TSC : MsgContent .
  vars CT CT' : ContentType .
  vars PV PV' : ProtocolVersion .
  vars PVL PVL' PVL'' PVL''' : List{ProtocolVersion} .
  vars SZ SZ' : MsgSize .
  vars AD AD' : AlertDescription .
  vars AL AL' : AlertLevel .
  vars HT HT' : HandshakeType .
  vars CSL CSL' CSL'' CSL''' : List{CipherSuite} .
  vars CML CML' CML'' CML''' : List{CompressionMethod} .
  vars NONCE NONCE' : Nonce .
  vars NONCE? NONCE?' : Nonce? .
  vars CERTL CERTL' CERTL'' CERTL''' : List{Certificate} .
  vars CTL CTL' CTL'' CTL''' : List{CertificateType} .
  vars SAL SAL' SAL'' SAL''' : List{SignatureAlgorithm} .
  vars TIL TIL' : List{TId} .
  vars NGL NGL' NGL'' NGL''' : List{NamedGroup} .
  vars KSL KSL' KSL'' KSL''' : List{KeyShareEntry} .
  vars PKML PKML' PKML'' PKML''' : List{PreSharedKeyExchangeMode} .
  vars OFL OFL' OFL'' OFL''' : List{OIDFilter} .
  vars PKM PKM' : PreSharedKeyExchangeMode .
  vars EXT EXT' : Extension .
  vars KUR KUR' : KeyUpdateRequest .
  vars SA SA' : SignatureAlgorithm .
  var FF : FiniteField .
  var NC : NamedCurve .
  vars N N' : Nat .
  var MVAL : MessageValue .
  var KEY : Key .
  var TICKET : TicketId .
  var TICKETL : List{TicketId} .
  vars BINDERL BINDERL' : List{Nonce} .
  vars CST CST' : ClientState .
  vars SST SST' : ServerState .
  vars CS CS' : CipherSuite .
  vars CM CM' : CompressionMethod .
  vars SESS SESS' : SessionState .
  vars NG NG' : NamedGroup .
  vars B B' : Bool .
  vars AID AID' : AttributeId .
  var MSGID : MessageId .
  vars AVAL AVAL' : AttributeValue .

  op applyRules : Set{BehaviorModification} RuleSet -> RuleSet .
  eq applyRules(BMODS, RULE RULES)
   = applyRule(RULE, BMODS) applyRules(BMODS, RULES) .
  eq applyRules(BMODS, none) = none .

  op applyRule : Rule Set{BehaviorModification} -> Rule .
  eq applyRule(crl T1 => T2 if COND [AS] ., BMODS)
   = (crl T1 => 'applyTerms[T2, upTerm(BMODS)] if applyCond(COND, BMODS) [AS] .) .
  eq applyRule(rl T1 => T2 [AS] ., BMODS)
   = (rl T1 => 'applyTerms[T2, upTerm(BMODS)] [AS] .) .


  ------------------------------
  --- Condition Modification ---
  ------------------------------
  op applyCond : Condition Set{BehaviorModification} -> Condition .
  eq applyCond(COND, (noCheck(RLABEL), BMODS))
   = applyCond(removeRfcCheck(COND, upTerm(RLABEL)), BMODS) .
  eq applyCond(COND, (BMOD, BMODS)) = applyCond(modifyMsg(COND, BMOD), BMODS) [owise] .
  eq applyCond(COND, empty) = COND .

  op modifyMsg : Condition BehaviorModification -> Condition .
  ceq modifyMsg(COND /\ ('MC':MsgContent := T1) /\ COND', BMOD)
   = COND /\ ('MC':MsgContent := 'applyMsg[T1, upTerm(BMOD)]) /\ COND'
  if isRecordHeaderModification?(BMOD) .
 ceq modifyMsg(COND /\ ('MC:MsgContent := 'buildClientHelloWithPSK[T1, T2]) /\ COND', BMOD)
   = COND /\ ('MC:MsgContent := 'buildClientHelloWithPSK[T1, 'applyMsg[T2, upTerm(BMOD)]]) /\ COND'
  if isClientHelloBinderCoveredModification?(BMOD) .
 ceq modifyMsg(COND /\ ('MC:MsgContent := 'buildSecondClientHelloWithPSK[T1, T2, T3]) /\ COND', BMOD)
   = COND /\ ('MC:MsgContent := 'buildSecondClientHelloWithPSK[T1, 'applyMsg[T2, upTerm(BMOD)], T3]) /\ COND'
  if isClientHelloBinderCoveredModification?(BMOD) .
 ceq modifyMsg(COND /\ ('MC:MsgContent := T1) /\ COND', BMOD)
   = COND /\ ('MC:MsgContent := 'applyMsg[T1, upTerm(BMOD)]) /\ COND'
  if isHandshakeBodyModification?(BMOD)
  /\ not isRecordHeaderModification?(BMOD)
  /\ not isClientHelloBinderCoveredTerm?(T1, BMOD) .
  eq modifyMsg(COND, BMOD) = COND [owise] .

  op removeRfcCheck : Condition Term -> Condition .
  eq removeRfcCheck(('rfc-requirement[T1, LABELT, T2, T3] = 'true.Bool) /\ COND, LABELT)
   = removeRfcCheck(COND, LABELT) .
  eq removeRfcCheck('rfc-requirement[T1, LABELT, T2, T3] = 'true.Bool, LABELT)
   = nil .
  eq removeRfcCheck((T1 := T2) /\ COND, LABELT)
   = (T1 := T2) /\ removeRfcCheck(COND, LABELT) [owise] .
  eq removeRfcCheck((T1 = T2) /\ COND, LABELT)
   = (T1 = T2) /\ removeRfcCheck(COND, LABELT) [owise] .
  eq removeRfcCheck((T1 : S) /\ COND, LABELT)
   = (T1 : S) /\ removeRfcCheck(COND, LABELT) [owise] .
  eq removeRfcCheck((T1 => T2) /\ COND, LABELT)
   = (T1 => T2) /\ removeRfcCheck(COND, LABELT) [owise] .
  eq removeRfcCheck(COND, LABELT) = COND [owise] .

  op isHandshakeBodyModification? : BehaviorModification -> Bool .
  eq isHandshakeBodyModification?(setM(MSGID, MVAL)) = true .
  eq isHandshakeBodyModification?(add(MSGID, MVAL)) = true .
  eq isHandshakeBodyModification?(remove(MSGID)) = true .
  eq isHandshakeBodyModification?(BMOD) = false [owise] .

  op isRecordHeaderModification? : BehaviorModification -> Bool .
  eq isRecordHeaderModification?(setM(#contentType, MVAL)) = true .
  eq isRecordHeaderModification?(setM(#version, MVAL)) = true .
  eq isRecordHeaderModification?(setM(#recordLen, MVAL)) = true .
  eq isRecordHeaderModification?(add(#contentType, MVAL)) = true .
  eq isRecordHeaderModification?(add(#version, MVAL)) = true .
  eq isRecordHeaderModification?(add(#recordLen, MVAL)) = true .
  eq isRecordHeaderModification?(remove(#contentType)) = true .
  eq isRecordHeaderModification?(remove(#version)) = true .
  eq isRecordHeaderModification?(remove(#recordLen)) = true .
  eq isRecordHeaderModification?(BMOD) = false [owise] .

  op isClientHelloBinderCoveredTerm? : Term BehaviorModification -> Bool .
  eq isClientHelloBinderCoveredTerm?('buildClientHelloWithPSK[T1, T2], BMOD)
   = isClientHelloBinderCoveredModification?(BMOD) .
  eq isClientHelloBinderCoveredTerm?('buildSecondClientHelloWithPSK[T1, T2, T3], BMOD)
   = isClientHelloBinderCoveredModification?(BMOD) .
  eq isClientHelloBinderCoveredTerm?(T1, BMOD) = false [owise] .

  op isClientHelloBinderCoveredModification? : BehaviorModification -> Bool .
  eq isClientHelloBinderCoveredModification?(setM(MSGID, MVAL)) = isClientHelloBinderCoveredMsgId?(MSGID) .
  eq isClientHelloBinderCoveredModification?(add(MSGID, MVAL)) = isClientHelloBinderCoveredMsgId?(MSGID) .
  eq isClientHelloBinderCoveredModification?(remove(MSGID)) = isClientHelloBinderCoveredMsgId?(MSGID) .
  eq isClientHelloBinderCoveredModification?(BMOD) = false [owise] .

  op isClientHelloBinderCoveredMsgId? : MessageId -> Bool .
  eq isClientHelloBinderCoveredMsgId?(#handshakeType) = true .
  eq isClientHelloBinderCoveredMsgId?(#handshakeLen) = true .
  eq isClientHelloBinderCoveredMsgId?(#protocol) = true .
  eq isClientHelloBinderCoveredMsgId?(#cipherSuites) = true .
  eq isClientHelloBinderCoveredMsgId?(#cipherSuitesLen) = true .
  eq isClientHelloBinderCoveredMsgId?(#random) = true .
  eq isClientHelloBinderCoveredMsgId?(#sessionId) = true .
  eq isClientHelloBinderCoveredMsgId?(#sessionIdLen) = true .
  eq isClientHelloBinderCoveredMsgId?(#compressions) = true .
  eq isClientHelloBinderCoveredMsgId?(#compressionsLen) = true .
  eq isClientHelloBinderCoveredMsgId?(#supported-versions) = true .
  eq isClientHelloBinderCoveredMsgId?(#supported-versions-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#signature-algorithms) = true .
  eq isClientHelloBinderCoveredMsgId?(#signature-algorithms-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#signature-algorithms-cert) = true .
  eq isClientHelloBinderCoveredMsgId?(#signature-algorithms-cert-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#key-shares) = true .
  eq isClientHelloBinderCoveredMsgId?(#key-shares-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#key-shares-groups) = true .
  eq isClientHelloBinderCoveredMsgId?(#supported-groups) = true .
  eq isClientHelloBinderCoveredMsgId?(#supported-groups-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#psk-key-exchange-mode) = true .
  eq isClientHelloBinderCoveredMsgId?(#psk-key-exchange-mode-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#early-data) = true .
  eq isClientHelloBinderCoveredMsgId?(#early-data-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#post-handshake) = true .
  eq isClientHelloBinderCoveredMsgId?(#post-handshake-len) = true .
  eq isClientHelloBinderCoveredMsgId?(#renegotiation-info) = true .
	  eq isClientHelloBinderCoveredMsgId?(#renegotiation-info-len) = true .
	  eq isClientHelloBinderCoveredMsgId?(#cks) = true .
	  eq isClientHelloBinderCoveredMsgId?(#cks-len) = true .
	  eq isClientHelloBinderCoveredMsgId?(#cookie) = true .
	  eq isClientHelloBinderCoveredMsgId?(#cookie-len) = true .
	  eq isClientHelloBinderCoveredMsgId?(#unknown-extension) = true .
	  eq isClientHelloBinderCoveredMsgId?(#unknown-extension-len) = true .
	  eq isClientHelloBinderCoveredMsgId?(#status-request-v2) = true .
	  eq isClientHelloBinderCoveredMsgId?(#status-request-v2-len) = true .
	  eq isClientHelloBinderCoveredMsgId?(#extensionLen) = true .
  eq isClientHelloBinderCoveredMsgId?(MSGID) = false [owise] .

  -------------------------
  --- Term Modification ---
  -------------------------
  op applyTerms : Configuration Set{BehaviorModification} -> Configuration .
  eq applyTerms(CONF, (BMOD, BMODS)) = applyTerms(applyTerm(CONF, BMOD), BMODS) .
  eq applyTerms(CONF, empty) = CONF .

  op dropBuiltTranscript : MsgContent MsgContent -> MsgContent .
  eq dropBuiltTranscript(TSC MC, MC) = TSC .
  eq dropBuiltTranscript(TSC, MC) = TSC [owise] .

  op getMsgFromFormalAction : FormalAction -> MsgContent .
  eq getMsgFromFormalAction(buildClientHelloV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerHelloV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerCertificateV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerKeyExchangeV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildCertificateRequestV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerHelloDoneV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientKeyExchangeV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientCertificateV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientCertificateVerifyV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientChangeCipherSpecV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerChangeCipherSpecV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientFinishedV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerFinishedV2(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientHelloV3(MC, TI)) = removeRecord(MC) .
  eq getMsgFromFormalAction(buildServerHelloV3(MC, TI)) = removeRecord(MC) .
  eq getMsgFromFormalAction(buildHelloRetryRequestV3(MC, TI)) = MC .  
  eq getMsgFromFormalAction(buildEncryptedExtensionV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildCertificateRequestV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerCertificateV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerCertificateVerifyV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerFinishedV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientCertificateV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientCertificateVerifyV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientFinishedV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildPostClientAuthenticationV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientKeyUpdateRequestV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildClientKeyUpdateResponseV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerKeyUpdateRequestV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildServerKeyUpdateResponseV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildEarlyDataV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(buildEndOfEarlyDataV3(MC, MC', TI)) = MC .
  eq getMsgFromFormalAction(skipF(ACT)) = empty .
  eq getMsgFromFormalAction(ACT) = empty [owise] .

  op applyTerm : Configuration BehaviorModification -> Configuration .

  eq applyTerm(CONF {OBJ, ACT}, setF(AID, AVAL))
   = applyTerm(CONF, setF(AID, AVAL)) {applyObject(OBJ, setF(AID, AVAL)), ACT} .

  eq applyTerm(< TI to TI' : Link | msgQueue : MSGS :: {MC'} > 
              {< TI : TLS | transcript : TSC >, ACT} CONF, skip())
   = < TI to TI' : Link | msgQueue : MSGS >
     {< TI : TLS | transcript : dropBuiltTranscript(TSC, getMsgFromFormalAction(ACT)) >, skipF(ACT)} CONF .

  eq applyTerm(CONF, BMOD) = CONF [owise] .

  ----------------------------
  --- Message Modification ---
  ----------------------------
  op applyMsg : MsgContent BehaviorModification -> MsgContent .
  eq applyMsg(MC, skip()) = empty .

  eq applyMsg(contentType(CT) MC, setM(#contentType, mv[CT'])) = contentType(CT') MC .
  eq applyMsg(version(PV) MC, setM(#version, mv[PV' PVL])) = version(PV') MC .
  eq applyMsg(recordLen(SZ) MC, setM(#recordLen, mv[SZ'])) = recordLen(SZ') MC .
  eq applyMsg(alertDesc(AD) MC, setM(#alertDesc, mv[AD'])) = alertDesc(AD') MC .
  eq applyMsg(alertLev(AL) MC, setM(#alertLev, mv[AL'])) = alertLev(AL') MC .
