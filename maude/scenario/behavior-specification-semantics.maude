  eq applyMsg(verifyData(NONCE, NONCE') MC, setM(#verifyData, mv[NONCE?])) = verifyData(NONCE?, NONCE?) MC .
  eq applyMsg(signature(encrypt(KEY, MC')) MC, setM(#signature, mv[NONCE?]))
   = signature(encrypt(KEY, empty)) MC .
