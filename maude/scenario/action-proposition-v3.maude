  sd executeAction(AP) := guardAction(AP, {'buildServerCertificateVerifyV3, send, server}) ; buildServerCertificateVerifyV3 .
  sd executeAction(AP) := guardAction(AP, {'buildServerFinishedV3, send, server}) ; buildServerFinishedV3 .
  sd executeAction(AP) := guardAction(AP, {'buildNewSessionTicketV3, send, server}) ; buildNewSessionTicketV3 .
  sd executeAction(AP) := guardAction(AP, {'buildPostClientAuthenticationV3, send, server}) ; buildPostClientAuthenticationV3 .
  sd executeAction(AP) := guardAction(AP, {'buildServerKeyUpdateRequestV3, send, server}) ; buildServerKeyUpdateRequestV3 .
  sd executeAction(AP) := guardAction(AP, {'buildServerKeyUpdateResponseV3, send, server}) ; buildServerKeyUpdateResponseV3 .
