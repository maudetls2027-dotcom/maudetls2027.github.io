  sd executeAction(AP) := guardAction(AP, {'processServerCertificateVerifyV3, receive, client}) ; processServerCertificateVerifyV3 .
  sd executeAction(AP) := guardAction(AP, {'processServerFinishedV3, receive, client}) ; processServerFinishedV3 .
  sd executeAction(AP) := guardAction(AP, {'processNewSessionTicketV3, receive, client}) ; processNewSessionTicketV3 .
  sd executeAction(AP) := guardAction(AP, {'processPostClientAuthenticationV3, receive, client}) ; processPostClientAuthenticationV3 .
  sd executeAction(AP) := guardAction(AP, {'processServerKeyUpdateRequestV3, receive, client}) ; processServerKeyUpdateRequestV3 .
  sd executeAction(AP) := guardAction(AP, {'processServerKeyUpdateResponseV3, receive, client}) ; processServerKeyUpdateResponseV3 .

  sd executeAction(AP) := guardAction(AP, {'buildHelloRetryRequestV3, send, server}) ; buildHelloRetryRequestV3 .
