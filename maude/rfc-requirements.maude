endm

mod RFC-REQUIREMENT is
  protecting TLS-OBJECT .
  protecting RFC-LABEL .
  protecting RFC-REQUIREMENT-ALERT-DESCRIPTION-PAIR .

  var CS : CipherSuite .
  var CSL : List{CipherSuite} .
  var NG : NamedGroup .
  var NGL : List{NamedGroup} .
  var KSL : List{KeyShareEntry} .
  var NONCE : Nonce .

  op rfc-requirement : RFCRequirementTarget RFCLabel MsgContent Object -> Bool .

  op rfcCipherSuiteAllowedBySecurity : CipherSuite -> Bool .
  eq rfcCipherSuiteAllowedBySecurity(TLS-RSA-WITH-NULL-MD5) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-RSA-WITH-NULL-SHA) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-RSA-WITH-NULL-SHA256) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-PSK-WITH-NULL-SHA) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-PSK-WITH-NULL-SHA256) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-PSK-WITH-NULL-SHA384) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-ECDHE-ECDSA-WITH-NULL-SHA) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-ECDHE-PSK-WITH-NULL-SHA256) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-DHE-PSK-WITH-NULL-SHA256) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-DHE-PSK-WITH-NULL-SHA384) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-ECDHE-RSA-WITH-RC4-128-SHA) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-ECDHE-ECDSA-WITH-RC4-128-SHA) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-ECDH-RSA-WITH-RC4-128-SHA) = false .
  eq rfcCipherSuiteAllowedBySecurity(TLS-ECDH-ECDSA-WITH-RC4-128-SHA) = false .
  eq rfcCipherSuiteAllowedBySecurity(CS) = true [owise] .

  op rfcCipherSuitesAllowedBySecurity : List{CipherSuite} -> Bool .
  eq rfcCipherSuitesAllowedBySecurity((CS CSL)) =
     rfcCipherSuiteAllowedBySecurity(CS) and rfcCipherSuitesAllowedBySecurity(CSL) .
  eq rfcCipherSuitesAllowedBySecurity(nil) = true .

  op rfcAllowedTls13NamedGroup : NamedGroup -> Bool .
  eq rfcAllowedTls13NamedGroup(secp256r1) = true .
  eq rfcAllowedTls13NamedGroup(secp384r1) = true .
  eq rfcAllowedTls13NamedGroup(secp521r1) = true .
  eq rfcAllowedTls13NamedGroup(ffdhe2048) = true .
  eq rfcAllowedTls13NamedGroup(ffdhe3072) = true .
  eq rfcAllowedTls13NamedGroup(ffdhe4096) = true .
  eq rfcAllowedTls13NamedGroup(ffdhe6144) = true .
  eq rfcAllowedTls13NamedGroup(ffdhe8192) = true .
  eq rfcAllowedTls13NamedGroup(NG) = false [owise] .

  op rfcAllowedTls13NamedGroups : List{NamedGroup} -> Bool .
  eq rfcAllowedTls13NamedGroups((NG NGL)) =
     rfcAllowedTls13NamedGroup(NG) and rfcAllowedTls13NamedGroups(NGL) .
  eq rfcAllowedTls13NamedGroups(nil) = true .

  op rfcAllowedTls13KeyShareGroups : List{KeyShareEntry} -> Bool .
  eq rfcAllowedTls13KeyShareGroups(({NG,NONCE} KSL)) =
     rfcAllowedTls13NamedGroup(NG) and rfcAllowedTls13KeyShareGroups(KSL) .
  eq rfcAllowedTls13KeyShareGroups(nil) = true .
endm

omod CHECK-RFC-REQUIREMENTS is
  protecting RFC-REQUIREMENT .
  protecting HANDSHAKE-TYPE .
  protecting NAT .
  protecting TLS-MESSAGE-CONTENT .
  protecting ALERT-DESCRIPTION? .
  protecting RFC-REQUIREMENT-ALERT-DESCRIPTION-PAIR .

  var RT : RFCRequirementTarget .
  var N : Nat .
  var MC : MsgContent .
  var OBJ : Object .

  op checkRequirements : RFCRequirementTarget Nat MsgContent Object -> AlertDescription? .

  eq checkRequirements(RT, s N, MC, OBJ)
   = if not rfc-requirement(RT, label[s N], MC, OBJ)
     then getAlertDescription(RT, label[s N])
     else checkRequirements(RT, N, MC, OBJ)
     fi .

  eq checkRequirements(RT, 0, MC, OBJ) = noError .
endom

omod TLS13-RFC-REQUIREMENTS-COMMON is
  protecting RFC-REQUIREMENT .
  protecting COMMON-AUX-OPERATOR .
  protecting HRR-RANDOM .
  protecting CHECK-RFC-REQUIREMENTS .

  vars MC TSC HC : MsgContent .
  vars EXT EXT' EXT'' : Extension .
  vars PV PV' : ProtocolVersion .
  vars PVL PVL' : List{ProtocolVersion} .
  var N : Nat .
  vars KSL KSL' : List{KeyShareEntry} .
  vars KS : KeyShareEntry .
  vars NG NG' : NamedGroup .
  vars NGL NGL' : List{NamedGroup} .
  vars CS CS' : CipherSuite .
  vars NONCE NONCE' : Nonce .
  vars VDATA? CV? SV? COOKIE? : Nonce? .
  var TICKETL : List{TicketId} .
  var BINDERL : List{Nonce} .
  var CERTL : List{Certificate} .
  vars KEYS : Set{Key} .
  var KEY : Key .
  var SIGN : EncrMsgContent .
  var SH : SignatureAlgorithm .
  vars SCL SCL' SCL'' : List{SignatureAlgorithm} .
  vars AUTH AUTH' : AuthenticationAlgorithm .
  vars HALGO HALGO' : HashAlgorithm .
  var PKA : PublicKeyAlgorithm .
  var CITEM : CertificateItems .
  var CERT : Certificate .
  vars CEOID CEOID' : CertificateExtensionOid .
  vars OID OID' : ObjectId .
  var OIDL : List{ObjectId} .
  vars OFL OFL' : List{OIDFilter} .
  var KU : X509KeyUsage .
  var KUL : List{X509KeyUsage} .
  var HT : HandshakeType .
  vars SZ SZ' : MsgSize .
  vars HSEC VDATA : Nonce .
  var CS? : ClientState .
  
  op keyShareEntriesFollowSupportedGroups : List{KeyShareEntry} List{NamedGroup} -> Bool .
  eq keyShareEntriesFollowSupportedGroups(nil, NGL) = true .
  eq keyShareEntriesFollowSupportedGroups(({NG,NONCE} KSL), NG NGL) = keyShareEntriesFollowSupportedGroups(KSL, NGL) .
 ceq keyShareEntriesFollowSupportedGroups(({NG,NONCE} KSL), NG' NGL) = keyShareEntriesFollowSupportedGroups(({NG,NONCE} KSL), NGL)
   if NG =/= NG' .
  eq keyShareEntriesFollowSupportedGroups(({NG,NONCE} KSL), nil) = false .


  op rfcAllowedHelloRetryRequestExtensions : Extension -> Bool .
  eq rfcAllowedHelloRetryRequestExtensions(supported-versions(PVL) EXT) = rfcAllowedHelloRetryRequestExtensions(EXT) .
  eq rfcAllowedHelloRetryRequestExtensions(supported-versions-len(SZ) EXT) = rfcAllowedHelloRetryRequestExtensions(EXT) .
  eq rfcAllowedHelloRetryRequestExtensions(key-shares(NG) EXT) = rfcAllowedHelloRetryRequestExtensions(EXT) .
  eq rfcAllowedHelloRetryRequestExtensions(key-shares-len(SZ) EXT) = rfcAllowedHelloRetryRequestExtensions(EXT) .
  eq rfcAllowedHelloRetryRequestExtensions(cookie EXT) = rfcAllowedHelloRetryRequestExtensions(EXT) .
  eq rfcAllowedHelloRetryRequestExtensions(cookie(COOKIE?) EXT) = rfcAllowedHelloRetryRequestExtensions(EXT) .
  eq rfcAllowedHelloRetryRequestExtensions(cookie-len(SZ) EXT) = rfcAllowedHelloRetryRequestExtensions(EXT) .
  eq rfcAllowedHelloRetryRequestExtensions(EXT) = EXT == empty [owise] .


  op rfcHrrSelectedGroupWasOffered : List{KeyShareEntry} NamedGroup -> Bool .
  eq rfcHrrSelectedGroupWasOffered({NG,NONCE} KSL, NG) = true .
 ceq rfcHrrSelectedGroupWasOffered({NG,NONCE} KSL, NG') = rfcHrrSelectedGroupWasOffered(KSL, NG')
   if NG =/= NG' .
  eq rfcHrrSelectedGroupWasOffered(nil, NG) = false .


  op rfcHrrSelectedGroupChangesClientHello : Extension Extension -> Bool .
  eq rfcHrrSelectedGroupChangesClientHello(key-shares(KSL) EXT, key-shares(NG) EXT') =
    KSL == nil or not rfcHrrSelectedGroupWasOffered(KSL, NG) .
  eq rfcHrrSelectedGroupChangesClientHello(EXT, EXT') = true [owise] .


  op rfcHrrSelectedGroupWasSupported : Extension Extension -> Bool .
  eq rfcHrrSelectedGroupWasSupported(supported-groups(NGL) EXT, key-shares(NG) EXT') = occurs(NG, NGL) .
  eq rfcHrrSelectedGroupWasSupported(EXT, EXT') = false [owise] .


  op rfcNoSecondHelloRetryRequest : MsgContent -> Bool .
  eq rfcNoSecondHelloRetryRequest(handshakeType(hello-retry-request) random(hrrNonce) MC) = false .
  eq rfcNoSecondHelloRetryRequest(MC) = true [owise] .


  op rfcServerVersionWasOffered : Extension Extension -> Bool .
  eq rfcServerVersionWasOffered(supported-versions(PVL) EXT, supported-versions(PV) EXT') = occurs(PV, PVL) .
  eq rfcServerVersionWasOffered(EXT, EXT') = true [owise] .


  op rfcServerHelloSelectedVersionMatchesHrr : MsgContent Extension -> Bool .
  eq rfcServerHelloSelectedVersionMatchesHrr(random(hrrNonce) extensions(supported-versions(PV) EXT) MC,
                                             supported-versions(PV) EXT')
   = true .
 ceq rfcServerHelloSelectedVersionMatchesHrr(random(hrrNonce) extensions(supported-versions(PV) EXT) MC,
                                             supported-versions(PV') EXT')
   = false
  if PV =/= PV' .
  eq rfcServerHelloSelectedVersionMatchesHrr(TSC, EXT) = true [owise] .


  op rfcServerHelloCipherSuiteMatchesHrr : MsgContent CipherSuite -> Bool .
  eq rfcServerHelloCipherSuiteMatchesHrr(random(hrrNonce) cipherSuites(CS) MC, CS)
   = true .
 ceq rfcServerHelloCipherSuiteMatchesHrr(random(hrrNonce) cipherSuites(CS) MC, CS')
   = false
  if CS =/= CS' .
  eq rfcServerHelloCipherSuiteMatchesHrr(TSC, CS) = true [owise] .


  op rfcAllowedServerHelloExtension : Extension -> Bool .
  eq rfcAllowedServerHelloExtension(supported-versions(PVL) EXT) = rfcAllowedServerHelloExtension(EXT) .
  eq rfcAllowedServerHelloExtension(supported-versions-len(SZ) EXT) = rfcAllowedServerHelloExtension(EXT) .
  eq rfcAllowedServerHelloExtension(key-shares(KS) EXT) = rfcAllowedServerHelloExtension(EXT) .
  eq rfcAllowedServerHelloExtension(key-shares-len(SZ) EXT) = rfcAllowedServerHelloExtension(EXT) .
  eq rfcAllowedServerHelloExtension(pre-shared-key(N) EXT) = rfcAllowedServerHelloExtension(EXT) .
  eq rfcAllowedServerHelloExtension(pre-shared-key-len(SZ) EXT) = rfcAllowedServerHelloExtension(EXT) .
  eq rfcAllowedServerHelloExtension(EXT) = EXT == empty [owise] .


  op rfcServerHelloExtensionWasRequested : Extension Extension -> Bool .
  eq rfcServerHelloExtensionWasRequested(supported-versions(PVL) EXT, supported-versions(PVL') EXT') = rfcServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfcServerHelloExtensionWasRequested(supported-versions-len(SZ) EXT, supported-versions-len(SZ') EXT') = rfcServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfcServerHelloExtensionWasRequested(key-shares(KSL) EXT, key-shares(KS) EXT') = rfcServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfcServerHelloExtensionWasRequested(key-shares-len(SZ) EXT, key-shares-len(SZ') EXT') = rfcServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfcServerHelloExtensionWasRequested(pre-shared-key(TICKETL, BINDERL) EXT, pre-shared-key(N) EXT') = rfcServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfcServerHelloExtensionWasRequested(pre-shared-key-len(SZ) EXT, pre-shared-key-len(SZ') EXT') = rfcServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfcServerHelloExtensionWasRequested(EXT, EXT') = EXT' == empty .


  op rfcServerHelloKeyShareMatchesClient : Extension Extension -> Bool .
  eq rfcServerHelloKeyShareMatchesClient(key-shares({NG,NONCE} KSL) EXT, key-shares({NG,NONCE'}) EXT') = true .
 ceq rfcServerHelloKeyShareMatchesClient(key-shares({NG,NONCE} KSL) EXT, key-shares({NG',NONCE'} KSL') EXT')
   = rfcServerHelloKeyShareMatchesClient(key-shares(KSL) EXT, key-shares({NG',NONCE'} KSL') EXT')
   if NG =/= NG' .
  eq rfcServerHelloKeyShareMatchesClient(key-shares((nil).List{KeyShareEntry}) EXT, key-shares(KSL) EXT') = false .
  eq rfcServerHelloKeyShareMatchesClient(EXT, EXT') = true [owise] .


  op rfcServerHelloKeyShareGroupWasSupported : Extension Extension -> Bool .
  eq rfcServerHelloKeyShareGroupWasSupported(supported-groups(NGL) EXT, key-shares({NG,NONCE}) EXT') = occurs(NG, NGL) .
  eq rfcServerHelloKeyShareGroupWasSupported(EXT, EXT') = true [owise] .


  op rfcAllowedTls13ServerHelloKeyShareGroup : Extension -> Bool .
  eq rfcAllowedTls13ServerHelloKeyShareGroup(key-shares({NG,NONCE}) EXT)
   = rfcAllowedTls13NamedGroup(NG) .
  eq rfcAllowedTls13ServerHelloKeyShareGroup(EXT) = true [owise] .


  op rfcAllowedTls13HelloRetryRequestKeyShareGroup : Extension -> Bool .
  eq rfcAllowedTls13HelloRetryRequestKeyShareGroup(key-shares(NG) EXT)
   = rfcAllowedTls13NamedGroup(NG) .
  eq rfcAllowedTls13HelloRetryRequestKeyShareGroup(EXT) = true [owise] .


  op rfcServerHelloPskKeAllowsKeyShare : Extension Extension -> Bool .
  eq rfcServerHelloPskKeAllowsKeyShare(psk-key-exchange-mode(psk-ke) EXT, key-shares(KS) EXT') = false .
  eq rfcServerHelloPskKeAllowsKeyShare(EXT, EXT') = true [owise] .


  op rfcServerHelloPskDheHasKeyShare : Extension Extension -> Bool .
  eq rfcServerHelloPskDheHasKeyShare(psk-key-exchange-mode(psk-dhe-ke) EXT, EXT') = includeKeyShareExtension(EXT') .
  eq rfcServerHelloPskDheHasKeyShare(EXT, EXT') = true [owise] .


  op rfcServerHelloSelectedPskInRange : Extension Extension -> Bool .
  eq rfcServerHelloSelectedPskInRange(pre-shared-key(TICKETL, BINDERL) EXT, pre-shared-key(N) EXT') = N < size(TICKETL) .
  eq rfcServerHelloSelectedPskInRange(EXT, EXT') = true [owise] .


  op rfcServerHelloKeyShareRequired : Extension Extension -> Bool .
  eq rfcServerHelloKeyShareRequired(psk-key-exchange-mode(psk-ke) EXT, EXT') = true .
  eq rfcServerHelloKeyShareRequired(psk-key-exchange-mode(psk-dhe-ke) EXT, EXT') = true .
  eq rfcServerHelloKeyShareRequired(EXT, EXT') = includeKeyShareExtension(EXT') [owise] .


  op rfcServerHelloSelectedPskPresent : Extension Extension -> Bool .
  eq rfcServerHelloSelectedPskPresent(pre-shared-key(TICKETL, BINDERL) EXT, EXT') = includeSelectedPSKExtension(EXT') .
  eq rfcServerHelloSelectedPskPresent(EXT, EXT') = true [owise] .


  op rfcAllowedEncryptedExtensions : Extension -> Bool .
  eq rfcAllowedEncryptedExtensions(supported-groups(NGL) EXT) = rfcAllowedEncryptedExtensions(EXT) .
  eq rfcAllowedEncryptedExtensions(supported-groups-len(SZ) EXT) = rfcAllowedEncryptedExtensions(EXT) .
  eq rfcAllowedEncryptedExtensions(early-data EXT) = rfcAllowedEncryptedExtensions(EXT) .
  eq rfcAllowedEncryptedExtensions(early-data-len(SZ) EXT) = rfcAllowedEncryptedExtensions(EXT) .
  eq rfcAllowedEncryptedExtensions(EXT) = EXT == empty [owise] .


  op rfcEncryptedExtensionWasRequested : Extension Extension -> Bool .
  eq rfcEncryptedExtensionWasRequested(supported-groups(NGL) EXT, supported-groups(NGL') EXT') = rfcEncryptedExtensionWasRequested(EXT, EXT') .
  eq rfcEncryptedExtensionWasRequested(supported-groups-len(SZ) EXT, supported-groups-len(SZ') EXT') = rfcEncryptedExtensionWasRequested(EXT, EXT') .
  eq rfcEncryptedExtensionWasRequested(early-data EXT, early-data EXT') = rfcEncryptedExtensionWasRequested(EXT, EXT') .
  eq rfcEncryptedExtensionWasRequested(early-data-len(SZ) EXT, early-data-len(SZ') EXT') = rfcEncryptedExtensionWasRequested(EXT, EXT') .
  eq rfcEncryptedExtensionWasRequested(EXT, EXT') = EXT' == empty [owise] .


  op rfcTls13ForbiddenSignatureAlgorithm : SignatureAlgorithm -> Bool .
  eq rfcTls13ForbiddenSignatureAlgorithm({AUTH,md5}) = true .
  eq rfcTls13ForbiddenSignatureAlgorithm({AUTH,sha224}) = true .
  eq rfcTls13ForbiddenSignatureAlgorithm({dsa,HALGO}) = true .
  eq rfcTls13ForbiddenSignatureAlgorithm(SH) = false [owise] .

  op rfcTls13ForbiddenSignatureAlgorithmsAbsent : List{SignatureAlgorithm} -> Bool .
  eq rfcTls13ForbiddenSignatureAlgorithmsAbsent(SH SCL)
   = (not rfcTls13ForbiddenSignatureAlgorithm(SH))
     and rfcTls13ForbiddenSignatureAlgorithmsAbsent(SCL) .
  eq rfcTls13ForbiddenSignatureAlgorithmsAbsent(nil) = true .

  op rfcTls13Sha1SignatureAlgorithmsLegacyOnly : List{SignatureAlgorithm} -> Bool .
  eq rfcTls13Sha1SignatureAlgorithmsLegacyOnly({rsa,sha} SCL)
   = rfcTls13Sha1SignatureAlgorithmsLegacyOnly(SCL) .
  eq rfcTls13Sha1SignatureAlgorithmsLegacyOnly({ecdsa,sha} SCL)
   = rfcTls13Sha1SignatureAlgorithmsLegacyOnly(SCL) .
  eq rfcTls13Sha1SignatureAlgorithmsLegacyOnly({AUTH,sha} SCL) = false [owise] .
  eq rfcTls13Sha1SignatureAlgorithmsLegacyOnly(SH SCL)
   = rfcTls13Sha1SignatureAlgorithmsLegacyOnly(SCL) [owise] .
  eq rfcTls13Sha1SignatureAlgorithmsLegacyOnly(nil) = true .

  op rfcTls13Sha1SignatureAlgorithmsLowestPriority : List{SignatureAlgorithm} -> Bool .
 ceq rfcTls13Sha1SignatureAlgorithmsLowestPriority(SCL {AUTH,sha} SCL' {AUTH',HALGO} SCL'') = false
   if HALGO =/= sha .
  eq rfcTls13Sha1SignatureAlgorithmsLowestPriority(SCL) = true [owise] .

  op rfcTls13ClientSignatureAlgorithmsValid : List{SignatureAlgorithm} -> Bool .
  eq rfcTls13ClientSignatureAlgorithmsValid(SCL)
   = rfcTls13ForbiddenSignatureAlgorithmsAbsent(SCL)
     and rfcTls13Sha1SignatureAlgorithmsLegacyOnly(SCL)
     and rfcTls13Sha1SignatureAlgorithmsLowestPriority(SCL) .

  op rfcTls13ClientSignatureSchemeListsValid : Extension -> Bool .
  eq rfcTls13ClientSignatureSchemeListsValid(signature-algorithms(SCL) EXT)
   = rfcTls13ClientSignatureAlgorithmsValid(SCL)
     and rfcTls13ClientSignatureSchemeListsValid(EXT) .
  eq rfcTls13ClientSignatureSchemeListsValid(signature-algorithms-cert(SCL) EXT)
   = rfcTls13ClientSignatureAlgorithmsValid(SCL)
     and rfcTls13ClientSignatureSchemeListsValid(EXT) .
  eq rfcTls13ClientSignatureSchemeListsValid(EXT) = true [owise] .

  op rfcTls13CertificateVerifySignatureAlgorithmAllowed : SignatureAlgorithm -> Bool .
  eq rfcTls13CertificateVerifySignatureAlgorithmAllowed({AUTH,sha}) = false .
  eq rfcTls13CertificateVerifySignatureAlgorithmAllowed(SH)
   = not rfcTls13ForbiddenSignatureAlgorithm(SH) [owise] .

  op rfcTls13NegotiatedSignatureAlgorithmsAllowed : List{SignatureAlgorithm} -> Bool .
  eq rfcTls13NegotiatedSignatureAlgorithmsAllowed({AUTH,sha} SCL) = false .
  eq rfcTls13NegotiatedSignatureAlgorithmsAllowed(SH SCL)
   = (not rfcTls13ForbiddenSignatureAlgorithm(SH))
     and rfcTls13NegotiatedSignatureAlgorithmsAllowed(SCL) .
  eq rfcTls13NegotiatedSignatureAlgorithmsAllowed(nil) = true .


  op rfcObjectIdOccurs : ObjectId List{ObjectId} -> Bool .
  eq rfcObjectIdOccurs(OID, OID OIDL) = true .
 ceq rfcObjectIdOccurs(OID, OID' OIDL) = rfcObjectIdOccurs(OID, OIDL)
   if OID =/= OID' .
  eq rfcObjectIdOccurs(OID, nil) = false .

  op rfcOidFilterOidOccurs : CertificateExtensionOid List{OIDFilter} -> Bool .
  eq rfcOidFilterOidOccurs(CEOID, oid-filter(CEOID, OIDL) OFL) = true .
 ceq rfcOidFilterOidOccurs(CEOID, oid-filter(CEOID', OIDL) OFL)
   = rfcOidFilterOidOccurs(CEOID, OFL)
   if CEOID =/= CEOID' .
  eq rfcOidFilterOidOccurs(CEOID, nil) = false .

  op rfcDuplicateOidFilters : List{OIDFilter} -> Bool .
  eq rfcDuplicateOidFilters(oid-filter(CEOID, OIDL) OFL)
   = rfcOidFilterOidOccurs(CEOID, OFL) or rfcDuplicateOidFilters(OFL) .
  eq rfcDuplicateOidFilters(nil) = false .

  op rfcOidFiltersUseAnyExtendedKeyUsage : List{OIDFilter} -> Bool .
  eq rfcOidFiltersUseAnyExtendedKeyUsage(oid-filter(id-ce-extKeyUsage, OIDL) OFL)
   = rfcObjectIdOccurs(anyExtendedKeyUsage, OIDL)
     or rfcOidFiltersUseAnyExtendedKeyUsage(OFL) .
  eq rfcOidFiltersUseAnyExtendedKeyUsage(oid-filter(CEOID, OIDL) OFL)
   = rfcOidFiltersUseAnyExtendedKeyUsage(OFL) [owise] .
  eq rfcOidFiltersUseAnyExtendedKeyUsage(nil) = false .

  op rfcOidFiltersValid : List{OIDFilter} -> Bool .
  eq rfcOidFiltersValid(OFL)
   = not rfcDuplicateOidFilters(OFL)
     and not rfcOidFiltersUseAnyExtendedKeyUsage(OFL) .


  op rfcCertificateRequestOtherExtensionsValid : Extension -> Bool .
  eq rfcCertificateRequestOtherExtensionsValid(oid-filters EXT) = rfcCertificateRequestOtherExtensionsValid(EXT) .
  eq rfcCertificateRequestOtherExtensionsValid(oid-filters(OFL) EXT)
   = rfcOidFiltersValid(OFL) and rfcCertificateRequestOtherExtensionsValid(EXT) .
  eq rfcCertificateRequestOtherExtensionsValid(oid-filters-len(SZ) EXT) = rfcCertificateRequestOtherExtensionsValid(EXT) .
  eq rfcCertificateRequestOtherExtensionsValid(unknown-extension EXT) = rfcCertificateRequestOtherExtensionsValid(EXT) .
  eq rfcCertificateRequestOtherExtensionsValid(unknown-extension-len(SZ) EXT) = rfcCertificateRequestOtherExtensionsValid(EXT) .
  eq rfcCertificateRequestOtherExtensionsValid(EXT) = EXT == empty [owise] .


  op rfcCertificateRequestExtensionsValid : Extension -> Bool .
  eq rfcCertificateRequestExtensionsValid(signature-algorithms(SCL) signature-algorithms-len(SZ) EXT)
   = rfcTls13NegotiatedSignatureAlgorithmsAllowed(SCL)
     and rfcCertificateRequestOtherExtensionsValid(EXT) .
  eq rfcCertificateRequestExtensionsValid(EXT) = false [owise] .


  op rfcAllowedNewSessionTicketExtensions : Extension -> Bool .
  eq rfcAllowedNewSessionTicketExtensions(early-data EXT) = rfcAllowedNewSessionTicketExtensions(EXT) .
  eq rfcAllowedNewSessionTicketExtensions(early-data-len(SZ) EXT) = rfcAllowedNewSessionTicketExtensions(EXT) .
  eq rfcAllowedNewSessionTicketExtensions(unknown-extension EXT) = rfcAllowedNewSessionTicketExtensions(EXT) .
  eq rfcAllowedNewSessionTicketExtensions(unknown-extension-len(SZ) EXT) = rfcAllowedNewSessionTicketExtensions(EXT) .
  eq rfcAllowedNewSessionTicketExtensions(EXT) = EXT == empty [owise] .


  op rfcCertificateListNonEmpty : List{Certificate} -> Bool .
  eq rfcCertificateListNonEmpty(nil) = false .
  eq rfcCertificateListNonEmpty(CERTL) = true [owise] .


  op rfcCertificateNoMd5Sha1 : List{Certificate} -> Bool .
  eq rfcCertificateNoMd5Sha1(x509(crSignatureAlgorithm({AUTH,md5}), CITEM) CERTL) = false .
  eq rfcCertificateNoMd5Sha1(x509(crSignatureAlgorithm({AUTH,sha}), CITEM) CERTL) = false .
  eq rfcCertificateNoMd5Sha1(CERT CERTL) = rfcCertificateNoMd5Sha1(CERTL) [owise] .
  eq rfcCertificateNoMd5Sha1(nil) = true .
  eq rfcCertificateNoMd5Sha1(x509(crSignatureAlgorithm({AUTH,md5}), CITEM)) = false .
  eq rfcCertificateNoMd5Sha1(x509(crSignatureAlgorithm({AUTH,sha}), CITEM)) = false .
  eq rfcCertificateNoMd5Sha1(CERTL) = true [owise] .

  op rfcCertificateNoOpenPgp : List{Certificate} -> Bool .
  eq rfcCertificateNoOpenPgp(x509(crTls13CertificateType(openpgp), CITEM) CERTL) = false .
  eq rfcCertificateNoOpenPgp(CERT CERTL) = rfcCertificateNoOpenPgp(CERTL) [owise] .
  eq rfcCertificateNoOpenPgp(nil) = true .

  op rfcX509KeyUsageAllowsDigitalSignature : List{X509KeyUsage} -> Bool .
  eq rfcX509KeyUsageAllowsDigitalSignature(digitalSignature KUL) = true .
  eq rfcX509KeyUsageAllowsDigitalSignature(KU KUL) = rfcX509KeyUsageAllowsDigitalSignature(KUL) [owise] .
  eq rfcX509KeyUsageAllowsDigitalSignature(nil) = false .

  op rfcCertificateAllowsDigitalSignature : Certificate -> Bool .
  eq rfcCertificateAllowsDigitalSignature(x509(crKeyUsage(KUL), CITEM))
   = rfcX509KeyUsageAllowsDigitalSignature(KUL) .
  eq rfcCertificateAllowsDigitalSignature(CERT) = true [owise] .

  op rfcCertificatesAllowDigitalSignature : List{Certificate} -> Bool .
  eq rfcCertificatesAllowDigitalSignature(CERT CERTL)
   = rfcCertificateAllowsDigitalSignature(CERT)
     and rfcCertificatesAllowDigitalSignature(CERTL) .
  eq rfcCertificatesAllowDigitalSignature(nil) = true .


  op rfcSignatureMatchesPublicKeyAlgorithm : PublicKeyAlgorithm SignatureAlgorithm -> Bool .
  eq rfcSignatureMatchesPublicKeyAlgorithm(id-ecPublicKey, SH) = authC(SH) == ecdsa .
  eq rfcSignatureMatchesPublicKeyAlgorithm(rsaEncryption, SH) = authC(SH) == rsa .
  eq rfcSignatureMatchesPublicKeyAlgorithm(id-dsa, SH) = authC(SH) == dsa .
  eq rfcSignatureMatchesPublicKeyAlgorithm(id-Ed25519, SH) = authC(SH) == ed25519 .
  eq rfcSignatureMatchesPublicKeyAlgorithm(id-Ed448, SH) = authC(SH) == ed448 .
  eq rfcSignatureMatchesPublicKeyAlgorithm(PKA, SH) = false [owise] .

  op rfcEqualAlgorithm : PublicKeyAlgorithm List{SignatureAlgorithm} -> Bool .
  eq rfcEqualAlgorithm(dhpublicnumber, SCL) = false .
  eq rfcEqualAlgorithm(PKA, SH SCL) = rfcSignatureMatchesPublicKeyAlgorithm(PKA, SH) or rfcEqualAlgorithm(PKA, SCL) .
  eq rfcEqualAlgorithm(PKA, nil) = false .


  op rfcCertificateAlgorithmsAccepted : List{Certificate} Extension -> Bool .
  eq rfcCertificateAlgorithmsAccepted(x509(crPublicKeyAlgorithm(PKA), crSignatureAlgorithm(SH), CITEM), signature-algorithms(SCL) EXT)
   = rfcEqualAlgorithm(PKA, SCL)
     and occurs(SH, SCL)
     and rfcCertificateAllowsDigitalSignature(x509(crPublicKeyAlgorithm(PKA), crSignatureAlgorithm(SH), CITEM)) .
  eq rfcCertificateAlgorithmsAccepted(x509(crPublicKeyAlgorithm(PKA), crSignatureAlgorithm(SH), CITEM) CERTL, signature-algorithms(SCL) EXT)
   = rfcEqualAlgorithm(PKA, SCL)
     and occurs(SH, SCL)
     and rfcCertificateAllowsDigitalSignature(x509(crPublicKeyAlgorithm(PKA), crSignatureAlgorithm(SH), CITEM))
     and rfcCertificateAlgorithmsAccepted(CERTL, signature-algorithms(SCL) EXT) .
  eq rfcCertificateAlgorithmsAccepted(CERTL, EXT) = true [owise] .


  op rfcCertificateSignatureValid : List{Certificate} Set{Key} Extension -> Bool .
  eq rfcCertificateSignatureValid(x509(crSignature(SIGN), CITEM), (KEY, KEYS), signature-algorithms(SCL SH SCL') EXT)
   = decrypt(KEY, SIGN) == hashContent(hash(hashC(SH), certificates(x509(CITEM))))
     or rfcCertificateSignatureValid(x509(crSignature(SIGN), CITEM), KEYS, signature-algorithms(SCL SH SCL') EXT) .
  eq rfcCertificateSignatureValid(CERTL, empty, EXT) = false .


  op rfcServerCertificateHandshakeType : ClientState HandshakeType -> Bool .
  eq rfcServerCertificateHandshakeType(V3C-SRV-ENCEXTS, certificate-request) = true .
  eq rfcServerCertificateHandshakeType(V3C-SRV-ENCEXTS, certificate) = true .
  eq rfcServerCertificateHandshakeType(V3C-CERT-REQ, certificate) = true .
  eq rfcServerCertificateHandshakeType(CS?:ClientState, HT) = false [owise] .


  op rfcCertificateVerifySignatureValid : Set{Key} MsgContent EncrMsgContent -> Bool .
  eq rfcCertificateVerifySignatureValid((KEY, KEYS), HC, SIGN) = HC == decrypt(KEY, SIGN) or rfcCertificateVerifySignatureValid(KEYS, HC, SIGN) .
  eq rfcCertificateVerifySignatureValid(empty, HC, SIGN) = false .

  op rfcCertificateVerifyAlgorithmCompatible : List{Certificate} SignatureAlgorithm -> Bool .
  eq rfcCertificateVerifyAlgorithmCompatible(x509(crPublicKeyAlgorithm(PKA), CITEM), SH)
   = rfcSignatureMatchesPublicKeyAlgorithm(PKA, SH)
     and rfcCertificateAllowsDigitalSignature(x509(crPublicKeyAlgorithm(PKA), CITEM)) .
  eq rfcCertificateVerifyAlgorithmCompatible(CERTL, SH) = false [owise] .


  op rfcFinishedVerifyDataValid : HashAlgorithm Nonce MsgContent Nonce? -> Bool .
 ceq rfcFinishedVerifyDataValid(HALGO, HSEC, TSC, VDATA?) = VDATA? == VDATA
   if VDATA := hash(HALGO, hkdfExpandLabel(HSEC, "finished", noNonce, HALGO), TSC) .

  
  op includePostHandshakeExtension : Extension -> Bool .
  eq includePostHandshakeExtension(post-handshake EXT) = true .
  eq includePostHandshakeExtension(EXT) = false [owise] .
endom

omod TLS13-CLIENT-HELLO-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var SI : TId .
  vars MC MC' TSC FCH : MsgContent .
  vars EXT EXT' EXT'' : Extension .
  vars PV PV' : ProtocolVersion .
  vars PVL PVL' : List{ProtocolVersion} .
  var CS : CipherSuite .
  vars CSL CSL' : List{CipherSuite} .
  vars CML : List{CompressionMethod} .
  vars KSL KSL' KSL'' : List{KeyShareEntry} .
  var NG : NamedGroup .
  vars NGL NGL' : List{NamedGroup} .
  vars NONCE NONCE' : Nonce .
  var COOKIE? : Nonce? .
  vars SCL SCL' : List{SignatureAlgorithm} .
  var AUTH : AuthenticationAlgorithm .
  var HALGO : HashAlgorithm .
  var HT : HandshakeType .
  var CT : ContentType .
  var SZ : MsgSize .
  var TICKET : TicketId .
  vars TICKETL TICKETL' : List{TicketId} .
  var BINDER : Nonce .
  vars BINDERL BINDERL' : List{Nonce} .
  vars PSK ESEC BKEY FKEY : Nonce .
  vars PIL PIL' : List{PSKInfo} .
  var BASE : MsgContent .

  op rfcHrrClientHelloKeyShareChangeAllowed : Extension Extension -> Bool .
  eq rfcHrrClientHelloKeyShareChangeAllowed(key-shares(KSL) EXT, key-shares(KSL') EXT')
   = KSL =/= KSL' .
  eq rfcHrrClientHelloKeyShareChangeAllowed(EXT, EXT')
   = true [owise] .

  op rfcHrrClientHelloEarlyDataChangeAllowed : Extension Extension -> Bool .
  eq rfcHrrClientHelloEarlyDataChangeAllowed(EXT, early-data EXT')
   = false .
  eq rfcHrrClientHelloEarlyDataChangeAllowed(EXT, EXT')
   = true [owise] .

  op rfcHrrClientHelloPskChangeAllowed : Extension Extension -> Bool .
  eq rfcHrrClientHelloPskChangeAllowed(pre-shared-key(TICKETL, BINDERL) EXT,
                                       pre-shared-key(TICKETL', BINDERL') EXT')
   = TICKETL == TICKETL' and BINDERL =/= BINDERL' .
  eq rfcHrrClientHelloPskChangeAllowed(EXT, EXT')
   = not includePSKExtension(EXT) and not includePSKExtension(EXT') [owise] .

  op rfcHrrClientHelloInvariantExtensions : Extension -> Extension .
  eq rfcHrrClientHelloInvariantExtensions(key-shares(KSL) EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(key-shares(NG) EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(early-data EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(early-data-len(SZ) EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(pre-shared-key(TICKETL, BINDERL) EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(cookie EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(cookie(COOKIE?) EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(cookie-len(SZ) EXT)
   = rfcHrrClientHelloInvariantExtensions(EXT) .
  eq rfcHrrClientHelloInvariantExtensions(EXT)
   = EXT [owise] .

  op rfcHrrClientHelloAllowedChanges : Extension Extension -> Bool .
  eq rfcHrrClientHelloAllowedChanges(EXT, EXT')
   = rfcHrrClientHelloInvariantExtensions(EXT) == rfcHrrClientHelloInvariantExtensions(EXT')
     and rfcHrrClientHelloKeyShareChangeAllowed(EXT, EXT')
     and rfcHrrClientHelloEarlyDataChangeAllowed(EXT, EXT')
     and rfcHrrClientHelloPskChangeAllowed(EXT, EXT') .

  op rfcHrrCookieCopied : Extension Extension -> Bool .
  eq rfcHrrCookieCopied(cookie(COOKIE?) EXT, cookie(COOKIE?) EXT') = true .
  eq rfcHrrCookieCopied(cookie EXT, cookie EXT') = true .
  eq rfcHrrCookieCopied(cookie(COOKIE?) EXT, EXT') = false [owise] .
  eq rfcHrrCookieCopied(cookie EXT, EXT') = false [owise] .
  eq rfcHrrCookieCopied(EXT, EXT') = true [owise] .

  op rfcHrrSecondClientHelloAllowed : MsgContent MsgContent -> Bool .
  op rfcHrrSecondClientHelloAllowed : MsgContent MsgContent Extension -> Bool .
  eq rfcHrrSecondClientHelloAllowed(handshakeType(client-hello) extensions(EXT) BASE,
                                    handshakeType(client-hello) extensions(EXT') BASE)
   = rfcHrrClientHelloAllowedChanges(EXT, EXT') .
  eq rfcHrrSecondClientHelloAllowed(FCH, MC)
   = false [owise] .
  eq rfcHrrSecondClientHelloAllowed(handshakeType(client-hello) extensions(EXT) BASE,
                                    handshakeType(client-hello) extensions(EXT') BASE,
                                    EXT'')
   = rfcHrrClientHelloAllowedChanges(EXT, EXT') and rfcHrrCookieCopied(EXT'', EXT') .
  eq rfcHrrSecondClientHelloAllowed(FCH, MC, EXT)
   = false [owise] .

  --- The local builder computes PSK binders before appending the pre_shared_key
  --- extension, so the checker reconstructs that model transcript by stripping
  --- the record header and the whole pre_shared_key extension representation.
  op rfcClientHelloBinderTranscript : MsgContent -> MsgContent .
  eq rfcClientHelloBinderTranscript(contentType(CT) version(PV) recordLen(SZ) MC)
   = rfcClientHelloBinderTranscript(MC) .
  eq rfcClientHelloBinderTranscript(extensions(pre-shared-key(TICKETL, BINDERL) pre-shared-key-len(SZ) EXT) MC)
   = extensions(EXT) MC .
  eq rfcClientHelloBinderTranscript(MC)
   = MC [owise] .

  op rfcExpectedPskBinder : Nonce CipherSuite MsgContent -> Nonce .
  op rfcExpectedPskBinder : Nonce CipherSuite MsgContent MsgContent -> Nonce .
  eq rfcExpectedPskBinder(PSK, CS, MC)
   = rfcExpectedPskBinder(PSK, CS, empty, MC) .
 ceq rfcExpectedPskBinder(PSK, CS, TSC, MC)
   = hash(hashC(CS), FKEY, TSC rfcClientHelloBinderTranscript(MC))
  if ESEC := hkdfExtract(noNonce, PSK, hashC(CS))
  /\ BKEY := deriveSecret(ESEC, "res binder", empty, hashC(CS))
  /\ FKEY := hkdfExpandLabel(BKEY, "finished", noNonce, hashC(CS)) .

  op rfcPSKBinderValid : List{TicketId} List{Nonce} List{PSKInfo} MsgContent -> Bool .
  op rfcPSKBinderValid : List{TicketId} List{Nonce} List{PSKInfo} MsgContent MsgContent -> Bool .
  eq rfcPSKBinderValid(TICKETL, BINDERL, PIL, MC)
   = rfcPSKBinderValid(TICKETL, BINDERL, PIL, empty, MC) .
  eq rfcPSKBinderValid(TICKET TICKETL, BINDER BINDERL, PIL {TICKET,PSK,CS} PIL', MC)
   = rfcPSKBinderValid(TICKET TICKETL, BINDER BINDERL, PIL {TICKET,PSK,CS} PIL', empty, MC) .
  eq rfcPSKBinderValid(TICKET TICKETL, BINDER BINDERL, PIL {TICKET,PSK,CS} PIL', TSC, MC)
   = BINDER == rfcExpectedPskBinder(PSK, CS, TSC, MC) .
  eq rfcPSKBinderValid(TICKET TICKETL, BINDER BINDERL, PIL, MC)
   = rfcPSKBinderValid(TICKET TICKETL, BINDER BINDERL, PIL, empty, MC) [owise] .
  eq rfcPSKBinderValid(TICKET TICKETL, BINDER BINDERL, PIL, TSC, MC)
   = rfcPSKBinderValid(TICKETL, BINDERL, PIL, TSC, MC) [owise] .
  eq rfcPSKBinderValid(nil, nil, PIL, MC)
   = rfcPSKBinderValid(nil, nil, PIL, empty, MC) .
  eq rfcPSKBinderValid(nil, nil, PIL, TSC, MC)
   = true .
  eq rfcPSKBinderValid(nil, BINDER BINDERL, PIL, MC)
   = rfcPSKBinderValid(nil, BINDER BINDERL, PIL, empty, MC) .
  eq rfcPSKBinderValid(nil, BINDER BINDERL, PIL, TSC, MC)
   = false .
  eq rfcPSKBinderValid(TICKET TICKETL, nil, PIL, MC)
   = rfcPSKBinderValid(TICKET TICKETL, nil, PIL, empty, MC) .
  eq rfcPSKBinderValid(TICKET TICKETL, nil, PIL, TSC, MC)
   = false .

  --- checkRequirements scans labels from high to low; keep the HRR invariant
  --- at label[6] so more specific ClientHello failures keep alert precedence.

  --- [RFC 8446 Section 4.2.11] Servers MUST validate PSK binders and abort when the selected PSK binder is invalid.
  eq rfc-requirement(tls13-client-hello, label[20], extensions(pre-shared-key(TICKETL, BINDERL) EXT) MC,
                     < SI : Server | pskInfo : PIL, transcript : TSC >)
   = rfcPSKBinderValid(TICKETL, BINDERL, PIL, TSC, extensions(pre-shared-key(TICKETL, BINDERL) EXT) MC) .

  eq rfc-requirement(tls13-client-hello, label[20], MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 5] ClientHello is processed as a handshake record; unexpected record content types terminate with unexpected_message.
  eq rfc-requirement(tls13-client-hello, label[19], contentType(handshake) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-client-hello, label[19], contentType(CT) MC, OBJ)
   = false [owise] .

  --- [RFC 8446 Section 4] The expected handshake message is ClientHello; unexpected handshake order or type aborts with unexpected_message.
  eq rfc-requirement(tls13-client-hello, label[18], handshakeType(client-hello) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-client-hello, label[18], handshakeType(HT) MC, OBJ)
   = false [owise] .

  --- [RFC 8446 Sections 4.1.2 and 6] ClientHello vector bounds must parse correctly; syntax length failures terminate with decode_error.
  eq rfc-requirement(tls13-client-hello, label[17], MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.2.9] In psk_dhe_ke, client and server MUST supply key_share values; in psk_ke, the server MUST NOT use key_share.
  eq rfc-requirement(tls13-client-hello, label[16], extensions(psk-key-exchange-mode(psk-dhe-ke) EXT) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-client-hello, label[16], extensions(psk-key-exchange-mode(psk-ke) EXT) MC, OBJ)
   = if includeKeyShareExtension(EXT) and includeSupportedGroupsExtension(EXT) then false else true fi .

  eq rfc-requirement(tls13-client-hello, label[16], extensions(EXT) MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 4.2.10] A client using early data MUST supply both pre_shared_key and early_data extensions.
  eq rfc-requirement(tls13-client-hello, label[15], extensions(early-data EXT) MC, OBJ)
   = includePSKExtension(EXT) .

  eq rfc-requirement(tls13-client-hello, label[15], extensions(EXT) MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 4.2.9] A client offering pre_shared_key MUST also provide psk_key_exchange_modes.
  eq rfc-requirement(tls13-client-hello, label[14], extensions(EXT) MC, OBJ)
   = not includePSKExtension(EXT) or includePSKExchangeModeExtension(EXT) .

  --- [RFC 8446 Appendix B.4] TLS 1.3 cipher suites cannot be used for TLS 1.2, and TLS 1.2 or lower cipher suites cannot be used with TLS 1.3.
  eq rfc-requirement(tls13-client-hello, label[13], cipherSuites(TLS-AES-128-CCM-SHA256 CSL') MC, OBJ)
   = rfc-requirement(tls13-client-hello, label[13], cipherSuites(CSL') MC, OBJ) .

  eq rfc-requirement(tls13-client-hello, label[13], cipherSuites(TLS-AES-128-CCM-8-SHA256 CSL') MC, OBJ)
   = rfc-requirement(tls13-client-hello, label[13], cipherSuites(CSL') MC, OBJ) .

  eq rfc-requirement(tls13-client-hello, label[13], cipherSuites(TLS-AES-128-GCM-SHA256 CSL') MC, OBJ)
   = rfc-requirement(tls13-client-hello, label[13], cipherSuites(CSL') MC, OBJ) .

  eq rfc-requirement(tls13-client-hello, label[13], cipherSuites(TLS-AES-256-GCM-SHA384 CSL') MC, OBJ)
   = rfc-requirement(tls13-client-hello, label[13], cipherSuites(CSL') MC, OBJ) .

  eq rfc-requirement(tls13-client-hello, label[13], cipherSuites(nil) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-client-hello, label[13], cipherSuites(CSL') MC, OBJ)
   = false [owise] .

  --- [RFC 8446 Section 4.2.3] If the server authenticates via certificate and the client omitted signature_algorithms, the server MUST abort.
 ceq rfc-requirement(tls13-client-hello, label[12], cipherSuites(CSL') extensions(EXT) MC, < SI : Server | cipherSuites : CSL >)
   = true
   if select(CSL', CSL) == noSuite .

 ceq rfc-requirement(tls13-client-hello, label[12], cipherSuites(CSL') extensions(EXT) MC, < SI : Server | cipherSuites : CSL >)
   = (authC(CS) == anon or includeSignatureAlgorithmsExtension(EXT))
   if CS := select(CSL', CSL) .

  --- [RFC 8446 Section 4.2.8] Clients MUST NOT offer multiple KeyShareEntry values for the same group.
  eq rfc-requirement(tls13-client-hello, label[11], extensions(key-shares(KSL {NG,NONCE} KSL' {NG,NONCE'} KSL'') EXT) MC, OBJ)
   = false .

  eq rfc-requirement(tls13-client-hello, label[11], extensions(EXT) MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Sections 4.1.2 and 4.2.1] TLS 1.3 ClientHello uses legacy_version 0x0303 and identifies TLS 1.3 via supported_versions 0x0304.
  eq rfc-requirement(tls13-client-hello, label[10], protocol(PV) extensions(supported-versions(PVL TLS-13 PVL') EXT) MC, OBJ)
   = PV == TLS-12 .

  eq rfc-requirement(tls13-client-hello, label[10], protocol(PV) extensions(supported-versions(PV') EXT) MC, OBJ)
   = PV' == TLS-13 .

  eq rfc-requirement(tls13-client-hello, label[10], protocol(PV) extensions(EXT) MC, OBJ)
   = includeSupportedVersionsExtension(EXT) [owise] .

  --- [RFC 8446 Section 4.2.3] Deprecated MD5/SHA-224/DSA algorithms MUST NOT be offered; SHA-1 legacy values, if offered, must be lowest priority.
  eq rfc-requirement(tls13-client-hello, label[9], extensions(EXT) MC, OBJ)
   = rfcTls13ClientSignatureSchemeListsValid(EXT) .

  --- [RFC 8446 Section 9.2] A TLS 1.3 ClientHello with supported_versions 0x0304 MUST meet mandatory extension requirements.
  eq rfc-requirement(tls13-client-hello, label[8], extensions(EXT) MC, OBJ)
   = ( includePSKExtension(EXT)
       or (includeSignatureAlgorithmsExtension(EXT) and includeSupportedGroupsExtension(EXT))
     )
     and
     ( (includeSupportedGroupsExtension(EXT) and includeKeyShareExtension(EXT))
       or
       (not includeSupportedGroupsExtension(EXT) and not includeKeyShareExtension(EXT))
     ) .

  --- [RFC 8446 Section 4.1.2] The TLS 1.3 ClientHello compression vector MUST contain exactly one zero byte, the null compression method.
  eq rfc-requirement(tls13-client-hello, label[7], compressions(no-compression) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-client-hello, label[7], compressions(CML) MC, OBJ)
   = false [owise] .

  --- [RFC 8446 Section 4.1.2] After HRR, ClientHello MUST be unchanged except for the allowed second-ClientHello updates.
  eq rfc-requirement(tls13-client-hello, label[6], MC, < SI : Server | firstClientHello : FCH, selectedExtensions : EXT >)
   = if FCH == empty or not validMsgSize(MC)
     then true
     else rfcHrrSecondClientHelloAllowed(FCH, removeRecord(MC), EXT)
     fi .

  eq rfc-requirement(tls13-client-hello, label[6], MC, < SI : Server | firstClientHello : FCH >)
   = if FCH == empty or not validMsgSize(MC)
     then true
     else rfcHrrSecondClientHelloAllowed(FCH, removeRecord(MC))
     fi .

  eq rfc-requirement(tls13-client-hello, label[6], MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Sections 4.1.1 and 4.2.7] The server must be able to negotiate supported parameters, including a mutually supported named group when groups are offered.
  eq rfc-requirement(tls13-client-hello, label[5], extensions(key-shares(KSL) supported-groups(NGL) EXT') MC,
                     < SI : Server | extensions : supported-groups(NGL') EXT >)
   = if keyShareEntriesFollowSupportedGroups(KSL, NGL) then select(NGL, NGL') =/= noGroup else true fi .

  eq rfc-requirement(tls13-client-hello, label[5], extensions(supported-groups(NGL) EXT') MC, < SI : Server | extensions : supported-groups(NGL') EXT >)
   = select(NGL, NGL') =/= noGroup .

  eq rfc-requirement(tls13-client-hello, label[5], extensions(EXT') MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 4.1.1] If no supported client/server parameters overlap, the server MUST abort with handshake_failure or insufficient_security.
  eq rfc-requirement(tls13-client-hello, label[4], cipherSuites(CSL') MC, < SI : Server | cipherSuites : CSL >)
   = select(CSL', CSL) =/= noSuite and rfcCipherSuitesAllowedBySecurity(CSL') .

  --- [RFC 8446 Section 4.2] There MUST NOT be more than one extension of the same type in a given extension block.
  eq rfc-requirement(tls13-client-hello, label[3], extensions(EXT) MC, OBJ)
   = not duplicateExtension(EXT) .

  --- [RFC 8446 Section 4.1.2] TLS 1.3 forbids renegotiation; reject TLS 1.2 renegotiation signaling on TLS 1.3 ClientHello paths.
  eq rfc-requirement(tls13-client-hello, label[2], extensions(EXT) MC, OBJ)
   = not includeRenegotiationInfoExtension(EXT) .

  --- [RFC 8446 Section 4.2.8] KeyShareEntry values MUST correspond to groups offered in the "supported_groups" extension and MUST appear in the same order.
  eq rfc-requirement(tls13-client-hello, label[1], extensions(key-shares(KSL) supported-groups(NGL) EXT) MC, OBJ)
   = keyShareEntriesFollowSupportedGroups(KSL, NGL)
     and rfcAllowedTls13NamedGroups(NGL)
     and rfcAllowedTls13KeyShareGroups(KSL) .

  eq rfc-requirement(tls13-client-hello, label[1], extensions(supported-groups(NGL) EXT) MC, OBJ)
   = rfcAllowedTls13NamedGroups(NGL) .

  eq rfc-requirement(tls13-client-hello, label[1], extensions(EXT) MC, OBJ)
   = true [owise] .
endom

omod TLS13-HELLO-RETRY-REQUEST-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var CI : TId .
  vars MC TSC : MsgContent .
  vars EXT EXT' : Extension .
  var PV : ProtocolVersion .
  var CS : CipherSuite .
  var CSL : List{CipherSuite} .
  vars CM : CompressionMethod .
  vars SID? SID'? : Nonce? .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 8446 Section 5] HelloRetryRequest is carried in a handshake record.
  eq rfc-requirement(tls13-hello-retry-request, label[14], random(hrrNonce) contentType(handshake) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-hello-retry-request, label[14], random(hrrNonce) contentType(CT) MC, OBJ)
   = false [owise] .

  --- [RFC 8446 Section 4] The expected handshake message is HelloRetryRequest.
  eq rfc-requirement(tls13-hello-retry-request, label[13], random(hrrNonce) handshakeType(hello-retry-request) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-hello-retry-request, label[13], random(hrrNonce) handshakeType(HT) MC, OBJ)
   = false [owise] .

  --- [RFC 8446 Sections 4 and 6] HelloRetryRequest syntax lengths must parse correctly.
  eq rfc-requirement(tls13-hello-retry-request, label[12], random(hrrNonce) MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.2.1] HelloRetryRequest selected_version MUST have been offered by the client.
  eq rfc-requirement(tls13-hello-retry-request, label[11], random(hrrNonce) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerVersionWasOffered(EXT, EXT') .

  --- [RFC 8446 Section 4.2] There MUST NOT be duplicate extensions.
  eq rfc-requirement(tls13-hello-retry-request, label[10], random(hrrNonce) extensions(EXT) MC, OBJ)
   = not duplicateExtension(EXT) .

  --- [RFC 8446 Section 4.1.4] HelloRetryRequest legacy_session_id_echo MUST match ClientHello.
  eq rfc-requirement(tls13-hello-retry-request, label[9], random(hrrNonce) sessionId(SID'?) MC, < CI : Client | sessionId : SID? >)
   = SID? == SID'? .

  --- [RFC 8446 Section 4.1.4] HelloRetryRequest compression method MUST be null.
  eq rfc-requirement(tls13-hello-retry-request, label[8], random(hrrNonce) compressions(CM) MC, OBJ)
   = CM == no-compression .

  --- [RFC 8446 Section 4.1.4] HelloRetryRequest cipher suite MUST be one offered by the client.
  eq rfc-requirement(tls13-hello-retry-request, label[7], random(hrrNonce) cipherSuites(CS) MC, < CI : Client | cipherSuites : CSL >)
   = occurs(CS, CSL) and rfcCipherSuiteAllowedBySecurity(CS) .

  --- [RFC 8446 Section 4.1.4] HelloRetryRequest legacy_version MUST be TLS 1.2.
  eq rfc-requirement(tls13-hello-retry-request, label[6], random(hrrNonce) protocol(PV) MC, OBJ)
   = PV == TLS-12 .

  --- [RFC 8446 Section 4.1.4] A client MUST abort on a second HelloRetryRequest in the same connection.
  eq rfc-requirement(tls13-hello-retry-request, label[5], random(hrrNonce) MC, < CI : Client | transcript : TSC >)
   = rfcNoSecondHelloRetryRequest(TSC) .

  --- [RFC 8446 Section 4.1.4] The selected group must be from the original supported_groups.
  eq rfc-requirement(tls13-hello-retry-request, label[4], random(hrrNonce) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcHrrSelectedGroupWasSupported(EXT, EXT')
     and rfcAllowedTls13HelloRetryRequestKeyShareGroup(EXT') .

  --- [RFC 8446 Section 4.1.4] The selected group must cause a changed ClientHello.
  eq rfc-requirement(tls13-hello-retry-request, label[3], random(hrrNonce) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcHrrSelectedGroupChangesClientHello(EXT, EXT') .

  --- [RFC 8446 Section 4.1.4] HelloRetryRequest MUST contain supported_versions.
  eq rfc-requirement(tls13-hello-retry-request, label[2], random(hrrNonce) extensions(EXT) MC, OBJ)
   = includeSupportedVersionsExtension(EXT) .

  --- [RFC 8446 Section 4.1.4] HelloRetryRequest MUST only contain extensions valid for HelloRetryRequest.
  eq rfc-requirement(tls13-hello-retry-request, label[1], random(hrrNonce) extensions(EXT) MC, OBJ)
   = rfcAllowedHelloRetryRequestExtensions(EXT) .
endom

omod TLS13-SERVER-HELLO-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  vars CI SI : TId .
  vars MC TSC : MsgContent .
  vars EXT EXT' : Extension .
  var PV : ProtocolVersion .
  var N : Nat .
  var CS : CipherSuite .
  var CSL : List{CipherSuite} .
  vars CM : CompressionMethod .
  var NONCE : Nonce .
  vars SID? SID'? : Nonce? .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 8446 Section 4] The expected handshake message is ServerHello.
  eq rfc-requirement(tls13-server-hello, label[19], random(NONCE) handshakeType(server-hello) contentType(handshake) MC, OBJ)
   = true .

  eq rfc-requirement(tls13-server-hello, label[19], random(NONCE) MC, OBJ)
   = false [owise] .

  --- [RFC 8446 Sections 4 and 6] ServerHello syntax lengths must parse correctly.
  eq rfc-requirement(tls13-server-hello, label[18], random(NONCE) MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.2.11] If PSK was offered, selected PSK extension must be present.
  eq rfc-requirement(tls13-server-hello, label[17], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerHelloSelectedPskPresent(EXT, EXT') .

  --- [RFC 8446 Section 4.2.8] ServerHello must contain key_share unless PSK-only mode applies.
  eq rfc-requirement(tls13-server-hello, label[16], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerHelloKeyShareRequired(EXT, EXT') .

  --- [RFC 8446 Section 4.2.11] selected_identity must be in the offered PSK range.
  eq rfc-requirement(tls13-server-hello, label[15], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerHelloSelectedPskInRange(EXT, EXT') .

  --- [RFC 8446 Section 4.2.9] psk_dhe_ke requires a server key_share.
  eq rfc-requirement(tls13-server-hello, label[14], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerHelloPskDheHasKeyShare(EXT, EXT') .

  --- [RFC 8446 Section 4.2.1] ServerHello MUST contain supported_versions.
  eq rfc-requirement(tls13-server-hello, label[13], random(NONCE) extensions(EXT) MC, OBJ)
   = includeSupportedVersionsExtension(EXT) .

  --- [RFC 8446 Section 4.2.9] The server MUST NOT send psk_key_exchange_modes.
  eq rfc-requirement(tls13-server-hello, label[12], random(NONCE) extensions(EXT) MC, OBJ)
   = not includePSKExchangeModeExtension(EXT) .

  --- [RFC 8446 Section 4.1.3] legacy_compression_method MUST be null for TLS 1.3 ServerHello.
  eq rfc-requirement(tls13-server-hello, label[11], random(NONCE) compressions(CM) extensions(EXT) MC, OBJ)
   = if includeSupportedVersionsExtension(EXT) then CM == no-compression else true fi .

  --- [RFC 8446 Section 4.1.3] legacy_session_id_echo MUST match the ClientHello session id.
  eq rfc-requirement(tls13-server-hello, label[10], random(NONCE) sessionId(SID'?) extensions(EXT) MC, < CI : Client | sessionId : SID? >)
   = if includeSupportedVersionsExtension(EXT) then SID? == SID'? else true fi .

  --- [RFC 8446 Section 4.2.9] ServerHello MUST NOT send key_share when psk_ke is used.
  eq rfc-requirement(tls13-server-hello, label[9], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerHelloPskKeAllowsKeyShare(EXT, EXT') .

  --- [RFC 8446 Section 4.2.8] ServerHello key_share group MUST appear in client supported_groups.
  eq rfc-requirement(tls13-server-hello, label[8], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerHelloKeyShareGroupWasSupported(EXT, EXT')
     and rfcAllowedTls13ServerHelloKeyShareGroup(EXT') .

  --- [RFC 8446 Section 4.2.8] ServerHello key_share MUST match a client offered group.
  eq rfc-requirement(tls13-server-hello, label[7], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerHelloKeyShareMatchesClient(EXT, EXT')
     and rfcAllowedTls13ServerHelloKeyShareGroup(EXT') .

  --- [RFC 8446 Section 4.2] ServerHello extension responses require corresponding client requests.
  eq rfc-requirement(tls13-server-hello, label[6], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = duplicateExtension(EXT') or (not rfcAllowedServerHelloExtension(EXT')) or rfcServerHelloExtensionWasRequested(EXT, EXT') .

  --- [RFC 8446 Section 4.2] ServerHello MUST NOT contain extensions forbidden for this message.
  eq rfc-requirement(tls13-server-hello, label[5], random(NONCE) extensions(EXT) MC, OBJ)
   = rfcAllowedServerHelloExtension(EXT) .

  --- [RFC 8446 Section 4.1.3] ServerHello cipher suite MUST be one offered by the client.
  eq rfc-requirement(tls13-server-hello, label[4], random(NONCE) cipherSuites(CS) MC, < CI : Client | cipherSuites : CSL >)
   = occurs(CS, CSL) and rfcCipherSuiteAllowedBySecurity(CS) .

  --- [RFC 8446 Section 4.2] There MUST NOT be duplicate extensions.
  eq rfc-requirement(tls13-server-hello, label[3], random(NONCE) extensions(EXT) MC, OBJ)
   = not duplicateExtension(EXT) .

  --- [RFC 8446 Section 4.2.1] ServerHello selected_version must be one offered by the client.
  eq rfc-requirement(tls13-server-hello, label[2], random(NONCE) extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = rfcServerVersionWasOffered(EXT, EXT') .

  --- [RFC 8446 Sections 4.1.3 and 4.2.1] ServerHello legacy_version and supported_versions must indicate TLS 1.3 correctly.
  eq rfc-requirement(tls13-server-hello, label[1], protocol(PV) random(NONCE) extensions(EXT) MC, OBJ)
   = if includeSupportedVersionsExtension(EXT) then PV == TLS-12 else true fi .

  --- [RFC 8446 Section 4.1.4] After HRR, ServerHello cipher suite MUST be the same as in the HRR.
  eq rfc-requirement(tls13-server-hello, label[22],
                     contentType(handshake) handshakeType(server-hello) random(NONCE) cipherSuites(CS) MC,
                     < CI : Client | transcript : TSC >)
   = if validMsgSize(contentType(handshake) handshakeType(server-hello) random(NONCE) cipherSuites(CS) MC)
     then rfcServerHelloCipherSuiteMatchesHrr(TSC, CS)
     else true
     fi .

  eq rfc-requirement(tls13-server-hello, label[22], MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 4.1.4] After HRR, ServerHello selected_version MUST be the same as in the HRR.
  eq rfc-requirement(tls13-server-hello, label[21],
                     contentType(handshake) handshakeType(server-hello) random(NONCE) extensions(EXT') MC,
                     < CI : Client | transcript : TSC >)
   = if validMsgSize(contentType(handshake) handshakeType(server-hello) random(NONCE) extensions(EXT') MC)
     then rfcServerHelloSelectedVersionMatchesHrr(TSC, EXT')
     else true
     fi .

  eq rfc-requirement(tls13-server-hello, label[21], MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 4.2.1] ServerHello selected_version MUST be one offered by the client.
  eq rfc-requirement(tls13-server-hello, label[20],
                     contentType(handshake) handshakeType(server-hello) random(NONCE) extensions(EXT') MC,
                     < CI : Client | extensions : EXT >)
   = if validMsgSize(contentType(handshake) handshakeType(server-hello) random(NONCE) extensions(EXT') MC)
     then rfcServerVersionWasOffered(EXT, EXT')
     else true
     fi .

  eq rfc-requirement(tls13-server-hello, label[20], MC, OBJ)
   = true [owise] .
endom

omod TLS13-ENCRYPTED-EXTENSION-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var CI : TId .
  var MC : MsgContent .
  vars EXT EXT' : Extension .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 8446 Section 4.2] EncryptedExtensions responses require corresponding client requests.
  eq rfc-requirement(tls13-encrypted-extension, label[5], extensions(EXT') MC, < CI : Client | extensions : EXT >)
   = duplicateExtension(EXT') or (not rfcAllowedEncryptedExtensions(EXT')) or rfcEncryptedExtensionWasRequested(EXT, EXT') .

  eq rfc-requirement(tls13-encrypted-extension, label[5], MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 5] EncryptedExtensions is read under application-data record protection.
  eq rfc-requirement(tls13-encrypted-extension, label[4], contentType(application-data) MC, OBJ) = true .

  eq rfc-requirement(tls13-encrypted-extension, label[4], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Section 4] The expected handshake message is EncryptedExtensions.
  eq rfc-requirement(tls13-encrypted-extension, label[3], handshakeType(encrypted-extension) MC, OBJ) = true .

  eq rfc-requirement(tls13-encrypted-extension, label[3], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Sections 4 and 6] EncryptedExtensions syntax lengths must parse correctly.
  eq rfc-requirement(tls13-encrypted-extension, label[2], MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.3.1] EncryptedExtensions MUST NOT contain forbidden extensions.
  eq rfc-requirement(tls13-encrypted-extension, label[1], extensions(EXT) MC, OBJ)
   = rfcAllowedEncryptedExtensions(EXT) .

endom

omod TLS13-CERTIFICATE-REQUEST-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var CI : TId .
  var MC : MsgContent .
  var EXT : Extension .
  var HT : HandshakeType .
  var CT : ContentType .
  var NONCE : Nonce .
  var NONCE? : Nonce? .

  --- [RFC 8446 Section 4.3.2] certificate_request_context is unique within this connection.
  eq rfc-requirement(tls13-certificate-request, label[7],
                     certificate-request-context(noNonce) MC,
                     < CI : Client | certificateRequestContext : noNonce >)
   = true .

  eq rfc-requirement(tls13-certificate-request, label[7],
                     certificate-request-context(NONCE) MC,
                     < CI : Client | certificateRequestContext : NONCE? >)
   = NONCE =/= NONCE? .

  eq rfc-requirement(tls13-certificate-request, label[7], MC, OBJ)
   = true [owise] .

  --- [RFC 8446 Section 4.6.2] Post-handshake CertificateRequest requires prior post_handshake_auth support.
  eq rfc-requirement(tls13-certificate-request, label[6], handshakeType(certificate-request) MC, < CI : Client | clientState : V3C-CT-FIN, extensions : EXT >)
   = includePostHandshakeExtension(EXT) .

  eq rfc-requirement(tls13-certificate-request, label[6], handshakeType(HT) MC, < CI : Client | clientState : V3C-CT-FIN, extensions : EXT >)
   = false [owise] .

  --- [RFC 8446 Section 5] CertificateRequest is read under application-data record protection.
  eq rfc-requirement(tls13-certificate-request, label[5], contentType(application-data) MC, OBJ) = true .

  eq rfc-requirement(tls13-certificate-request, label[5], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Section 4] CertificateRequest or Certificate may be expected in this state.
  eq rfc-requirement(tls13-certificate-request, label[4], handshakeType(certificate-request) MC, OBJ) = true .

  eq rfc-requirement(tls13-certificate-request, label[4], handshakeType(certificate) MC, OBJ) = true .

  eq rfc-requirement(tls13-certificate-request, label[4], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Sections 4 and 6] CertificateRequest syntax lengths must parse correctly.
  eq rfc-requirement(tls13-certificate-request, label[3], MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.2] There MUST NOT be duplicate CertificateRequest extensions.
  eq rfc-requirement(tls13-certificate-request, label[2], extensions(EXT) MC, OBJ)
   = not duplicateExtension(EXT) .

  --- [RFC 8446 Section 4.3.2] CertificateRequest MUST include signature_algorithms and only allowed extensions.
  eq rfc-requirement(tls13-certificate-request, label[1], extensions(EXT) MC, OBJ)
   = rfcCertificateRequestExtensionsValid(EXT) .
endom

omod TLS13-CERTIFICATE-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars CI SI : TId .
  var OBJ : Object .
  var MC : MsgContent .
  var EXT : Extension .
  vars NONCE? NONCE'? : Nonce? .
  vars CERT CERTL : List{Certificate} .
  var CERT1 : Certificate .
  vars KEYS : Set{Key} .
  var HT : HandshakeType .
  var CT : ContentType .
  var CS? : ClientState .
  var RL : RFCLabel .

  eq rfc-requirement(tls13-client-certificate, RL, MC, OBJ)
   = rfc-requirement(tls13-server-certificate, RL, MC, OBJ) .

  --- [RFC 8446 Section 5] Client Certificate is read under application-data record protection.
  eq rfc-requirement(tls13-server-certificate, label[8], contentType(application-data) MC, < SI : Server | serverState : V3S-SRV-FIN >) = true .

  eq rfc-requirement(tls13-server-certificate, label[8], contentType(CT) MC, < SI : Server | serverState : V3S-SRV-FIN >) = false [owise] .

  --- [RFC 8446 Section 5] Certificate is read under application-data record protection.
  eq rfc-requirement(tls13-server-certificate, label[7], contentType(application-data) MC, < CI : Client | >) = true .

  eq rfc-requirement(tls13-server-certificate, label[7], contentType(CT) MC, < CI : Client | >) = false [owise] .

  --- [RFC 8446 Section 4] The expected handshake message is Certificate.
  eq rfc-requirement(tls13-server-certificate, label[7], handshakeType(certificate) MC, < SI : Server | serverState : V3S-SRV-FIN >) = true .

  eq rfc-requirement(tls13-server-certificate, label[7], handshakeType(HT) MC, < SI : Server | serverState : V3S-SRV-FIN >) = false [owise] .

  --- [RFC 8446 Section 4] Certificate handshake type must be valid for the current state.
  eq rfc-requirement(tls13-server-certificate, label[6], handshakeType(HT) MC, < CI : Client | clientState : CS? >)
   = rfcServerCertificateHandshakeType(CS?, HT) .

  --- [RFC 8446 Sections 4 and 6] Certificate syntax lengths must parse correctly.
  eq rfc-requirement(tls13-server-certificate, label[6], MC, < SI : Server | serverState : V3S-SRV-FIN >)
   = validMsgSize(MC) .

  --- [RFC 8446 Sections 4 and 6] Certificate syntax lengths must parse correctly.
  eq rfc-requirement(tls13-server-certificate, label[5], MC, < CI : Client | >)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.4.2] Client certificate_list must satisfy local client-certificate policy.
  eq rfc-requirement(tls13-server-certificate, label[5], certificates(CERTL) MC, < SI : Server | serverState : V3S-SRV-FIN >)
   = true .

  --- [RFC 8446 Section 4.4.2.2] Certificate signatures must verify.
  eq rfc-requirement(tls13-server-certificate, label[4], certificates(nil) MC, < CI : Client | clientState : CS? >)
   = true .

  eq rfc-requirement(tls13-server-certificate, label[4], certificates(CERTL) MC, < CI : Client | clientState : CS?, publicKey : KEYS, extensions : EXT >)
   = if (CS? == V3C-SRV-ENCEXTS or CS? == V3C-CERT-REQ) then rfcCertificateSignatureValid(CERTL, KEYS, EXT) else true fi .

  --- [RFC 8446 Section 4.4.2] Client CertificateRequest context must match.
  eq rfc-requirement(tls13-server-certificate, label[4], certificate-request-context(NONCE'?) MC, < SI : Server | serverState : V3S-SRV-FIN, certificateRequestContext : NONCE? >)
   = NONCE? == NONCE'? .

  --- [RFC 8446 Section 4.4.2.2] Certificate public key/signature algorithms must be acceptable.
  eq rfc-requirement(tls13-server-certificate, label[3], certificates(CERTL) MC, < CI : Client | clientState : CS?, extensions : EXT >)
   = if (CS? == V3C-SRV-ENCEXTS or CS? == V3C-CERT-REQ) then rfcCertificateAlgorithmsAccepted(CERTL, EXT) else true fi .

  --- [RFC 8446 Section 4.4.2.2] Client certificate signatures must verify.
  eq rfc-requirement(tls13-server-certificate, label[3], certificates(CERT1) MC, < SI : Server | serverState : V3S-SRV-FIN, publicKey : KEYS, extensions : EXT >)
   = rfcCertificateSignatureValid(CERT1, KEYS, EXT) .

  --- [RFC 8446 Section 4.4.2.2] Certificates MUST NOT use MD5 or SHA-1 signatures.
  eq rfc-requirement(tls13-server-certificate, label[2], certificates(CERTL) MC, < CI : Client | clientState : CS? >)
   = if (CS? == V3C-SRV-ENCEXTS or CS? == V3C-CERT-REQ)
     then rfcCertificateNoOpenPgp(CERTL) and rfcCertificateNoMd5Sha1(CERTL)
     else true
     fi .

  --- [RFC 8446 Section 4.4.2.2] Client certificates must use acceptable signature algorithms.
  eq rfc-requirement(tls13-server-certificate, label[2], certificates(CERT1) MC, < SI : Server | serverState : V3S-SRV-FIN, extensions : EXT >)
   = rfcCertificateAlgorithmsAccepted(CERT1, EXT) .

  --- [RFC 8446 Section 4.4.2] Server certificate_list MUST be non-empty.
  eq rfc-requirement(tls13-server-certificate, label[1], certificates(CERTL) MC, < CI : Client | clientState : CS? >)
   = if (CS? == V3C-SRV-ENCEXTS or CS? == V3C-CERT-REQ) then rfcCertificateListNonEmpty(CERTL) else true fi .

  --- [RFC 8446 Section 4.4.2.2] Client certificate signatures MUST NOT use MD5 or SHA-1.
  eq rfc-requirement(tls13-server-certificate, label[1], certificates(CERT1) MC, < SI : Server | serverState : V3S-SRV-FIN >)
   = rfcCertificateNoOpenPgp(CERT1) and rfcCertificateNoMd5Sha1(CERT1) .
endom

omod TLS13-CERTIFICATE-VERIFY-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  vars CI SI : TId .
  vars MC TSC : MsgContent .
  var EXT : Extension .
  vars KEYS : Set{Key} .
  var SIGN : EncrMsgContent .
  var SC : SignatureAlgorithm .
  var SCL : List{SignatureAlgorithm} .
  var CERTL : List{Certificate} .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 8446 Section 5] CertificateVerify is read under application-data record protection.
  eq rfc-requirement(tls13-certificate-verify, label[6], contentType(application-data) MC, OBJ) = true .

  eq rfc-requirement(tls13-certificate-verify, label[6], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Section 4.4.3] CertificateVerify signature algorithm must be compatible with the sender's end-entity certificate key.
  eq rfc-requirement(tls13-certificate-verify, label[7], certificate-verify-algorithm(SC) MC,
                     < CI : Client | peerCertificate : CERTL >)
   = rfcCertificateVerifyAlgorithmCompatible(CERTL, SC) .

  eq rfc-requirement(tls13-certificate-verify, label[7], certificate-verify-algorithm(SC) MC,
                     < SI : Server | peerCertificate : CERTL >)
   = rfcCertificateVerifyAlgorithmCompatible(CERTL, SC) .

  --- [RFC 8446 Section 4] The expected handshake message is CertificateVerify.
  eq rfc-requirement(tls13-certificate-verify, label[5], handshakeType(certificate-verify) MC, OBJ) = true .

  eq rfc-requirement(tls13-certificate-verify, label[5], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Sections 4 and 6] CertificateVerify syntax lengths must parse correctly.
  eq rfc-requirement(tls13-certificate-verify, label[4], MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.4.3] CertificateVerify signature must verify against the transcript.
  eq rfc-requirement(tls13-certificate-verify, label[3], signature(SIGN) certificate-verify-algorithm(SC) MC, < CI : Client | transcript : TSC, publicKey : KEYS >)
   = rfcCertificateVerifySignatureValid(KEYS, hashContent(hash(hashC(SC), TSC)), SIGN) .

  eq rfc-requirement(tls13-certificate-verify, label[3], signature(SIGN) certificate-verify-algorithm(SC) MC, < SI : Server | transcript : TSC, publicKey : KEYS >)
   = rfcCertificateVerifySignatureValid(KEYS, hashContent(hash(hashC(SC), TSC)), SIGN) .

  --- [RFC 8446 Section 4.4.3] CertificateVerify signature algorithm must be offered.
  eq rfc-requirement(tls13-certificate-verify, label[2], certificate-verify-algorithm(SC) MC, < CI : Client | extensions : signature-algorithms(SCL) EXT >)
   = occurs(SC, SCL) .

  eq rfc-requirement(tls13-certificate-verify, label[2], certificate-verify-algorithm(SC) MC, < SI : Server | selectedExtensions : signature-algorithms(SCL) EXT >)
   = occurs(SC, SCL) .

  --- [RFC 8446 Sections 4.2.3 and 4.4.3] CertificateVerify MUST NOT use SHA-1, MD5, SHA-224, or DSA.
  eq rfc-requirement(tls13-certificate-verify, label[1], certificate-verify-algorithm(SC) MC, OBJ)
   = rfcTls13CertificateVerifySignatureAlgorithmAllowed(SC) .
endom

omod TLS13-FINISHED-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  vars CI SI : TId .
  vars MC TSC : MsgContent .
  var CS : CipherSuite .
  var VDATA? : Nonce? .
  var HT : HandshakeType .
  var CT : ContentType .
  var HSEC : Nonce .

  --- [RFC 8446 Section 5] Finished is read under application-data record protection.
  eq rfc-requirement(tls13-finished, label[4], contentType(application-data) MC, OBJ) = true .

  eq rfc-requirement(tls13-finished, label[4], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Section 4] The expected handshake message is Finished.
  eq rfc-requirement(tls13-finished, label[3], handshakeType(finished) MC, OBJ) = true .

  eq rfc-requirement(tls13-finished, label[3], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Sections 4 and 6] Finished syntax lengths must parse correctly.
  eq rfc-requirement(tls13-finished, label[2], MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.4.4] Finished verify_data must be correct.
  eq rfc-requirement(tls13-finished, label[1], verifyData(VDATA?) MC, < CI : Client | transcript : TSC, handshakeSecret : HSEC, selectedCipherSuite : CS >)
   = rfcFinishedVerifyDataValid(hashC(CS), HSEC, TSC, VDATA?) .

  eq rfc-requirement(tls13-finished, label[1], verifyData(VDATA?) MC, < SI : Server | transcript : TSC, handshakeSecret : HSEC, selectedCipherSuite : CS >)
   = rfcFinishedVerifyDataValid(hashC(CS), HSEC, TSC, VDATA?) .
endom

omod TLS13-KEY-UPDATE-REQUEST-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  vars CI SI : TId .
  var MC : MsgContent .
  var HT : HandshakeType .
  var KUR : KeyUpdateRequest .
  var RL : RFCLabel .

  eq rfc-requirement(tls13-server-key-update-request, RL, MC, OBJ)
   = rfc-requirement(tls13-client-key-update-request, RL, MC, OBJ) .

  --- [RFC 8446 Section 4] The expected handshake message is KeyUpdate.
  eq rfc-requirement(tls13-client-key-update-request, label[3], handshakeType(key-update-request) MC, OBJ) = true .

  eq rfc-requirement(tls13-client-key-update-request, label[3], handshakeType(certificate-request) MC, < CI : Client | >) = true .

  eq rfc-requirement(tls13-client-key-update-request, label[3], handshakeType(new-session-ticket) MC, < CI : Client | >) = true .

  eq rfc-requirement(tls13-client-key-update-request, label[3], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Sections 4 and 6] KeyUpdate syntax lengths must parse correctly.
  eq rfc-requirement(tls13-client-key-update-request, label[2], MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.6.3] KeyUpdate request_update value must be known.
  eq rfc-requirement(tls13-client-key-update-request, label[1], keyUpdateRequest(unknown) MC, OBJ) = false .

  eq rfc-requirement(tls13-client-key-update-request, label[1], keyUpdateRequest(KUR) MC, OBJ) = true [owise] .
endom

omod TLS13-END-OF-EARLY-DATA-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var MC : MsgContent .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 8446 Section 4.5] EndOfEarlyData is encrypted under client early traffic keys.
  eq rfc-requirement(tls13-end-of-early-data, label[1], contentType(application-data) MC, OBJ) = true .

  eq rfc-requirement(tls13-end-of-early-data, label[1], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Section 4.5] The expected handshake message is EndOfEarlyData.
  eq rfc-requirement(tls13-end-of-early-data, label[2], handshakeType(end-of-early-data) MC, OBJ) = true .

  eq rfc-requirement(tls13-end-of-early-data, label[2], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Sections 4.5 and 6] EndOfEarlyData syntax lengths must parse correctly.
	  eq rfc-requirement(tls13-end-of-early-data, label[3], MC, OBJ)
	   = validMsgSize(MC) .
	endom

omod TLS13-NEW-SESSION-TICKET-RFC-REQUIREMENTS is
  protecting TLS13-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var MC : MsgContent .
  var EXT : Extension .
  var HT : HandshakeType .
  var CT : ContentType .
  var TICKET : TicketId .
  var NONCE : Nonce .

  --- [RFC 8446 Section 5] NewSessionTicket is read under application-data record protection.
  eq rfc-requirement(tls13-new-session-ticket, label[4], contentType(application-data) MC, OBJ) = true .

  eq rfc-requirement(tls13-new-session-ticket, label[4], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Section 4] The expected handshake message is NewSessionTicket.
  eq rfc-requirement(tls13-new-session-ticket, label[3], handshakeType(new-session-ticket) MC, OBJ) = true .

  eq rfc-requirement(tls13-new-session-ticket, label[3], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 8446 Sections 4 and 6] NewSessionTicket syntax lengths must parse correctly.
  eq rfc-requirement(tls13-new-session-ticket, label[2], MC, OBJ)
   = validMsgSize(MC) .

  --- [RFC 8446 Section 4.6.1] NewSessionTicket extensions may include early_data and unknown extensions are ignored.
  eq rfc-requirement(tls13-new-session-ticket, label[1], newSessionTicket(TICKET, NONCE) extensions(EXT) MC, OBJ)
   = not duplicateExtension(EXT) and rfcAllowedNewSessionTicketExtensions(EXT) .

  eq rfc-requirement(tls13-new-session-ticket, label[1], MC, OBJ)
   = true [owise] .
endom

omod TLS13-RFC-REQUIREMENTS is
  protecting TLS13-CLIENT-HELLO-RFC-REQUIREMENTS .
  protecting TLS13-HELLO-RETRY-REQUEST-RFC-REQUIREMENTS .
  protecting TLS13-SERVER-HELLO-RFC-REQUIREMENTS .
  protecting TLS13-ENCRYPTED-EXTENSION-RFC-REQUIREMENTS .
  protecting TLS13-CERTIFICATE-REQUEST-RFC-REQUIREMENTS .
  protecting TLS13-CERTIFICATE-RFC-REQUIREMENTS .
  protecting TLS13-CERTIFICATE-VERIFY-RFC-REQUIREMENTS .
  protecting TLS13-FINISHED-RFC-REQUIREMENTS .
  protecting TLS13-END-OF-EARLY-DATA-RFC-REQUIREMENTS .
  protecting TLS13-NEW-SESSION-TICKET-RFC-REQUIREMENTS .
  protecting TLS13-KEY-UPDATE-REQUEST-RFC-REQUIREMENTS .

  vars SI CI : TId .
  vars MC FCH TSC : MsgContent .
  vars EXT EXT' : Extension .
  var CSL : List{CipherSuite} .
  var PIL : List{PSKInfo} .
  var N : Nat .
  var NONCE : Nonce .
  vars NONCE? NONCE'? SID? : Nonce? .
  var TICKET : TicketId .
  var KUR : KeyUpdateRequest .

  --- Full handshake
  eq messageError(< SI : Server | serverState : V3S-READY >, MC)
   = checkRequirements(tls13-client-hello, 20, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V3S-READY, firstClientHello : FCH >, MC)
   = checkRequirements(tls13-client-hello, 20, MC, < SI : Server | firstClientHello : FCH >) .

  eq messageError(< CI : Client | clientState : V3C-CT-HLO >, random(hrrNonce) MC)
   = checkRequirements(tls13-hello-retry-request, 14, random(hrrNonce) MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-CT-HLO >, random(hrrNonce) MC)
   = checkRequirements(tls13-hello-retry-request, 14, random(hrrNonce) MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-CT-HLO >, random(nonce(SI, N)) MC)
   = checkRequirements(tls13-server-hello, 22, random(nonce(SI, N)) MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-CT-HLO >, random(nonce(SI, N)) MC)
   = checkRequirements(tls13-server-hello, 22, random(nonce(SI, N)) MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-SRV-HLO >, MC)
   = checkRequirements(tls13-encrypted-extension, 5, MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-SRV-ENCEXTS >, certificate-request-context(NONCE?) MC)
   = checkRequirements(tls13-certificate-request, 5, certificate-request-context(NONCE?) MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-CERT-REQ >, MC)
   = checkRequirements(tls13-server-certificate, 7, MC, < CI : Client | >) .  

   eq messageError(< CI : Client | clientState : V3C-SRV-CERT >, MC)
   = checkRequirements(tls13-certificate-verify, 7, MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-SRV-CERT-VF >, MC)
   = checkRequirements(tls13-finished, 4, MC, < CI : Client | >) .

   eq messageError(< SI : Server | serverState : V3S-SRV-FIN >, MC)
   = checkRequirements(tls13-client-certificate, 8, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V3S-CT-CERT >, MC)
   = checkRequirements(tls13-certificate-verify, 7, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V3S-CT-CERT-VF >, MC)
   = checkRequirements(tls13-finished, 4, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V3S-END-EARLY-DATA >, MC)
   = checkRequirements(tls13-end-of-early-data, 3, MC, < SI : Server | >) .


  --- Post Handshakes
  eq messageError(< CI : Client | clientState : V3C-CT-FIN, postClientAuthReq : true, certificateRequestContext : NONCE'? >,
                  certificate-request-context(NONCE?) MC)
   = checkRequirements(tls13-certificate-request, 7, certificate-request-context(NONCE?) MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V3C-CT-FIN, newSessionTicketWait : true >, newSessionTicket(TICKET, NONCE) MC)
   = checkRequirements(tls13-new-session-ticket, 4, newSessionTicket(TICKET, NONCE) MC, < CI : Client | >) .


  --- Key Update
  eq messageError(< CI : Client | clientState : V3C-CT-FIN, keyUpdateWait : true >, keyUpdateRequest(KUR) MC)
   = checkRequirements(tls13-server-key-update-request, 3, keyUpdateRequest(KUR) MC, < CI : Client | >) .

  eq messageError(< SI : Server | serverState : V3S-CT-FIN, keyUpdateWait : true >, keyUpdateRequest(KUR) MC)
   = checkRequirements(tls13-client-key-update-request, 3, keyUpdateRequest(KUR) MC, < SI : Server | >) .
endom

omod TLS12-RFC-REQUIREMENTS-COMMON is
  protecting CHECK-RFC-REQUIREMENTS .
  protecting COMMON-AUX-OPERATOR .

  var CA : TId .
  var PARAM : MsgContent .
  var CS : CipherSuite .
  var KEX : KeyExchangeAlgorithm .
  vars EXT EXT' : Extension .
  vars SHL SHL' : List{SignatureAlgorithm} .
  vars SALGOL SALGOL' : List{SignatureAlgorithm} .
  vars SH SALGO : SignatureAlgorithm .
  var AUTH : AuthenticationAlgorithm .
  var HALGO : HashAlgorithm .
  vars NGL NGL' : List{NamedGroup} .
  vars NG NG' : NamedGroup .
  vars CV? SV? CV'? SV'? MS? HASH? : Nonce? .
  var MS : MasterSecret .
  var HASH : Nonce .
  vars CRANDOM SRANDOM KV : Nonce .
  vars CERT CERTL : List{Certificate} .
  var CITEM : CertificateItems .
  var PKA : PublicKeyAlgorithm .
  var SIGN : EncrMsgContent .
  var KEY : Key .
  var KEYS : Set{Key} .
  vars CAL : List{TId} .
  var B : Bool .
  vars SZ SZ' : MsgSize .

  op rfc12AllowedClientHelloExtensions : Extension -> Bool .
  eq rfc12AllowedClientHelloExtensions(signature-algorithms-len(valid) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(signature-algorithms(SHL) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(signature-algorithms-cert-len(valid) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(signature-algorithms-cert(SHL) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(supported-groups-len(valid) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(supported-groups(NGL) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(renegotiation-info(CV?, SV?) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(renegotiation-info-len(valid) EXT) = rfc12AllowedClientHelloExtensions(EXT) .
  eq rfc12AllowedClientHelloExtensions(EXT) = EXT == empty [owise] .


  op rfc12SignatureAlgorithmsDoNotContainAnon : Extension -> Bool .
  eq rfc12SignatureAlgorithmsDoNotContainAnon(signature-algorithms(SHL {anon,HALGO} SHL') EXT) = false .
  eq rfc12SignatureAlgorithmsDoNotContainAnon(signature-algorithms-cert(SHL {anon,HALGO} SHL') EXT) = false .
  eq rfc12SignatureAlgorithmsDoNotContainAnon(EXT) = true [owise] .


  op rfc12SignatureAlgorithmsOverlap : Extension Extension -> Bool .
  eq rfc12SignatureAlgorithmsOverlap(signature-algorithms(SH SHL) EXT, signature-algorithms(SHL') EXT')
   = occurs(SH, SHL') or rfc12SignatureAlgorithmsOverlap(signature-algorithms(SHL) EXT, signature-algorithms(SHL') EXT') .


  eq rfc12SignatureAlgorithmsOverlap(signature-algorithms(nil) EXT, signature-algorithms(SHL') EXT') = false .
  eq rfc12SignatureAlgorithmsOverlap(EXT, EXT') = true [owise] .


  op validClientRenegotiationInfoForV2 : Extension Nonce? Nonce? -> Bool .
  eq validClientRenegotiationInfoForV2(EXT, CV?, SV?) =
    if includeRenegotiationInfoExtension(EXT)
    then validClientRenegotiationInfo(EXT, CV?, SV?)
    else true
    fi .


  op validServerRenegotiationInfoForV2 : Bool Extension Nonce? Nonce? -> Bool .
  eq validServerRenegotiationInfoForV2(true, EXT, CV?, SV?) = validServerRenegotiationInfo(EXT, CV?, SV?) .
  eq validServerRenegotiationInfoForV2(false, EXT, CV?, SV?) = not includeRenegotiationInfoExtension(EXT) .


  op rfc12ServerHelloExtensionWasRequested : Extension Extension -> Bool .
  eq rfc12ServerHelloExtensionWasRequested(signature-algorithms(SHL) EXT, signature-algorithms(SHL') EXT')
   = rfc12ServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfc12ServerHelloExtensionWasRequested(signature-algorithms-len(SZ) EXT, signature-algorithms-len(SZ') EXT')
   = rfc12ServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfc12ServerHelloExtensionWasRequested(supported-groups(NGL) EXT, supported-groups(NGL') EXT')
   = rfc12ServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfc12ServerHelloExtensionWasRequested(supported-groups-len(SZ) EXT, supported-groups-len(SZ') EXT')
   = rfc12ServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfc12ServerHelloExtensionWasRequested(renegotiation-info(CV?, SV?) EXT, renegotiation-info(CV'?, SV'?) EXT')
   = rfc12ServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfc12ServerHelloExtensionWasRequested(renegotiation-info-len(SZ) EXT, renegotiation-info-len(SZ') EXT')
   = rfc12ServerHelloExtensionWasRequested(EXT, EXT') .
  eq rfc12ServerHelloExtensionWasRequested(EXT, EXT') = EXT' == empty [owise] .


  op rfc12NoServerSignatureAlgorithmsExtension : Extension -> Bool .
  eq rfc12NoServerSignatureAlgorithmsExtension(signature-algorithms(SHL) EXT) = false .
  eq rfc12NoServerSignatureAlgorithmsExtension(signature-algorithms-cert(SHL) EXT) = false .
  eq rfc12NoServerSignatureAlgorithmsExtension(EXT) = true [owise] .


  op rfc12NoServerSupportedGroupsExtension : Extension -> Bool .
  eq rfc12NoServerSupportedGroupsExtension(supported-groups(NGL) EXT) = false .
  eq rfc12NoServerSupportedGroupsExtension(EXT) = true [owise] .


  op rfc12ValidPublicKeyAlgorithm : AuthenticationAlgorithm PublicKeyAlgorithm -> Bool .
  eq rfc12ValidPublicKeyAlgorithm(rsa, rsaEncryption) = true .
  eq rfc12ValidPublicKeyAlgorithm(ecdsa, id-ecPublicKey) = true .
  eq rfc12ValidPublicKeyAlgorithm(dss, id-dsa) = true .
  eq rfc12ValidPublicKeyAlgorithm(dsa, id-dsa) = true .
  eq rfc12ValidPublicKeyAlgorithm(ed25519, id-Ed25519) = true .
  eq rfc12ValidPublicKeyAlgorithm(ed448, id-Ed448) = true .
  eq rfc12ValidPublicKeyAlgorithm(AUTH, PKA) = false [owise] .


  op rfc12SignatureMatchesPublicKeyAlgorithm : PublicKeyAlgorithm SignatureAlgorithm -> Bool .
  eq rfc12SignatureMatchesPublicKeyAlgorithm(id-ecPublicKey, SH) = authC(SH) == ecdsa .
  eq rfc12SignatureMatchesPublicKeyAlgorithm(rsaEncryption, SH) = authC(SH) == rsa .
  eq rfc12SignatureMatchesPublicKeyAlgorithm(id-dsa, SH) = authC(SH) == dsa .
  eq rfc12SignatureMatchesPublicKeyAlgorithm(id-Ed25519, SH) = authC(SH) == ed25519 .
  eq rfc12SignatureMatchesPublicKeyAlgorithm(id-Ed448, SH) = authC(SH) == ed448 .
  eq rfc12SignatureMatchesPublicKeyAlgorithm(PKA, SH) = false [owise] .


  op rfc12CertificatePublicKeyMatchesSuite : CipherSuite List{Certificate} -> Bool .
  eq rfc12CertificatePublicKeyMatchesSuite(CS, x509(crPublicKeyAlgorithm(PKA), CITEM))
   = rfc12CertificatePublicKeyMatchesSuite(keyC(CS), authC(CS), PKA) .
  eq rfc12CertificatePublicKeyMatchesSuite(CS, CERT) = true [owise] .

  op rfc12CertificatePublicKeyMatchesSuite : KeyExchangeAlgorithm AuthenticationAlgorithm PublicKeyAlgorithm -> Bool .
  eq rfc12CertificatePublicKeyMatchesSuite(rsaKE, AUTH, PKA) = PKA == rsaEncryption .
  eq rfc12CertificatePublicKeyMatchesSuite(dh, AUTH, PKA) = PKA == dhpublicnumber .
  eq rfc12CertificatePublicKeyMatchesSuite(ecdh, AUTH, PKA) = PKA == id-ecPublicKey .
  eq rfc12CertificatePublicKeyMatchesSuite(dhe, AUTH, PKA) = rfc12ValidPublicKeyAlgorithm(AUTH, PKA) .
  eq rfc12CertificatePublicKeyMatchesSuite(ecdhe, AUTH, PKA) = rfc12ValidPublicKeyAlgorithm(AUTH, PKA) .
  eq rfc12CertificatePublicKeyMatchesSuite(KEX, AUTH, PKA) = true [owise] .


  op rfc12CertificateIssuerAccepted : List{TId} List{Certificate} -> Bool .
  eq rfc12CertificateIssuerAccepted(CAL, x509(crIssuer(CA), CITEM)) = occurs(CA, CAL) .
  eq rfc12CertificateIssuerAccepted(CAL, CERT) = true [owise] .


  op rfc12CertificateSignatureValidWithExtension : Set{Key} Extension List{Certificate} -> Bool .
  eq rfc12CertificateSignatureValidWithExtension((KEY, KEYS), signature-algorithms(SALGOL SALGO SALGOL') EXT, x509(CITEM, crSignature(SIGN)))
   = decrypt(KEY, SIGN) == hashContent(hash(hashC(SALGO), certificates(x509(CITEM))))
     or rfc12CertificateSignatureValidWithExtension(KEYS, signature-algorithms(SALGOL SALGO SALGOL') EXT, x509(CITEM, crSignature(SIGN))) .
  eq rfc12CertificateSignatureValidWithExtension(empty, EXT, CERT) = false .
  eq rfc12CertificateSignatureValidWithExtension(KEYS, EXT, CERT) = true [owise] .


  op rfc12CertificateSignedByOfferedAlgorithm : Extension List{Certificate} -> Bool .
  eq rfc12CertificateSignedByOfferedAlgorithm(signature-algorithms(SALGOL) EXT, x509(crSignatureAlgorithm(SALGO), CITEM)) = occurs(SALGO, SALGOL) .
  eq rfc12CertificateSignedByOfferedAlgorithm(EXT, CERT) = true [owise] .


  op rfc12CertificateSignatureValidWithAlgorithms : Set{Key} List{SignatureAlgorithm} List{Certificate} -> Bool .
  eq rfc12CertificateSignatureValidWithAlgorithms((KEY, KEYS), SALGOL SALGO SALGOL', x509(CITEM, crSignature(SIGN)))
   = decrypt(KEY, SIGN) == hashContent(hash(hashC(SALGO), certificates(x509(CITEM))))
     or rfc12CertificateSignatureValidWithAlgorithms(KEYS, SALGOL SALGO SALGOL', x509(CITEM, crSignature(SIGN))) .
  eq rfc12CertificateSignatureValidWithAlgorithms(empty, SALGOL, CERT) = false .
  eq rfc12CertificateSignatureValidWithAlgorithms(KEYS, nil, CERT) = true [owise] .

  op rfc12CertificateSignatureValidWithEffectiveAlgorithms : CipherSuite Set{Key} Extension List{Certificate} -> Bool .
  eq rfc12CertificateSignatureValidWithEffectiveAlgorithms(CS, KEYS, EXT, CERT)
   = rfc12CertificateSignatureValidWithAlgorithms(KEYS, effectiveSignatureAlgorithmsV2(CS, EXT), CERT) .


  op rfc12CertificateSignedByRequestedAlgorithm : List{SignatureAlgorithm} List{Certificate} -> Bool .
  eq rfc12CertificateSignedByRequestedAlgorithm(SALGOL, x509(crSignatureAlgorithm(SALGO), CITEM)) = occurs(SALGO, SALGOL) .
  eq rfc12CertificateSignedByRequestedAlgorithm(SALGOL, CERT) = true [owise] .

  op rfc12CertificateSignedByEffectiveAlgorithm : CipherSuite Extension List{Certificate} -> Bool .
  eq rfc12CertificateSignedByEffectiveAlgorithm(CS, EXT, CERT)
   = rfc12CertificateSignedByRequestedAlgorithm(effectiveSignatureAlgorithmsV2(CS, EXT), CERT) .


  op rfc12CertificateListNonEmpty : List{Certificate} -> Bool .
  eq rfc12CertificateListNonEmpty(nil) = false .
  eq rfc12CertificateListNonEmpty(CERTL) = true [owise] .


  op rfc12CertificateVerifySignatureValid : Set{Key} Nonce EncrMsgContent -> Bool .
  eq rfc12CertificateVerifySignatureValid((KEY, KEYS), HASH, SIGN)
   = decrypt(KEY, SIGN) == hashContent(HASH) or rfc12CertificateVerifySignatureValid(KEYS, HASH, SIGN) .
  eq rfc12CertificateVerifySignatureValid(empty, HASH, SIGN) = false .

  op rfc12CertificateVerifyAlgorithmCompatible : List{Certificate} SignatureAlgorithm -> Bool .
  eq rfc12CertificateVerifyAlgorithmCompatible(x509(crPublicKeyAlgorithm(PKA), CITEM), SH)
   = rfc12SignatureMatchesPublicKeyAlgorithm(PKA, SH) .
  eq rfc12CertificateVerifyAlgorithmCompatible(CERTL, SH) = true [owise] .


  op rfc12ServerKeyExchangeSignatureValid : CipherSuite Set{Key} Nonce Nonce MsgContent EncrMsgContent -> Bool .
  eq rfc12ServerKeyExchangeSignatureValid(CS, (KEY, KEYS), CRANDOM, SRANDOM, PARAM, SIGN)
   = decrypt(KEY, SIGN) == random(CRANDOM) random(SRANDOM) PARAM
     or rfc12ServerKeyExchangeSignatureValid(CS, KEYS, CRANDOM, SRANDOM, PARAM, SIGN) .
  eq rfc12ServerKeyExchangeSignatureValid(CS, empty, CRANDOM, SRANDOM, PARAM, SIGN) = false .
  op rfc12ServerKeyExchangeGroupAccepted : CipherSuite MsgContent Extension -> Bool .
  eq rfc12ServerKeyExchangeGroupAccepted(CS, serverKeyExchange(NG,KV), supported-groups(NG') EXT)
   = not (keyC(CS) == ecdhe or keyC(CS) == ecdh) or NG == NG' .
  eq rfc12ServerKeyExchangeGroupAccepted(CS, PARAM, EXT) = true [owise] .

  op rfc12ServerKeyExchangeSignatureAlgorithmOffered : CipherSuite SignatureAlgorithm Extension -> Bool .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, signature-algorithms(SALGOL) EXT)
   = occurs(SALGO, SALGOL) .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, signature-algorithms-len(SZ) EXT)
   = rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, EXT) .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, signature-algorithms-cert(SALGOL) EXT)
   = rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, EXT) .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, signature-algorithms-cert-len(SZ) EXT)
   = rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, EXT) .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, EXT) = SALGO == {authC(CS),sha} [owise] .

  op rfc12ServerKeyExchangeSignatureAlgorithmOffered : SignatureAlgorithm Extension -> Bool .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(SALGO, signature-algorithms(SALGOL) EXT)
   = occurs(SALGO, SALGOL) .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(SALGO, signature-algorithms-len(SZ) EXT)
   = rfc12ServerKeyExchangeSignatureAlgorithmOffered(SALGO, EXT) .
  eq rfc12ServerKeyExchangeSignatureAlgorithmOffered(SALGO, EXT) = true [owise] .


  op rfc12FinishedVerifyDataValid : MasterSecret Nonce? Nonce Nonce? -> Bool .
  eq rfc12FinishedVerifyDataValid(MS, MS?, HASH, HASH?) = MS == MS? and HASH == HASH? .
endom

omod TLS12-CLIENT-HELLO-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var SI : TId .
  var MC : MsgContent .
  var PV : ProtocolVersion .
  vars CSL CSL' : List{CipherSuite} .
  vars CML CML' : List{CompressionMethod} .
  vars EXT EXT' : Extension .
  vars CV? SV? : Nonce? .
  vars DMS? : Nonce? .
  var SID? : Nonce? .
  var SID : Nonce .
  var SESS : SessionState .
  var DPCERTL : List{Certificate} .
  vars DCM? : CompressionMethod? .
  var DCM : CompressionMethod .
  vars DCS? : CipherSuite? .
  var DCS : CipherSuite .
  var B : Bool .
  var HT : HandshakeType .
  var CT : ContentType .

  op rfc12ClientHelloOffersSessionCipherSuite : SessionState Nonce? List{CipherSuite} -> Bool .
  eq rfc12ClientHelloOffersSessionCipherSuite(SESS, noNonce, CSL) = true .
 ceq rfc12ClientHelloOffersSessionCipherSuite(SESS, SID, CSL) = occurs(DCS, CSL)
  if {DPCERTL, DCM?, DCS, DMS?} := SESS[SID] .
  eq rfc12ClientHelloOffersSessionCipherSuite(SESS, SID?, CSL) = true [owise] .

  op rfc12ClientHelloOffersSessionCompression : SessionState Nonce? List{CompressionMethod} -> Bool .
  eq rfc12ClientHelloOffersSessionCompression(SESS, noNonce, CML) = true .
 ceq rfc12ClientHelloOffersSessionCompression(SESS, SID, CML) = occurs(DCM, CML)
  if {DPCERTL, DCM, DCS?, DMS?} := SESS[SID] .
  eq rfc12ClientHelloOffersSessionCompression(SESS, SID?, CML) = true [owise] .

  --- [RFC 5246 Section 6.2.1] ClientHello is carried in a handshake record.
  eq rfc-requirement(tls12-client-hello, label[13], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-client-hello, label[13], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.4.1.2] Resumption ClientHello MUST include the session cipher suite.
  eq rfc-requirement(tls12-client-hello, label[14], sessionId(SID?) cipherSuites(CSL') MC,
                     < SI : Server | sessionState : SESS >)
   = rfc12ClientHelloOffersSessionCipherSuite(SESS, SID?, CSL') .

  --- [RFC 5246 Section 7.4.1.2] Resumption ClientHello MUST include the session compression method.
  eq rfc-requirement(tls12-client-hello, label[15], sessionId(SID?) compressions(CML') MC,
                     < SI : Server | sessionState : SESS >)
   = rfc12ClientHelloOffersSessionCompression(SESS, SID?, CML') .

  --- [RFC 5246 Section 7.4] The expected handshake message is ClientHello.
  eq rfc-requirement(tls12-client-hello, label[12], handshakeType(client-hello) MC, OBJ) = true .

  eq rfc-requirement(tls12-client-hello, label[12], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] ClientHello syntax lengths must parse correctly.
  eq rfc-requirement(tls12-client-hello, label[11], MC, OBJ) = validMsgSize(MC) .

  --- [RFC 5746 Section 3.4] Client renegotiation_info MUST match previous verify_data.
  eq rfc-requirement(tls12-client-hello, label[10], extensions(EXT) MC, < SI : Server | prevClientVerifyData : CV?, prevServerVerifyData : SV? >)
   = validClientRenegotiationInfoForV2(EXT, CV?, SV?) .

  --- [RFC 5246 Section 7.4.1.4.1] Signature algorithms must overlap with server-supported algorithms.
  eq rfc-requirement(tls12-client-hello, label[9], extensions(EXT') MC, < SI : Server | extensions : EXT >)
   = rfc12SignatureAlgorithmsOverlap(EXT', EXT) .

  --- [RFC 5246 Section 7.4.1.4] ClientHello extensions must be extensions supported by this TLS 1.2 model.
  eq rfc-requirement(tls12-client-hello, label[8], extensions(EXT) MC, OBJ) = rfc12AllowedClientHelloExtensions(EXT) .

  --- [RFC 5246 Section 7.4.1.4.1] Missing signature_algorithms uses the suite-specific SHA-1 fallback.
  eq rfc-requirement(tls12-client-hello, label[7], extensions(EXT) MC, < SI : Server | clientCertificateReq : B >)
   = true .

  --- [RFC 5246 Section 7.4.1.4.1] The anonymous signature value MUST NOT appear in signature_algorithms.
  eq rfc-requirement(tls12-client-hello, label[6], extensions(EXT) MC, OBJ) = rfc12SignatureAlgorithmsDoNotContainAnon(EXT) .

  --- [RFC 5246 Section 7.4.1.4] There MUST NOT be more than one extension of the same type.
  eq rfc-requirement(tls12-client-hello, label[5], extensions(EXT) MC, OBJ) = not duplicateExtension(EXT) .

  --- [RFC 5246 Section 7.4.1.2] The server MUST select an acceptable compression method.
  eq rfc-requirement(tls12-client-hello, label[4], compressions(CML') MC, < SI : Server | compressions : CML >)
   = if occurs(no-compression, CML') then select(CML', CML) =/= noComp else true fi .

  --- [RFC 5246 Sections 7.4.1.2 and 7.4.3] The server MUST select an acceptable cipher suite.
  eq rfc-requirement(tls12-client-hello, label[3], cipherSuites(CSL') extensions(EXT) MC,
                     < SI : Server | cipherSuites : CSL >)
   = selectCipherSuiteV2(CSL, CSL', EXT) =/= noSuite
     and rfcCipherSuitesAllowedBySecurity(CSL') .

  --- [RFC 5246 Section 7.4.1.2] compression_methods MUST contain CompressionMethod.null.
  eq rfc-requirement(tls12-client-hello, label[2], compressions(CML) MC, OBJ) = occurs(no-compression, CML) .

  --- [RFC 5246 Section 7.4.1.2] ClientHello.client_version MUST be a supported TLS version.
  eq rfc-requirement(tls12-client-hello, label[1], protocol(PV) MC, OBJ) = PV == TLS-12 .
endom

omod TLS12-SERVER-HELLO-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var CI : TId .
  var MC : MsgContent .
  var PV : ProtocolVersion .
  var CSL : List{CipherSuite} .
  var CS : CipherSuite .
  var CML : List{CompressionMethod} .
  var CM : CompressionMethod .
  vars EXT EXT' : Extension .
  vars CV? SV? : Nonce? .
  var B : Bool .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 5246 Section 7.4.1.4] ServerHello extension responses require corresponding ClientHello requests.
  --- [RFC 5746 Section 3.6] renegotiation_info is permitted when secure renegotiation was signaled.
  eq rfc-requirement(tls12-server-hello, label[11],
                     contentType(handshake) handshakeType(server-hello) extensions(EXT') MC,
                     < CI : Client | extensions : EXT, secureRenegotiation : B, prevClientVerifyData : CV? >)
   = if validMsgSize(contentType(handshake) handshakeType(server-hello) extensions(EXT') MC)
     then rfc12ServerHelloExtensionWasRequested(
            extensionsFor(client-hello, EXT clientRenegotiationInfoForV2(B, CV?)),
            EXT')
     else true
     fi .

  eq rfc-requirement(tls12-server-hello, label[11], MC, OBJ) = true [owise] .

  --- [RFC 5246 Section 6.2.1] ServerHello is carried in a handshake record.
  eq rfc-requirement(tls12-server-hello, label[10], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-server-hello, label[10], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.4] The expected handshake message is ServerHello.
  eq rfc-requirement(tls12-server-hello, label[9], handshakeType(server-hello) MC, OBJ) = true .

  eq rfc-requirement(tls12-server-hello, label[9], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] ServerHello syntax lengths must parse correctly.
  eq rfc-requirement(tls12-server-hello, label[8], MC, OBJ) = validMsgSize(MC) .

  --- [RFC 5746 Section 3.6] Server renegotiation_info MUST match previous verify_data.
  eq rfc-requirement(tls12-server-hello, label[7], extensions(EXT) MC, < CI : Client | secureRenegotiation : B, prevClientVerifyData : CV?, prevServerVerifyData : SV? >)
   = validServerRenegotiationInfoForV2(B, EXT, CV?, SV?) .

  --- [RFC 5246 Section 7.4.1.4] There MUST NOT be duplicate ServerHello extensions.
  eq rfc-requirement(tls12-server-hello, label[6], extensions(EXT) MC, OBJ) = not duplicateExtension(EXT) .

  --- [RFC 4492 Section 5.1] Servers MUST NOT negotiate supported_groups in ServerHello in this model.
  eq rfc-requirement(tls12-server-hello, label[5], extensions(EXT) MC, OBJ) = rfc12NoServerSupportedGroupsExtension(EXT) .

  --- [RFC 5246 Section 7.4.1.4.1] Servers MUST NOT send supported_signature_algorithms.
  eq rfc-requirement(tls12-server-hello, label[4], extensions(EXT) MC, OBJ) = rfc12NoServerSignatureAlgorithmsExtension(EXT) .

  --- [RFC 5246 Section 7.4.1.3] The compression method selected by the server MUST be offered by the client.
  eq rfc-requirement(tls12-server-hello, label[3], compressions(CM) MC, < CI : Client | compressions : CML >) = occurs(CM, CML) .

  --- [RFC 5246 Section 7.4.1.3] The cipher suite selected by the server MUST be offered by the client.
  eq rfc-requirement(tls12-server-hello, label[2], cipherSuites(CS) MC, < CI : Client | cipherSuites : CSL >)
   = occurs(CS, CSL) and rfcCipherSuiteAllowedBySecurity(CS) .

  --- [RFC 5246 Section 7.4.1.3] ServerHello.server_version MUST be TLS 1.2 in this model.
  eq rfc-requirement(tls12-server-hello, label[1], protocol(PV) MC, OBJ) = PV == TLS-12 .
endom

omod TLS12-CERTIFICATE-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars CI SI : TId .
  var OBJ : Object .
  var MC : MsgContent .
  var CS : CipherSuite .
  var EXT : Extension .
  var SALGOL : List{SignatureAlgorithm} .
  vars CERT CERTL : List{Certificate} .
  var PUBKS : Set{Key} .
  vars CAL : List{TId} .
  var HT : HandshakeType .
  var CT : ContentType .
  var RL : RFCLabel .

  eq rfc-requirement(tls12-client-certificate, RL, MC, OBJ)
   = rfc-requirement(tls12-server-certificate, RL, MC, OBJ) .

  --- [RFC 5246 Section 6.2.1] Certificate is carried in a handshake record.
  eq rfc-requirement(tls12-server-certificate, label[8], contentType(handshake) MC, < CI : Client | >) = true .

  eq rfc-requirement(tls12-server-certificate, label[8], contentType(CT) MC, < CI : Client | >) = false [owise] .

  --- [RFC 5246 Section 6.2.1] Certificate is carried in a handshake record.
  eq rfc-requirement(tls12-server-certificate, label[8], contentType(handshake) MC, < SI : Server | >) = true .

  eq rfc-requirement(tls12-server-certificate, label[8], contentType(CT) MC, < SI : Server | >) = false [owise] .

  --- [RFC 5246 Section 7.4] The expected handshake message is Certificate.
  eq rfc-requirement(tls12-server-certificate, label[7], handshakeType(certificate) MC, < CI : Client | >) = true .

  eq rfc-requirement(tls12-server-certificate, label[7], handshakeType(HT) MC, < CI : Client | >) = false [owise] .

  --- [RFC 5246 Section 7.4] The expected handshake message is Certificate.
  eq rfc-requirement(tls12-server-certificate, label[7], handshakeType(certificate) MC, < SI : Server | >) = true .

  eq rfc-requirement(tls12-server-certificate, label[7], handshakeType(HT) MC, < SI : Server | >) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] Certificate syntax lengths must parse correctly.
  eq rfc-requirement(tls12-server-certificate, label[6], MC, < CI : Client | >) = validMsgSize(MC) .

  --- [RFC 5246 Sections 7.4 and 6] Certificate syntax lengths must parse correctly.
  eq rfc-requirement(tls12-server-certificate, label[6], MC, < SI : Server | >) = validMsgSize(MC) .

  --- [RFC 5246 Section 7.4.2] A non-anonymous server MUST send a non-empty certificate_list.
  eq rfc-requirement(tls12-server-certificate, label[5], certificates(CERTL) MC, < CI : Client | >) = rfc12CertificateListNonEmpty(CERTL) .

  --- [RFC 5246 Section 7.4.6] This model requires a non-empty client certificate_list when client auth is requested.
  eq rfc-requirement(tls12-server-certificate, label[5], certificates(CERTL) MC, < SI : Server | >) = rfc12CertificateListNonEmpty(CERTL) .

  --- [RFC 5246 Section 7.4.2] If signature_algorithms was omitted, use the suite-specific SHA-1 fallback.
  eq rfc-requirement(tls12-server-certificate, label[4], certificates(CERT) MC,
                     < CI : Client | extensions : EXT, selectedCipherSuite : CS >)
   = rfc12CertificateSignedByEffectiveAlgorithm(CS, EXT, CERT) .

  --- [RFC 5246 Section 7.4.6] Client certificates must use a requested signature algorithm.
  eq rfc-requirement(tls12-server-certificate, label[4], certificates(CERT) MC, < SI : Server | certificateAlgo : SALGOL >)
   = rfc12CertificateSignedByRequestedAlgorithm(SALGOL, CERT) .

  --- [RFC 5246 Section 7.4.2] Server certificate signatures must verify.
  eq rfc-requirement(tls12-server-certificate, label[3], certificates(CERT) MC,
                     < CI : Client | publicKey : PUBKS, extensions : EXT, selectedCipherSuite : CS >)
   = rfc12CertificateSignatureValidWithEffectiveAlgorithms(CS, PUBKS, EXT, CERT) .

  --- [RFC 5246 Section 7.4.6] Client certificate signatures must verify.
  eq rfc-requirement(tls12-server-certificate, label[3], certificates(CERT) MC, < SI : Server | publicKey : PUBKS, certificateAlgo : SALGOL >)
   = rfc12CertificateSignatureValidWithAlgorithms(PUBKS, SALGOL, CERT) .

  --- [RFC 5246 Section 7.4.2] Server certificate chains must be issued by an accepted authority in this model.
  eq rfc-requirement(tls12-server-certificate, label[2], certificates(CERT) MC, < CI : Client | certificateAuth : CAL >)
   = rfc12CertificateIssuerAccepted(CAL, CERT) .

  --- [RFC 5246 Section 7.4.6] Client certificates should be issued by one of the requested authorities.
  eq rfc-requirement(tls12-server-certificate, label[2], certificates(CERT) MC, < SI : Server | certificateAuth : CAL >)
   = rfc12CertificateIssuerAccepted(CAL, CERT) .

  --- [RFC 5246 Section 7.4.2] Server certificates MUST be appropriate for the negotiated cipher suite.
  eq rfc-requirement(tls12-server-certificate, label[1], certificates(CERT) MC, < CI : Client | selectedCipherSuite : CS >)
   = rfc12CertificatePublicKeyMatchesSuite(CS, CERT) .

  --- [RFC 5246 Section 7.4.6] Client certificates MUST be appropriate for the negotiated cipher suite.
  eq rfc-requirement(tls12-server-certificate, label[1], certificates(CERT) MC, < SI : Server | selectedCipherSuite : CS >)
   = rfc12CertificatePublicKeyMatchesSuite(CS, CERT) .
endom

omod TLS12-CLIENT-KEY-EXCHANGE-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var SI : TId .
  var MC : MsgContent .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 5246 Section 6.2.1] ClientKeyExchange is carried in a handshake record.
  eq rfc-requirement(tls12-client-key-exchange, label[3], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-client-key-exchange, label[3], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.4] The expected handshake message is ClientKeyExchange.
  eq rfc-requirement(tls12-client-key-exchange, label[2], handshakeType(client-key-exchange) MC, OBJ) = true .

  eq rfc-requirement(tls12-client-key-exchange, label[2], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.4.7] ClientKeyExchange syntax lengths must parse correctly.
  eq rfc-requirement(tls12-client-key-exchange, label[1], MC, OBJ) = validMsgSize(MC) .
endom

omod TLS12-CERTIFICATE-VERIFY-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var SI : TId .
  vars MC TSC : MsgContent .
  var SCL : List{SignatureAlgorithm} .
  var SC : SignatureAlgorithm .
  var SIGN : EncrMsgContent .
  var PUBKS : Set{Key} .
  var CERTL : List{Certificate} .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 5246 Section 7.4.8] CertificateVerify signature algorithm must be compatible with the client certificate key.
  eq rfc-requirement(tls12-certificate-verify, label[6], certificate-verify-algorithm(SC) MC,
                     < SI : Server | peerCertificate : CERTL >)
   = rfc12CertificateVerifyAlgorithmCompatible(CERTL, SC) .

  --- [RFC 5246 Section 6.2.1] CertificateVerify is carried in a handshake record.
  eq rfc-requirement(tls12-certificate-verify, label[5], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-certificate-verify, label[5], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.4] The expected handshake message is CertificateVerify.
  eq rfc-requirement(tls12-certificate-verify, label[4], handshakeType(certificate-verify) MC, OBJ) = true .

  eq rfc-requirement(tls12-certificate-verify, label[4], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] CertificateVerify syntax lengths must parse correctly.
  eq rfc-requirement(tls12-certificate-verify, label[3], MC, OBJ) = validMsgSize(MC) .

  --- [RFC 5246 Section 7.4.8] CertificateVerify signature algorithm must be requested.
  eq rfc-requirement(tls12-certificate-verify, label[2], signature(SIGN) certificate-verify-algorithm(SC) MC,
                     < SI : Server | transcript : TSC, publicKey : PUBKS, certificateAlgo : SCL >)
   = if rfc12CertificateVerifySignatureValid(PUBKS, hash(hashC(SC), TSC), SIGN) then occurs(SC, SCL) else true fi .

  eq rfc-requirement(tls12-certificate-verify, label[2], certificate-verify-algorithm(SC) MC, < SI : Server | certificateAlgo : SCL >)
   = occurs(SC, SCL) .

  --- [RFC 5246 Section 7.4.8] CertificateVerify signatures must verify over the handshake transcript.
  eq rfc-requirement(tls12-certificate-verify, label[1], signature(SIGN) certificate-verify-algorithm(SC) MC, < SI : Server | transcript : TSC, publicKey : PUBKS >)
   = rfc12CertificateVerifySignatureValid(PUBKS, hash(hashC(SC), TSC), SIGN) .
endom

omod TLS12-SERVER-KEY-EXCHANGE-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var CI : TId .
  var MC : MsgContent .
  var CS : CipherSuite .
  var EXT : Extension .
  var NG : NamedGroup .
  vars CRANDOM SRANDOM KV : Nonce .
  var SIGN : EncrMsgContent .
  vars KEYS PUBKS : Set{Key} .
  var CERTL : List{Certificate} .
  var SALGO : SignatureAlgorithm .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 5246 Section 6.2.1] ServerKeyExchange is carried in a handshake record.
  eq rfc-requirement(tls12-server-key-exchange, label[5], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-server-key-exchange, label[5], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.4] The expected handshake message is ServerKeyExchange.
  eq rfc-requirement(tls12-server-key-exchange, label[4], handshakeType(server-key-exchange) MC, OBJ) = true .

  eq rfc-requirement(tls12-server-key-exchange, label[4], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] ServerKeyExchange syntax lengths must parse correctly.
  eq rfc-requirement(tls12-server-key-exchange, label[3], MC, OBJ) = validMsgSize(MC) .

  --- [RFC 5246 Section 7.4.3] Ephemeral ECDH parameters must use an accepted group.
  eq rfc-requirement(tls12-server-key-exchange, label[2], serverKeyExchange(NG,KV) MC, < CI : Client | selectedCipherSuite : CS, extensions : EXT >)
   = rfc12ServerKeyExchangeGroupAccepted(CS, serverKeyExchange(NG,KV), EXT) .

  --- [RFC 5246 Section 7.4.3] ServerKeyExchange signatures must verify when present.
  eq rfc-requirement(tls12-server-key-exchange, label[1], serverKeyExchange(NG,KV) signature(SIGN) MC,
                     < CI : Client | publicKey : PUBKS, selectedCipherSuite : CS, clientRandom : CRANDOM, serverRandom : SRANDOM >)
   = rfc12ServerKeyExchangeSignatureValid(CS, PUBKS, CRANDOM, SRANDOM, serverKeyExchange(NG,KV), SIGN) .

  eq rfc-requirement(tls12-server-key-exchange, label[1], serverKeyExchange(NG,KV) MC, OBJ) = true [owise] .

  --- [RFC 5246 Section 7.4.3] If signature_algorithms was omitted,
  --- ServerKeyExchange must use the suite-specific SHA-1 fallback.
  eq rfc-requirement(tls12-server-key-exchange, label[6], server-key-exchange-algorithm(SALGO) MC,
                     < CI : Client | extensions : EXT, peerCertificate : CERTL, selectedCipherSuite : CS >)
   = rfc12ServerKeyExchangeSignatureAlgorithmOffered(CS, SALGO, EXT)
     and rfc12CertificateVerifyAlgorithmCompatible(CERTL, SALGO) .

  eq rfc-requirement(tls12-server-key-exchange, label[6], MC, OBJ) = true [owise] .
endom

omod TLS12-CERTIFICATE-REQUEST-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var CI : TId .
  var MC : MsgContent .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 5246 Section 7.4] CertificateRequest or ServerHelloDone may be expected at this point.
  eq rfc-requirement(tls12-certificate-request, label[3], handshakeType(certificate-request) MC, OBJ) = true .

  eq rfc-requirement(tls12-certificate-request, label[3], handshakeType(server-hello-done) MC, OBJ) = true .

  eq rfc-requirement(tls12-certificate-request, label[3], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 6.2.1] CertificateRequest is carried in a handshake record.
  eq rfc-requirement(tls12-certificate-request, label[2], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-certificate-request, label[2], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] CertificateRequest syntax lengths must parse correctly.
  eq rfc-requirement(tls12-certificate-request, label[1], MC, OBJ) = validMsgSize(MC) .
endom

omod TLS12-SERVER-HELLO-DONE-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  var CI : TId .
  var MC : MsgContent .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 5246 Section 7.4] The expected handshake message is ServerHelloDone.
  eq rfc-requirement(tls12-server-hello-done, label[3], handshakeType(server-hello-done) MC, OBJ) = true .

  eq rfc-requirement(tls12-server-hello-done, label[3], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 6.2.1] ServerHelloDone is carried in a handshake record.
  eq rfc-requirement(tls12-server-hello-done, label[2], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-server-hello-done, label[2], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] ServerHelloDone syntax lengths must parse correctly.
  eq rfc-requirement(tls12-server-hello-done, label[1], MC, OBJ) = validMsgSize(MC) .
endom

omod TLS12-CHANGE-CIPHER-SPEC-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  vars CI SI : TId .
  var MC : MsgContent .
  var CT : ContentType .

  --- [RFC 5246 Section 6.2.1] ChangeCipherSpec is carried in a change_cipher_spec record.
  eq rfc-requirement(change-cipher-spec-message, label[2], contentType(change-cipher-spec) MC, OBJ) = true .

  eq rfc-requirement(change-cipher-spec-message, label[2], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.1] ChangeCipherSpec syntax lengths must parse correctly.
  eq rfc-requirement(change-cipher-spec-message, label[1], MC, OBJ) = validMsgSize(MC) .
endom

omod TLS12-FINISHED-RFC-REQUIREMENTS is
  protecting TLS12-RFC-REQUIREMENTS-COMMON .

  vars OBJ : Object .
  vars CI SI : TId .
  vars MC TSC : MsgContent .
  var CS : CipherSuite .
  vars MS? HASH? : Nonce? .
  vars MS MS' : MasterSecret .
  var HASH' : Nonce .
  var HT : HandshakeType .
  var CT : ContentType .

  --- [RFC 5246 Section 6.2.1] Finished is carried in a handshake record.
  eq rfc-requirement(tls12-finished, label[4], contentType(handshake) MC, OBJ) = true .

  eq rfc-requirement(tls12-finished, label[4], contentType(CT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Section 7.4] The expected handshake message is Finished.
  eq rfc-requirement(tls12-finished, label[3], handshakeType(finished) MC, OBJ) = true .

  eq rfc-requirement(tls12-finished, label[3], handshakeType(HT) MC, OBJ) = false [owise] .

  --- [RFC 5246 Sections 7.4 and 6] Finished syntax lengths must parse correctly.
  eq rfc-requirement(tls12-finished, label[2], MC, OBJ) = validMsgSize(MC) .

  --- [RFC 5246 Section 7.4.9] Finished verify_data must match the handshake transcript and master secret.
  eq rfc-requirement(tls12-finished, label[1], verifyData(MS?, HASH?) MC, < SI : Server | transcript : TSC, selectedCipherSuite : CS, masterSecret : MS >)
   = rfc12FinishedVerifyDataValid(MS, MS?, hash(hashC(CS), TSC), HASH?) .

  eq rfc-requirement(tls12-finished, label[1], verifyData(MS?, HASH?) MC, < CI : Client | transcript : TSC, selectedCipherSuite : CS, masterSecret : MS >)
   = rfc12FinishedVerifyDataValid(MS, MS?, hash(hashC(CS), TSC), HASH?) .
endom

omod TLS12-RFC-REQUIREMENTS is
  protecting TLS12-CLIENT-HELLO-RFC-REQUIREMENTS .
  protecting TLS12-SERVER-HELLO-RFC-REQUIREMENTS .
  protecting TLS12-CERTIFICATE-RFC-REQUIREMENTS .
  protecting TLS12-CLIENT-KEY-EXCHANGE-RFC-REQUIREMENTS .
  protecting TLS12-CERTIFICATE-VERIFY-RFC-REQUIREMENTS .
  protecting TLS12-SERVER-KEY-EXCHANGE-RFC-REQUIREMENTS .
  protecting TLS12-CERTIFICATE-REQUEST-RFC-REQUIREMENTS .
  protecting TLS12-SERVER-HELLO-DONE-RFC-REQUIREMENTS .
  protecting TLS12-CHANGE-CIPHER-SPEC-RFC-REQUIREMENTS .
  protecting TLS12-FINISHED-RFC-REQUIREMENTS .

  vars SI CI : TId .
  var MC : MsgContent .
  var CSL : List{CipherSuite} .
  var CML : List{CompressionMethod} .
  var EXT : Extension .
  var B : Bool .
  vars CV? SV? : Nonce? .
  var CERTL : List{Certificate} .

  --- Full handshake
  eq messageError(< SI : Server | serverState : V2S-READY >, MC)
   = checkRequirements(tls12-client-hello, 15, MC, < SI : Server | >) .

  eq messageError(< CI : Client | clientState : V2C-CT-HLO, cipherSuites : CSL, compressions : CML,
                                 extensions : EXT, secureRenegotiation : B,
                                 prevClientVerifyData : CV?, prevServerVerifyData : SV? >, MC)
   = checkRequirements(tls12-server-hello, 11, MC,
       < CI : Client | cipherSuites : CSL, compressions : CML, extensions : EXT,
                       secureRenegotiation : B, prevClientVerifyData : CV?, prevServerVerifyData : SV? >) .

  eq messageError(< CI : Client | clientState : V2C-SRV-HLO >, MC)
   = checkRequirements(tls12-server-certificate, 8, MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V2C-SRV-CERT, extensions : EXT, peerCertificate : CERTL >, MC)
   = checkRequirements(tls12-server-key-exchange, 6, MC,
       < CI : Client | extensions : EXT, peerCertificate : CERTL >) .

  eq messageError(< CI : Client | clientState : V2C-SRV-KEY-X >, MC)
   = checkRequirements(tls12-certificate-request, 3, MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V2C-CERT-REQ >, MC)
   = checkRequirements(tls12-server-hello-done, 3, MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V2C-CT-FIN >, MC)
   = checkRequirements(change-cipher-spec-message, 2, MC, < CI : Client | >) .

  eq messageError(< CI : Client | clientState : V2C-SRV-CHG-CSPEC >, MC)
   = checkRequirements(tls12-finished, 4, MC, < CI : Client | >) .

  eq messageError(< SI : Server | serverState : V2S-HLO-DONE >, MC)
   = checkRequirements(tls12-client-certificate, 8, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V2S-CT-CERT >, MC)
   = checkRequirements(tls12-client-key-exchange, 3, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V2S-CT-KEY-X >, MC)
   = checkRequirements(tls12-certificate-verify, 6, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V2S-CT-CERT-VF >, MC)
   = checkRequirements(change-cipher-spec-message, 2, MC, < SI : Server | >) .

  eq messageError(< SI : Server | serverState : V2S-CT-CHG-CSPEC >, MC)
   = checkRequirements(tls12-finished, 4, MC, < SI : Server | >) .

  --- Renegotiation
  eq messageError(< SI : Server | serverState : V2S-DONE >, MC)
   = checkRequirements(tls12-client-hello, 15, MC, < SI : Server | >) .
endom
