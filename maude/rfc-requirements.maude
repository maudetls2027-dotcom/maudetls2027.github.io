  eq getAlertDescription(tls13-finished, label[1]) = decrypt-error .
  eq getAlertDescription(tls13-finished, label[2]) = decode-error .
  eq getAlertDescription(tls13-finished, label[3]) = unexpected-message .
  eq getAlertDescription(tls13-finished, label[4]) = unexpected-message .

  eq getAlertDescription(tls13-end-of-early-data, label[1]) = unexpected-message .
  eq getAlertDescription(tls13-end-of-early-data, label[2]) = unexpected-message .
  eq getAlertDescription(tls13-end-of-early-data, label[3]) = decode-error .

  eq getAlertDescription(tls13-client-key-update-request, label[1]) = illegal-parameter .
  eq getAlertDescription(tls13-client-key-update-request, label[2]) = decode-error .
  eq getAlertDescription(tls13-client-key-update-request, label[3]) = unexpected-message .

  eq getAlertDescription(tls13-server-key-update-request, label[1]) = illegal-parameter .
  eq getAlertDescription(tls13-server-key-update-request, label[2]) = decode-error .
  eq getAlertDescription(tls13-server-key-update-request, label[3]) = illegal-parameter .

  eq getAlertDescription(tls12-client-hello, label[1]) = protocol-version .
  eq getAlertDescription(tls12-client-hello, label[2]) = illegal-parameter .
  eq getAlertDescription(tls12-client-hello, label[3]) = handshake-failure .
  eq getAlertDescription(tls12-client-hello, label[4]) = handshake-failure .
