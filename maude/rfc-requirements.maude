  eq getAlertDescription(tls12-certificate-verify, label[6]) = illegal-parameter .

  eq getAlertDescription(tls12-server-key-exchange, label[1]) = decrypt-error .
  eq getAlertDescription(tls12-server-key-exchange, label[2]) = illegal-parameter .
