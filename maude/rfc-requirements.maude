fmod RFC-LABEL is
  protecting NAT .

  sort RFCLabel .
  op label[_] : Nat -> RFCLabel [ctor] .
endfm

mod RFC-REQUIREMENT-ALERT-DESCRIPTION-PAIR is
  protecting HANDSHAKE-TYPE .
  protecting RFC-LABEL .
  protecting ALERT .

  sort RFCRequirementTarget .

  --- ChangeCipherSpec is not a handshake message, but TLS 1.2 checks it through
  --- the same requirement/alert machinery.
  op change-cipher-spec-message : -> RFCRequirementTarget [ctor] .

  ops tls13-client-hello tls13-hello-retry-request
      tls13-server-hello tls13-encrypted-extension
      tls13-certificate-request
      tls13-server-certificate tls13-client-certificate
      tls13-certificate-verify tls13-finished
      tls13-end-of-early-data tls13-new-session-ticket
      tls13-client-key-update-request tls13-server-key-update-request
      tls12-client-hello tls12-server-hello
      tls12-server-certificate tls12-client-certificate
      tls12-client-key-exchange tls12-certificate-verify
      tls12-server-key-exchange tls12-certificate-request
      tls12-server-hello-done tls12-finished : -> RFCRequirementTarget [ctor] .

  op getAlertDescription : RFCRequirementTarget RFCLabel -> AlertDescription .
  eq getAlertDescription(tls13-client-hello, label[1]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[2]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[3]) = handshake-failure .
  eq getAlertDescription(tls13-client-hello, label[4]) = handshake-failure .
  eq getAlertDescription(tls13-client-hello, label[5]) = handshake-failure .
  eq getAlertDescription(tls13-client-hello, label[6]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[7]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[8]) = missing-extension .
  eq getAlertDescription(tls13-client-hello, label[9]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[10]) = protocol-version .
  eq getAlertDescription(tls13-client-hello, label[11]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[12]) = missing-extension .
  eq getAlertDescription(tls13-client-hello, label[13]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[14]) = missing-extension .
  eq getAlertDescription(tls13-client-hello, label[15]) = handshake-failure .
  eq getAlertDescription(tls13-client-hello, label[16]) = illegal-parameter .
  eq getAlertDescription(tls13-client-hello, label[17]) = decode-error .
  eq getAlertDescription(tls13-client-hello, label[18]) = unexpected-message .
  eq getAlertDescription(tls13-client-hello, label[19]) = unexpected-message .
  eq getAlertDescription(tls13-client-hello, label[20]) = illegal-parameter .

  eq getAlertDescription(tls13-hello-retry-request, label[1]) = handshake-failure .
  eq getAlertDescription(tls13-hello-retry-request, label[2]) = protocol-version .
  eq getAlertDescription(tls13-hello-retry-request, label[3]) = illegal-parameter .
  eq getAlertDescription(tls13-hello-retry-request, label[4]) = illegal-parameter .
  eq getAlertDescription(tls13-hello-retry-request, label[5]) = unexpected-message .
  eq getAlertDescription(tls13-hello-retry-request, label[6]) = handshake-failure .
  eq getAlertDescription(tls13-hello-retry-request, label[7]) = handshake-failure .
  eq getAlertDescription(tls13-hello-retry-request, label[8]) = handshake-failure .
  eq getAlertDescription(tls13-hello-retry-request, label[9]) = handshake-failure .
  eq getAlertDescription(tls13-hello-retry-request, label[10]) = handshake-failure .
  eq getAlertDescription(tls13-hello-retry-request, label[11]) = protocol-version .
  eq getAlertDescription(tls13-hello-retry-request, label[12]) = decode-error .
  eq getAlertDescription(tls13-hello-retry-request, label[13]) = unexpected-message .
  eq getAlertDescription(tls13-hello-retry-request, label[14]) = unexpected-message .

  eq getAlertDescription(tls13-server-hello, label[1]) = protocol-version .
