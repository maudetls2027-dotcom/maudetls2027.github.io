   = gen(getCertificate(MC) buildCertificateBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI) send(TI, EMC) AFL, MAP, N) .

  eq gen(buildMServerCertificateVerifyV3(MC, EMC, TI) AFL, MAP, N)
   = gen(buildCertificateVerifyBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI) send(TI, EMC) AFL, MAP, N) .

  eq gen(buildMServerFinishedV3(MC, EMC, TI) AFL, MAP, N)
   = gen(buildRandom(MC) buildFinishedBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI) send(TI, EMC) AFL, MAP, N) .

  eq gen(buildMClientCertificateV3(MC, EMC, TI) AFL, MAP, N)
   = gen(getCertificate(MC) buildCertificateBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI) send(TI, EMC) AFL, MAP, N) .

  eq gen(buildMClientCertificateVerifyV3(MC, EMC, TI) AFL, MAP, N)
   = gen(buildCertificateVerifyBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI) send(TI, EMC) AFL, MAP, N) .

  eq gen(buildMClientFinishedV3(MC, EMC, TI) AFL, MAP, N)
   = gen(buildRandom(MC) buildFinishedBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI) send(TI, EMC) AFL, MAP, N) .
endfm

mod INTERNAL-FORMAL-SCENARIO-GENERATOR is
  protecting FORMAL-SCENARIO-GENERATOR .
  protecting COMMON-AUX-OPERATOR .
  protecting BUILD-RECORD-LAYER .

  vars MC MC' MC'' EMC DMC : MsgContent .
  vars MAP MAP' : Map{TLSTerm,Nat} .
  vars N N' N'' BASE : Nat .
  var AFL : List{FormalAction} .
  var SCEN : Scen .

  vars TI TI' TI'' : TId .
  var CT : ContentType .
  var HT : HandshakeType .
  var PV : ProtocolVersion .
  var PVL : List{ProtocolVersion} .
  var CS : CipherSuite .
  var CSS : Set{CipherSuite} .
  var CSL : List{CipherSuite} .
  vars NONCE NONCE' HASH PSK : Nonce .
  vars SID? NONCE? : Nonce? .
  var CM : CompressionMethod .
  var CML : List{CompressionMethod} .
  var CMS : Set{CompressionMethod} .
  var EXT : Extension .
  vars LEN LEN' LEN'' LEN''' LEN'''' : MsgSize .
  var B : Bool .
  var KSS : Set{KeyShareEntry} .
  var KSL : List{KeyShareEntry} .
  var SE : ScenExp .
  var NG : NamedGroup .
  var NGL : List{NamedGroup} .
  var SC : SignatureAlgorithm .
  var SCL : List{SignatureAlgorithm} .
  var CERT : Certificate .
  var CERTL : List{Certificate} .
  var SHALGO : Set{SignatureAlgorithm} .
  var SHALGOL : List{SignatureAlgorithm} .
  var KEY : Key .
  var PMS : PreMasterSecret .
  var MS : MasterSecret .
  var AUTH : AuthenticationAlgorithm .
  var SIGN : EncrMsgContent .
  var AL : AlertLevel .
  var AD : AlertDescription .
  var CITEM : CertificateItems .
  var EM : PreSharedKeyExchangeMode .
  var EML : List{PreSharedKeyExchangeMode} .
  var TICKET : TicketId .
  var TICKETL : List{TicketId} .
  var NONCEL : List{Nonce} .
  var SZ : MsgSize .
  var CTL : List{CertificateType} .
  var CLL : List{SignatureAlgorithm} .
  var CAL : List{TId} .
  var KUR : KeyUpdateRequest .
  vars CV? SV? : Nonce? .

  eq addSameRecord(contentType(CT) version(PV) recordLen(SZ) EMC, MC)
   = contentType(CT) version(PV) recordLen(SZ) MC .
  eq addSameRecord(EMC, MC) = MC [owise] .

  eq gen(updateContext(TI, MC, B) AFL, MAP, N)
   = updateContext(TI, v[MAP[t[MC]]], B) ; gen(AFL, MAP, N) .

 ceq gen(buildRecord(TI, MC) AFL, MAP, N)
   = (v[N] := buildRecord(TI, c[CT], c[PV], c[LEN], v[MAP[t[MC']]])) ; gen(AFL, insert(t[MC], N, MAP), s N)
  if contentType(CT) version(PV) recordLen(LEN) MC' := MC .

  eq gen(buildRandom(random(NONCE) MC) AFL, MAP, N) 
   = (v[N] := generateRandom(NONCE)) ; gen(AFL, insert(t[NONCE], N, MAP), s N) .

  eq gen(buildRandom(verifyData(NONCE) MC) AFL, MAP, N) 
   = gen(AFL, MAP, N) .

  eq gen(buildRandom(verifyData(NONCE,NONCE') MC) AFL, MAP, N) 
   = gen(AFL, MAP, N) .

  eq gen(buildRandom(verifyData(noNonce) MC) AFL, MAP, N) 
   = (v[N] := generateRandom(noNonce)) ; gen(AFL, insert(t[noNonce], N, MAP), s N) .

  eq gen(buildRandom(verifyData(noNonce, noNonce) MC) AFL, MAP, N) 
   = (v[N] := generateRandom(noNonce)) ; gen(AFL, insert(t[noNonce], N, MAP), s N) .

  eq gen(buildRandom(certificate-request-context(NONCE) MC) AFL, MAP, N) 
   = if $hasMapping(MAP, t[NONCE]) 
     then gen(AFL, MAP, N)
     else (v[N] := generateRandom(NONCE)) ; gen(AFL, insert(t[NONCE], N, MAP), s N) fi .

  eq gen(buildRandom(certificate-request-context(noNonce) MC) AFL, MAP, N) 
   = (v[N] := generateRandom(noNonce)) ; gen(AFL, insert(t[noNonce], N, MAP), s N) .

  eq gen(buildRandom(newSessionTicket(TICKET, NONCE) MC) AFL, MAP, N) 
   = (v[N] := generateRandom(NONCE)) ; gen(AFL, insert(t[NONCE], N, MAP), s N) .


  eq gen(buildSessionId(sessionId(SID?) MC) AFL, MAP, N) 
   = if $hasMapping(MAP, t[SID?]) 
     then gen(AFL, MAP, N)
     else (v[N] := generateRandom(SID?)) ; gen(AFL, insert(t[SID?], N, MAP), s N)
     fi .

  eq gen(buildTicket(newSessionTicket(TICKET, NONCE) MC) AFL, MAP, N)
   = (v[N] := generateTicket(v[MAP[t[NONCE]]])) ; gen(AFL, insert(t[TICKET], N, MAP), s N) .

  eq gen(buildPSK(TI, newSessionTicket(TICKET, NONCE) MC, PSK) AFL, MAP, N)
   = (v[N] := generatePSK(TI, v[MAP[t[TICKET]]])) ; gen(AFL, insert(t[PSK], N, MAP), s N) .

 ceq gen(buildClientHelloBody(TI, MC) AFL, MAP, N) 
   = (v[N] := buildClientHello(TI, c[HT], c[PV], c[LEN'], c[CSL], v[MAP[t[NONCE]]], c[LEN''], v[MAP[t[SID?]]], c[LEN'''], c[CML])) ; 
     gen(addExtension(TI, EXT, MC') addExtensionLen(TI, LEN'''', MC') addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N) 
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) 
     protocol(PV) cipherSuites(CSL) cipherSuitesLen(LEN') random(NONCE) sessionId(SID?) sessionIdLen(LEN'') compressions(CML) compressionsLen(LEN''') 
     extensions(EXT) extensionsLen(LEN'''') := MC' .

 ceq gen(buildServerHelloBody(TI, MC) AFL, MAP, N) 
   = (v[N] := buildServerHello(TI, c[HT], c[PV], c[CS], v[MAP[t[NONCE]]], c[LEN'], v[MAP[t[SID?]]], c[CM])) ; 
     gen(addExtension(TI, EXT, MC') addExtensionLen(TI, LEN'', MC') addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N) 
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) 
     protocol(PV) cipherSuites(CS) random(NONCE) sessionId(SID?) sessionIdLen(LEN') compressions(CM) extensions(EXT) extensionsLen(LEN'') := MC' .

 ceq gen(buildEncryptedExtensionBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildEncryptedExtension(TI, c[HT])) ;
     gen(addExtension(TI, EXT, MC') addExtensionLen(TI, LEN', MC') addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) extensions(EXT) extensionsLen(LEN') := MC' .

  eq gen(getCertificate(certificates(nil) MC) AFL, MAP, N)
   = (v[N] := generateEmptyCertificate()) ; gen(AFL, insert(t[(nil).List{Certificate}], N, MAP), s N) .

  eq gen(getCertificate(certificates(CERT) MC) AFL, MAP, N)
   = (v[N] := getCertificate(cert-path)) ; gen(AFL, insert(t[CERT], N, MAP), s N) .

 ceq gen(buildCertificateBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildCertificate(TI, c[HT], c[LEN'], v[MAP[t[CERTL]]])) ; gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) certificatesLen(LEN') certificates(CERTL) := MC' .

 ceq gen(buildCertificateBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildCertificate(TI, c[HT], c[LEN'], v[MAP[t[CERTL]]])) ; gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) certificatesLen(LEN') certificates(CERTL) extensions(EXT) extensionsLen(valid) := MC' .

 ceq gen(buildCertificateBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildCertificate(TI, c[HT], c[LEN'], v[MAP[t[CERTL]]], c[LEN''], v[MAP[t[NONCE?]]])) ; gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) certificate-request-context-len(LEN'') certificate-request-context(NONCE?) certificatesLen(LEN') certificates(CERTL) 
     extensions(EXT) extensionsLen(valid) := MC' .

 ceq gen(buildCertificateRequestBodyV2(TI, MC) AFL, MAP, N)
   = (v[N] := buildCertificateRequest(TI, c[HT], c[CTL], c[LEN'], c[CLL], c[LEN''])) ; 
     gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) 
     certificateTypesLen(LEN') certificateTypes(CTL) certificateAlgosLen(LEN'') certificateAlgos(CLL) certificateAuthsLen(LEN''') certificateAuths(CAL) := MC' .

 ceq gen(buildCertificateRequestBodyV3(TI, MC) AFL, MAP, N)
   = (v[N] := buildCertificateRequest(TI, c[HT], c[LEN'], v[MAP[t[NONCE?]]])) ; 
     gen(addExtension(TI, EXT, MC') addExtensionLen(TI, LEN'', MC') addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) certificate-request-context(NONCE?) certificate-request-context-len(LEN')
     extensions(EXT) extensionsLen(LEN'') := MC' .

 ceq gen(buildCertificateVerifyBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildCertificateVerify(TI, c[HT], v[MAP[t[KEY]]])) ; gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) signature-len(valid) signature(encrypt(KEY, MC'')) := MC'
  /\ $hasMapping(MAP, t[KEY]) .

 ceq gen(buildCertificateVerifyBody(TI, MC) AFL, MAP, N)
   = (v[N] := genCertificatePrivateKey(prvkey-path)) ; (v[s N] := buildCertificateVerify(TI, c[HT], v[N])) ;
     gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], s N, insert(t[KEY], N, MAP)), s s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) signature-len(valid) signature(encrypt(KEY, MC'')) := MC'
  /\ not $hasMapping(MAP, t[KEY]) .

 ceq gen(buildCertificateVerifyBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildCertificateVerify(TI, c[HT], c[SC], v[MAP[t[KEY]]])) ; gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) certificate-verify-algorithm(SC) signature-len(LEN') signature(encrypt(KEY, MC'')) := MC'
  /\ $hasMapping(MAP, t[KEY]) .

 ceq gen(buildCertificateVerifyBody(TI, MC) AFL, MAP, N)
   = (v[N] := genCertificatePrivateKey(prvkey-path)) ; (v[s N] := buildCertificateVerify(TI, c[HT], c[SC], v[N])) ;
     gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], s N, insert(t[KEY], N, MAP)), s s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) certificate-verify-algorithm(SC) signature-len(LEN') signature(encrypt(KEY, MC'')) := MC'
  /\ not $hasMapping(MAP, t[KEY]) .

 ceq gen(buildServerKeyExchangeBody(TI, MC) AFL, MAP, N)
   = (v[N] := generateRandom(NONCE)) ;
     (v[s N] := buildECDHEServerKeyExchange(TI, c[HT], c[namedcurve], c[NG:NamedGroup], v[N], v[MAP[t[KEY]]])) ; 
	 gen(AFL, insert(t[MC'], s N, insert(t[NONCE], N, MAP)), s s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) serverKeyExchange(NG:NamedGroup,ecdh(NG:NamedGroup, NONCE))
     server-key-exchange-algorithm(SC) signature(encrypt(KEY, MC'')) := MC'
  /\ $hasMapping(MAP, t[KEY]) .

 ceq gen(buildServerKeyExchangeBody(TI, MC) AFL, MAP, N)
   = (v[N] := genCertificatePrivateKey(prvkey-path)) ;
     (v[s N] := generateRandom(NONCE)) ;
     (v[s s N] := buildECDHEServerKeyExchange(TI, c[HT], c[namedcurve], c[NG:NamedGroup], v[s N], v[N])) ;
     gen(AFL, insert(t[MC'], s s N, insert(t[NONCE], s N, insert(t[KEY], N, MAP))), s s s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) serverKeyExchange(NG:NamedGroup,ecdh(NG:NamedGroup, NONCE))
     server-key-exchange-algorithm(SC) signature(encrypt(KEY, MC'')) := MC'
  /\ not $hasMapping(MAP, t[KEY]) .

 ceq gen(buildServerKeyExchangeBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildServerKeyExchange(TI, c[HT])) ; gen(AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) MC'' := MC' .


 ceq gen(buildClientKeyExchangeBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildClientKeyExchange(TI, c[HT], v[MAP[t[KEY]]], v[MAP[t[PMS]]])) ; gen(AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) encrypt(KEY, clientPMSParam(PMS)) := MC' .

 ceq gen(buildClientKeyExchangeBody(TI, MC) AFL, MAP, N)
   = (v[N] := generateRandom(NONCE)) ;
     (v[s N] := buildECDHClientKeyExchange(TI, c[HT], v[N])) ; gen(AFL, insert(t[MC'], s N, insert(t[NONCE], N, MAP)), s s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) clientECDHParam(ecdh(NG,NONCE)) := MC' .

 ceq gen(buildServerHelloDoneBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildServerHelloDone(TI, c[HT])) ; gen(AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) := MC' .

 ceq gen(buildEndOfEarlyDataBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildEndOfEarlyData()) ; gen(AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) := MC' .

  eq gen(buildChangeCipherSpecBody(TI, changeCipherSpec MC) AFL, MAP, N)
   = (v[N] := buildChangeCipherSpec(TI)) ; gen(AFL, insert(t[changeCipherSpec], N, MAP), s N) .

 ceq gen(buildFinishedBody(TI, MC) AFL, MAP, N)
   = (v[N] := generateVerifyData(TI)) ; (v[s N] := buildFinished(TI, c[HT], v[N])) ; gen(AFL, insert(t[MC'], s N, MAP), s s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) verifyData(NONCE) := MC' .

 ceq gen(buildFinishedBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildFinished(TI, c[HT], v[MAP[t[noNonce]]])) ; gen(AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) verifyData(noNonce) := MC' .

 ceq gen(buildFinishedBody(TI, MC) AFL, MAP, N)
   = (v[N] := generateVerifyData(TI)) ; (v[s N] := buildFinished(TI, c[HT], v[N])) ; gen(AFL, insert(t[MC'], s N, MAP), s s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) verifyData(MS,HASH) := MC' .

 ceq gen(buildFinishedBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildFinished(TI, c[HT], v[MAP[t[noNonce]]])) ; gen(AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) verifyData(noNonce,noNonce) := MC' .

 ceq gen(buildNewSessionTicketBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildNewSessionTicket(TI, v[MAP[t[TICKET]]])) ; gen(AFL, insert(t[MC'], N, MAP), s N) 
	  if MC' := removeRecord(MC)
	  /\ handshakeType(new-session-ticket) handshakeLen(valid) newSessionTicket(TICKET, NONCE) MC'' := MC' .

 ceq gen(buildKeyUpdateRequestBody(TI, MC) AFL, MAP, N)
   = (v[N] := buildKeyUpdateRequest(TI, c[HT], c[KUR])) ; gen(addHandshakeLen(TI, LEN, MC') AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ handshakeType(HT) handshakeLen(LEN) keyUpdateRequest(KUR) := MC' .

 ceq gen(buildAlert(TI, MC) AFL, MAP, N)
   = (v[N] := buildAlert(TI, c[AL], c[AD])) ; gen(AFL, insert(t[MC'], N, MAP), s N)
  if MC' := removeRecord(MC)
  /\ alertLev(AL) alertDesc(AD) := MC' .

  eq gen(learnClientRandom(MC, NONCE) AFL, MAP, N)
   = (v[N] := getRandom(v[MAP[t[MC]]])) ; gen(AFL, insert(t[NONCE], N, MAP), s N) .

  eq gen(learnServerRandom(MC, NONCE) AFL, MAP, N)
   = (v[N] := getRandom(v[MAP[t[MC]]])) ; gen(AFL, insert(t[NONCE], N, MAP), s N) .

  eq gen(learnCipherSuite(MC, CSS) AFL, MAP, N)
   = (v[N] := getCipherSuites(v[MAP[t[MC]]])) ; gen(AFL, insert(t[CSS], N, MAP), s N) .

  eq gen(learnCompressionMethod(MC, CMS) AFL, MAP, N)
   = (v[N] := getCompressionMethods(v[MAP[t[MC]]])) ; gen(AFL, insert(t[CMS], N, MAP), s N) .

  eq gen(learnKeySharesExtension(MC, KSS) AFL, MAP, N)
   = (v[N] := getKeyShareEntries(v[MAP[t[MC]]])) ; gen(AFL, insert(t[KSS], N, MAP), s N) .

 ceq gen(learnPublicKey(MC) AFL, MAP, N)
   = gen(learnPublicKey(MC, KEY) AFL, MAP, N) 
  if certificates(x509(CITEM, crPublicKey(KEY))) MC' := MC .

  eq gen(learnPublicKey(MC, KEY) AFL, MAP, N)
   = (v[N] := getPublicKeyFromCertificate(getCertificate(v[MAP[t[MC]]]))) ; gen(AFL, insert(t[KEY], N, MAP), s N) .

  eq gen(learnRSAPreMasterSecret(MC,KEY,PMS,TI) AFL, MAP, N)
   = (v[N] := getRSAPreMasterSecret(v[MAP[t[MC]]], v[MAP[t[KEY]]], TI)) ; gen(AFL, insert(t[PMS], N, MAP), s N) .

  eq gen(learnTicket(TI, PSK, newSessionTicket(TICKET, NONCE) MC) AFL, MAP, N)
   = (v[N] := getTicket(v[MAP[t[newSessionTicket(TICKET, NONCE) MC]]])) ; gen(AFL, insert(t[TICKET], N, MAP), s N) .

  eq gen(addServerRandom(NONCE) AFL, MAP, N) 
   = (v[N] := generateRandom(NONCE)) ; gen(AFL, insert(t[NONCE], N, MAP), s N) .

  eq gen(addPreMasterSecret(PV,NONCE,PMS) AFL, MAP, N) 
   = (v[N] := generateRandom(NONCE)) ; (v[s N] := generatePreMasterSecret(c[PV], v[N])) ; gen(AFL, insert(t[PMS], s N, insert(t[NONCE], N, MAP)), s s N) .

  eq gen(addHandshakeLen(TI, LEN, MC) AFL, MAP, N)
   = addHandshakeLen(TI, c[LEN], v[MAP[t[MC]]]) ; gen(AFL, MAP, N) .

  eq gen(addExtensionLen(TI, LEN, MC) AFL, MAP, N)
   = addExtensionLen(TI, c[LEN], v[MAP[t[MC]]]) ; gen(AFL, MAP, N) .

  eq gen(addExtension(TI, pre-shared-key(N) pre-shared-key-len(SZ) EXT, MC) AFL, MAP, N')
   = addSHPreSharedKeyExtension(TI, c[SZ], v[MAP[t[MC]]], c[N]) ; gen(addExtension(TI, EXT, MC), MAP, N') .
  
 ceq gen(addExtension(TI, pre-shared-key(tkId(TI',N'), nonce(TI'',N'')) pre-shared-key-len(SZ), MC) AFL, MAP, N)
   = addCHPreSharedKeyExtension(TI, c[SZ], v[MAP[t[MC]]], v[MAP[t[tkId(TI',N')]]]) ;
     setCHPreSharedKeyBinder(TI, v[MAP[t[MC]]], v[MAP[t[nonce(TI'',N'')]]]) ;
     gen(AFL, MAP, N)
  if $hasMapping(MAP, t[tkId(TI',N')])
  /\ $hasMapping(MAP, t[nonce(TI'',N'')]) .

 ceq gen(addExtension(TI, pre-shared-key(tkId(TI',N'), nonce(TI'',N'')) pre-shared-key-len(SZ), MC) AFL, MAP, N)
   = addCHPreSharedKeyExtension(TI, c[SZ], v[MAP[t[MC]]], v[MAP[t[tkId(TI',N')]]]) ;
     (v[N] := generateRandom(nonce(TI'', N''))) ;
     setCHPreSharedKeyBinder(TI, v[MAP[t[MC]]], v[N]) ;
     gen(AFL, insert(t[nonce(TI'',N'')], N, MAP), s N)
  if $hasMapping(MAP, t[tkId(TI',N')])
  /\ not $hasMapping(MAP, t[nonce(TI'',N'')]) .

  eq gen(addExtension(TI, pre-shared-key(tkId(TI',N'), NONCE) pre-shared-key-len(SZ), MC) AFL, MAP, N)
   = if $hasMapping(MAP, t[tkId(TI',N')])
     then addCHPreSharedKeyExtension(TI, c[SZ], v[MAP[t[MC]]], v[MAP[t[tkId(TI',N')]]]) ; gen(AFL, MAP, N) 
     else (v[N] := generateRandom(nonce(TI', N'))) ; addCHPreSharedKeyExtension(TI, c[SZ], v[MAP[t[MC]]], v[N]) ; gen(AFL, MAP, s N) fi .

  eq gen(addExtension(TI, key-shares(NG) key-shares-len(SZ) EXT, MC) AFL, MAP, N)
   = addHRRKeyShareExtension(TI, c[SZ], v[MAP[t[MC]]], c[NG]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, s N) .

 ceq gen(addExtension(TI, key-shares(KSL) key-shares-len(SZ) EXT, MC) AFL, MAP, N)
   = SCEN ; addKeyShareExtension(TI, c[SZ], v[MAP[t[MC]]], v[BASE]) ; gen(addExtension(TI, EXT, MC) AFL, MAP', N')
  if {SCEN,MAP',N',BASE} := genKeyShareEntryList(TI, KSL, MAP, N) .

  sort Tuple{Scen,Map{TLSTerm,Nat},Nat,Nat} .
  op {_,_,_,_} : Scen Map{TLSTerm,Nat} Nat Nat -> Tuple{Scen,Map{TLSTerm,Nat},Nat,Nat} [ctor] .

  op genKeyShareEntryList : TId List{KeyShareEntry} Map{TLSTerm,Nat} Nat -> Tuple{Scen,Map{TLSTerm,Nat},Nat,Nat} . 
  op genKeyShareEntryList : TId List{KeyShareEntry} Map{TLSTerm,Nat} Nat Nat ScenStmt -> Tuple{Scen,Map{TLSTerm,Nat},Nat,Nat} . 

  eq genKeyShareEntryList(TI, KSL, MAP, N) = genKeyShareEntryList(TI, KSL, MAP, s N, N, (v[N] := buildEmptyKeyShareEntryList())) .

  eq genKeyShareEntryList(TI, {NG, dh(NG, NONCE)} KSL, MAP, N, BASE, SCEN)
   = genKeyShareEntryList(TI, KSL, insert(t[NONCE], N, MAP), s N, BASE, SCEN ; (v[N] := generateRandom(NONCE)) ; (addKeyShareEntry(TI, v[BASE], v[N], c[NG]))) .

  eq genKeyShareEntryList(TI, {NG, ecdh(NG, NONCE)} KSL, MAP, N, BASE, SCEN)
   = genKeyShareEntryList(TI, KSL, insert(t[NONCE], N, MAP), s N, BASE, SCEN ; (v[N] := generateRandom(NONCE)) ; (addKeyShareEntry(TI, v[BASE], v[N], c[NG]))) .

  eq genKeyShareEntryList(TI, nil, MAP, N, BASE, SCEN) = {SCEN,MAP,N,BASE} .

  eq gen(addExtension(TI, supported-versions(PVL) supported-versions-len(SZ) EXT, MC) AFL, MAP, N)
   = addSupportedVersionExtension(TI, c[SZ], v[MAP[t[MC]]], c[PVL]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, supported-groups(NGL) supported-groups-len(SZ) EXT, MC) AFL, MAP, N)
   = addSupportedGroupExtension(TI, c[SZ], v[MAP[t[MC]]], c[NGL]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, signature-algorithms(SCL) signature-algorithms-len(SZ) EXT, MC) AFL, MAP, N)
   = addSignatureAlgorithmExtension(TI, c[SZ], v[MAP[t[MC]]], c[SCL]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, signature-algorithms-cert(SCL) signature-algorithms-cert-len(SZ) EXT, MC) AFL, MAP, N)
   = addSignatureAlgorithmCertExtension(TI, c[SZ], v[MAP[t[MC]]], c[SCL]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, psk-key-exchange-mode(EML) psk-key-exchange-mode-len(SZ) EXT, MC) AFL, MAP, N)
   = addPSKExchangeModeExtension(TI, c[SZ], v[MAP[t[MC]]], c[EML]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, early-data early-data-len(SZ) EXT, MC) AFL, MAP, N)
   = addEarlyDataExtension(TI, c[SZ], v[MAP[t[MC]]]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, post-handshake post-handshake-len(SZ) EXT, MC) AFL, MAP, N)
   = addPostHandshakeAuthExtension(TI, c[SZ], v[MAP[t[MC]]]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, renegotiation-info(CV?, SV?) renegotiation-info-len(SZ) EXT, MC) AFL, MAP, N)
   = addRenegotiationInfoExtension(TI, c[SZ], v[MAP[t[MC]]]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, renegotiation-info-len(SZ) renegotiation-info(CV?, SV?) EXT, MC) AFL, MAP, N)
   = addRenegotiationInfoExtension(TI, c[SZ], v[MAP[t[MC]]]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, cks cks-len(SZ) EXT, MC) AFL, MAP, N)
   = addCKSExtension(TI, c[SZ], v[MAP[t[MC]]]) ; gen(addExtension(TI, EXT, MC) AFL, MAP, N) .

  eq gen(addExtension(TI, empty, MC) AFL, MAP, N)
   = gen(AFL, MAP, N) .

 ceq gen(encryptOrPlain(MC, EMC, TI) AFL, MAP, N)
   = gen(AFL, insert(t[EMC], MAP[t[MC]], MAP), N)
  if MC == EMC .

 ceq gen(encryptOrPlain(MC, EMC, TI) AFL, MAP, N)
   = (v[N] := encrypt(TI, v[MAP[t[MC]]])) ; gen(AFL, insert(t[EMC], N, MAP), s N)
  if MC =/= EMC .

  eq gen(decrypt(MC, DMC, TI) AFL, MAP, N)
   = (v[N] := decrypt(TI, v[MAP[t[MC]]])) ; gen(AFL, insert(t[DMC], N, MAP), s N) .
endm
