fmod TLS-TERM is
  protecting TLS-MESSAGE-CONTENT .
  protecting SET{CipherSuite} .
  protecting SET{CompressionMethod} .
  protecting SET{KeyShareEntry} .

  sort TLSTerm .
  op t[_] : MsgContent -> TLSTerm [ctor] .
  op t[_] : Nonce? -> TLSTerm [ctor] .
  op t[_] : PreMasterSecret -> TLSTerm [ctor] .
  op t[_] : Set{CipherSuite} -> TLSTerm [ctor] .
  op t[_] : Set{CompressionMethod} -> TLSTerm [ctor] .
  op t[_] : Key -> TLSTerm [ctor] .
  op t[_] : Set{KeyShareEntry} -> TLSTerm [ctor] .
  op t[_] : List{Certificate} -> TLSTerm [ctor] .
  op t[_] : TicketId -> TLSTerm [ctor] .
endfm

view TLSTerm from TRIV to TLS-TERM is
  sort Elt to TLSTerm .
endv

fmod SCENARIO is
  protecting NAT .
  protecting STRING .
  protecting TLS-MESSAGE-CONTENT .
  protecting SET{SignatureAlgorithm} .
  protecting SET{Certificate} .

  sort Scen .
  op nil : -> Scen [ctor] .
  op _;_ : Scen Scen -> Scen [ctor assoc id: nil format(d d n d)] .

  sorts ScenConst ScenVar ScenExp ScenStmt .
  subsort ScenConst ScenVar < ScenExp .
  subsort ScenStmt < Scen .

  op _:=_ : ScenVar ScenExp -> ScenStmt [ctor] .
  op v[_] : Nat -> ScenVar [ctor] .
  op c[_] : Nat -> ScenVar [ctor] .
  op c[_] : Nonce? -> ScenConst [ctor] .
  op c[_] : ContentType -> ScenConst [ctor] .
  op c[_] : MsgContent -> ScenConst [ctor] .
  op c[_] : List{NamedGroup} -> ScenConst [ctor] .
  op c[_] : List{ProtocolVersion} -> ScenConst [ctor] .
  op c[_] : List{CipherSuite} -> ScenConst [ctor] .
  op c[_] : HandshakeType -> ScenConst [ctor] .
  op c[_] : MsgSize -> ScenConst [ctor] .
  op c[_] : CurveType -> ScenConst [ctor] .
  op c[_] : List{CompressionMethod} -> ScenConst [ctor] .
  op c[_] : AlertLevel -> ScenConst [ctor] .
  op c[_] : AlertDescription -> ScenConst [ctor] .
  op c[_] : List{PreSharedKeyExchangeMode} -> ScenConst [ctor] .
  op p[_,_] : String Nat -> ScenConst [ctor] . --- Path
  op c[_] : List{SignatureAlgorithm} -> ScenConst [ctor] .
  op c[_] : TicketId -> ScenConst [ctor] .
  op c[_] : List{CertificateType} -> ScenConst [ctor] .
  op c[_] : List{TId} -> ScenConst [ctor] .
  op c[_] : List{KeyShareEntry} -> ScenConst [ctor] .
  op c[_] : Bool -> ScenConst [ctor] .
  op c[_] : KeyUpdateRequest -> ScenConst [ctor] .

  --- Initial configuration 
  ops accept connect close : TId -> ScenStmt [ctor] .
  op getCertificate : ScenExp -> ScenExp [ctor] .
  op cert-path : -> ScenConst [ctor] .
  op genCertificatePrivateKey : ScenExp -> ScenExp [ctor] .
  op prvkey-path : -> ScenConst [ctor] .
  op setUpPSK : TId ScenExp -> ScenStmt [ctor] .

  --- Initialize operations
  op initializePV : ScenConst -> ScenStmt [ctor] .
  op initializeCS : ScenConst -> ScenStmt [ctor] .
  op initializeCM : ScenConst -> ScenStmt [ctor] .
  op initializeNC : ScenConst -> ScenStmt [ctor] .
  op initializeNG : ScenConst -> ScenStmt [ctor] .
  op initializeSV : ScenConst -> ScenStmt [ctor] .
  op initializeSA : ScenConst -> ScenStmt [ctor] .
  op initializeEM : ScenConst -> ScenStmt [ctor] .
  op initializeKS : ScenConst -> ScenStmt [ctor] .
  op initializeNST : ScenConst -> ScenStmt [ctor] .
  op initializeCR : ScenConst -> ScenStmt [ctor] .
  op initializeED : ScenConst -> ScenStmt [ctor] .
  op initializePCA : ScenConst -> ScenStmt [ctor] .
  op initializeKU : ScenConst -> ScenStmt [ctor] .

  --- Network communication
  op recv : TId -> ScenExp [ctor] .
  op send : TId ScenVar -> ScenStmt [ctor] .

  --- Assertion
  op assertEqual : ScenExp ScenExp -> ScenStmt [ctor] .
  op assertTrue : ScenExp -> ScenStmt [ctor] .

  --- Crypto computation
  op encrypt : TId ScenExp -> ScenExp [ctor] .
  op decrypt : TId ScenExp -> ScenExp [ctor] .

  --- Field operation
  op getContentType : ScenVar -> ScenExp [ctor] .
  op getRecordVersion : ScenVar -> ScenExp [ctor] .
  op getHandshakeMessageType : ScenVar -> ScenExp [ctor] .
  op getProtocolVersion : ScenVar -> ScenExp [ctor] .
  op getProtocolVersion : ScenVar -> ScenExp [ctor] .
  op getCipherSuite : ScenVar Nat -> ScenExp [ctor] .
  op getCipherSuites : ScenVar -> ScenExp [ctor] .
  op getCompressionMethod : ScenVar Nat -> ScenExp [ctor] .
  op getCompressionMethods : ScenVar -> ScenExp [ctor] .
  op getSessionId : ScenVar -> ScenExp [ctor] .
  op getAlertLevel : ScenVar -> ScenExp [ctor] .
  op getAlertDescription : ScenVar -> ScenExp [ctor] .
  op getSupportedVersion : ScenVar Nat -> ScenExp [ctor] .
  op getSupportedVersions : ScenVar -> ScenExp [ctor] .
  op getAuthenticationAlgorithm : ScenVar Nat -> ScenExp [ctor] .
  op getAuthenticationAlgorithms : ScenVar -> ScenExp [ctor] .
  op getKeyShareNamedGroup : ScenExp -> ScenExp [ctor] .
  op getNamedGroup : ScenVar Nat -> ScenExp [ctor] .
  op getNamedGroups : ScenVar -> ScenExp [ctor] .
  op getKeyShareEntry : ScenVar Nat -> ScenExp [ctor] .
  op getKeyShareEntries : ScenVar -> ScenExp [ctor] .
  op getRandom : ScenVar -> ScenExp [ctor] .
  op getSessionId : ScenVar -> ScenExp [ctor] .
  op getPublicKeyFromCertificate : ScenExp -> ScenExp [ctor] .
  op getRSAPreMasterSecret : ScenVar ScenVar TId -> ScenExp [ctor] .
  op calculateMasterSecret : TId TId ScenVar ScenVar ScenVar -> ScenExp [ctor] .
  op getCertificate : ScenVar -> ScenExp [ctor] .
  op getTicket : ScenVar -> ScenExp [ctor] .
  op getPskExchangeMode : ScenVar Nat -> ScenExp [ctor] .
  op getCertificateContext : ScenVar -> ScenExp [ctor] .

  --- Build message
  --- Arguments: ProtocolVersion, CipherSuites, Random, SessionId, Compression
  op buildServerHello : TId ScenExp ScenExp ScenExp ScenExp ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildClientHello : TId ScenExp ScenExp ScenExp ScenExp ScenExp ScenExp ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildEncryptedExtension : TId ScenExp -> ScenExp [ctor] .


  op buildCertificate : TId ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildCertificate : TId ScenExp ScenExp ScenExp ScenExp ScenExp -> ScenExp [ctor] .

  op buildClientKeyExchange : TId ScenExp -> ScenExp [ctor] .
  op buildClientKeyExchange : TId ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildECDHClientKeyExchange : TId ScenExp ScenExp -> ScenExp [ctor] .
  op buildECDHEServerKeyExchange : TId ScenExp ScenExp ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildServerKeyExchange : TId ScenExp -> ScenExp [ctor] .
  op buildServerHelloDone : TId ScenExp -> ScenExp [ctor] .
  op buildEndOfEarlyData() : -> ScenExp [ctor] .
  op buildNewSessionTicket : TId ScenExp -> ScenExp [ctor] .
  op buildKeyUpdateRequest : TId ScenExp ScenExp -> ScenExp [ctor] .
  --- Arguments: public key, preMasterSecret
  op buildInvalidPaddingRSAClientKeyExchange : ScenExp ScenExp -> ScenExp [ctor] .
  op buildCertificateRequest : TId ScenExp ScenExp ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildCertificateRequest : TId ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildCertificateVerify : TId ScenExp ScenExp -> ScenExp [ctor] .
  op buildCertificateVerify : TId ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildFinished : TId ScenExp ScenExp -> ScenExp [ctor] .
  op buildChangeCipherSpec : TId -> ScenExp [ctor] .
  --- Arguments: AlertLevel AlertDescription 
  op buildAlert : TId ScenExp ScenExp -> ScenExp [ctor] .
  --- Arguments: ContentType, ProtocolVersion, Record Length, Message
  op buildRecord : TId ScenExp ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  --- Arguments : NamedGroup, Opaque(Key)
  op buildKeyShareEntry : ScenExp ScenExp -> ScenExp [ctor] .

  op buildClientKeyUpdateRequest : TId ScenExp ScenExp ScenExp -> ScenExp [ctor] .
  op buildServerKeyUpdateRequest : TId ScenExp ScenExp ScenExp -> ScenExp [ctor] .

  --- Add message contents 
  op addEarlyDataExtension : TId ScenExp ScenExp -> ScenStmt [ctor] .
  op addPostHandshakeAuthExtension : TId ScenExp ScenExp -> ScenStmt [ctor] .
  op addKeyShareExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addHRRKeyShareExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addSupportedVersionExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addSupportedGroupExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addSignatureAlgorithmExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addSignatureAlgorithmCertExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addSupportedAuthenticationAlgorithmExtension : TId ScenExp ScenExp -> ScenStmt [ctor] .
  op addNamedCurvesExtension : TId ScenExp ScenExp -> ScenStmt [ctor] .
  op addPSKExchangeModeExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addCHPreSharedKeyExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op setCHPreSharedKeyBinder : TId ScenExp ScenExp -> ScenStmt [ctor] .
  op addSHPreSharedKeyExtension : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .
  op addRenegotiationInfoExtension : TId ScenExp ScenExp  -> ScenStmt [ctor] .
  op addCKSExtension : TId ScenExp ScenExp -> ScenStmt [ctor] .
  op addExtensionLen : TId ScenExp ScenExp -> ScenStmt [ctor] .
  op addHandshakeLen : TId ScenExp ScenExp -> ScenStmt [ctor] .

  op addKeyShareEntry : TId ScenExp ScenExp ScenExp -> ScenStmt [ctor] .


  op buildEmptyKeyShareEntryList() : -> ScenExp [ctor] .

  --- Node configuration 
  op updateContext : TId ScenExp Bool -> ScenStmt [ctor] .


  op generateRandom : Nonce? -> ScenExp [ctor] .
  op generatePreMasterSecret : ScenExp ScenExp -> ScenExp [ctor] .
  op generateTicket : ScenExp -> ScenExp [ctor] .
  op generateTicket : TId ScenExp -> ScenExp [ctor] .
  op generatePSK : TId ScenExp -> ScenExp [ctor] .
  op generateEmptyCertificate() : -> ScenExp [ctor] .
  op generateVerifyData : TId -> ScenExp [ctor] .

  op check : TId ScenExp -> ScenStmt [ctor] .


  sort TId? .
  subsort TId < TId? .
  op noId : -> TId? [ctor] .
endfm

fmod SCENARIO-GENERATOR is 
  protecting LIST{FormalAction} .
  protecting INTERNAL-FORMAL-ACTION .
  protecting SCENARIO .
  protecting MAP{TLSTerm,Nat} .

  op gen : List{FormalAction} -> Scen .
  op gen : List{FormalAction} Map{TLSTerm,Nat} Nat -> Scen .

  var AFL : List{FormalAction} .
  var MAP : Map{TLSTerm,Nat} .
  var N : Nat .
  var ACT : FormalAction .

  op addSameRecord : MsgContent MsgContent -> MsgContent .

  eq gen(AFL) = gen(AFL, empty, 0) .
  eq gen(nil, MAP, N) = nil .
  eq gen(skipF(ACT) AFL, MAP, N) = gen(AFL, MAP, N) .
endfm

fmod PROCESS-MESSAGE-GENERATOR is
  protecting SCENARIO .
  protecting SCENARIO-GENERATOR .

  vars MC MC' MC'' : MsgContent .
  var N : Nat .
  var CS : CipherSuite .
  var CSL : List{CipherSuite} .
  var CM : CompressionMethod .
  var CML : List{CompressionMethod} .
  var AL : AlertLevel .
  var CT : ContentType .
  var PV : ProtocolVersion .
  var PVL : List{ProtocolVersion} .
  var HTY : HandshakeType .
  var DS : AlertDescription .
  var NONCE : Nonce .
  var SID? NONCE? : Nonce? .
  var EXT : Extension .
  var SC : SignatureAlgorithm .
  var SCL : List{SignatureAlgorithm} .
  var KS : KeyShareEntry .
  var KSL : List{KeyShareEntry} .
  var NG : NamedGroup .
  var NGL : List{NamedGroup} .
  var COMP : DHComputation .
  var TI : TId .
  var AFL : List{FormalAction} .
  var MAP : Map{TLSTerm,Nat} .
  var EML : List{PreSharedKeyExchangeMode} .
  var EM : PreSharedKeyExchangeMode .

  eq gen(processMessage(TI, MC) AFL, MAP, N)
   = processMessage(MC, v[MAP[t[MC]]]) ; 
     gen(learnMessage(TI, MC, MC) AFL, MAP, N) .

  op processMessage : MsgContent ScenVar -> ScenStmt .
  eq processMessage(contentType(CT) MC, v[N])
   = assertEqual(c[CT], getContentType(v[N])) ; processMessage(MC, v[N]) .

  --- Do not strictly validate record-layer version for alert processing:
  --- - TLS 1.2 ClientHello may use {03,XX} for compatibility.
  --- - TLS 1.3 legacy_record_version must be ignored by receivers.
  eq processMessage(version(PV) MC, v[N])
   = processMessage(MC, v[N]) .

  eq processMessage(handshakeType(HTY) MC, v[N])
   = assertEqual(c[HTY], getHandshakeMessageType(v[N])) ; processMessage(MC, v[N]) .

  eq processMessage(protocol(PV) MC, v[N])
   = assertEqual(c[PV], getProtocolVersion(v[N])) ; processMessage(MC, v[N]) .

  eq processMessage(cipherSuites(CSL CS) MC , v[N])
   = assertEqual(c[CS], getCipherSuite(v[N], size(CSL CS))) ; processMessage(cipherSuites(CSL) MC, v[N]) .

  eq processMessage(cipherSuites(nil) MC, v[N])
   = processMessage(MC, v[N]) .

  eq processMessage(compressions(CML CM) MC, v[N])
   = assertEqual(c[CM], getCompressionMethod(v[N], size(CML CM))) ; processMessage(compressions(CML) MC, v[N]) .

  eq processMessage(compressions(nil) MC, v[N])
   = processMessage(MC, v[N]) .

  eq processMessage(alertLev(AL) MC, v[N])
   = assertEqual(c[AL], getAlertLevel(v[N])) ; processMessage(MC, v[N]) .

  eq processMessage(alertDesc(DS) MC, v[N])
   = assertEqual(c[DS], getAlertDescription(v[N])) ; processMessage(MC, v[N]) .

  eq processMessage(extensions(supported-versions(PVL PV) EXT) MC, v[N])
   = assertEqual(c[PV], getSupportedVersion(v[N], size(PVL PV))) ; processMessage(extensions(supported-versions(PVL) EXT) MC, v[N]) .

  eq processMessage(extensions(supported-versions(nil) EXT) MC, v[N])
   = processMessage(extensions(EXT) MC, v[N]) .

  eq processMessage(extensions(signature-algorithms(SCL SC) EXT) MC, v[N])
   = assertEqual(c[SC], getAuthenticationAlgorithm(v[N], size(SCL SC))) ; processMessage(extensions(signature-algorithms(SCL) EXT) MC, v[N]) .

  eq processMessage(extensions(signature-algorithms(nil) EXT) MC, v[N])
   = processMessage(extensions(EXT) MC, v[N]) .

  eq processMessage(extensions(key-shares(KSL {NG,COMP}) EXT) MC, v[N])
   = assertEqual(c[NG], getKeyShareNamedGroup(getKeyShareEntry(v[N], size(KSL {NG,COMP})))) ; processMessage(extensions(key-shares(KSL) EXT) MC, v[N]) .

  eq processMessage(extensions(key-shares((nil).List{KeyShareEntry}) EXT) MC, v[N])
   = processMessage(extensions(EXT) MC, v[N]) .

  eq processMessage(extensions(supported-groups(NGL NG) EXT) MC, v[N])
   = assertEqual(c[NG], getNamedGroup(v[N], size(NGL NG))) ; processMessage(extensions(supported-groups(NGL) EXT) MC, v[N]) .

  eq processMessage(extensions(supported-groups(nil) EXT) MC, v[N])
   = processMessage(extensions(EXT) MC, v[N]) . 

  eq processMessage(extensions(psk-key-exchange-mode(EML EM) EXT) MC, v[N])
   = assertEqual(c[EM], getPskExchangeMode(v[N], size(EML EM))) ; processMessage(extensions(psk-key-exchange-mode(EML) EXT) MC, v[N]) .

  eq processMessage(extensions(psk-key-exchange-mode(nil) EXT) MC, v[N])
   = processMessage(extensions(EXT) MC, v[N]) . 

  eq processMessage(extensions(empty) MC, v[N]) = processMessage(MC, v[N]) .

  eq processMessage(MC, v[N]) = nil [owise] .

  eq gen(learnMessage(TI, MC random(NONCE), MC') AFL, MAP, N)
   = (v[N] := getRandom(v[MAP[t[MC']]])) ; gen(learnMessage(TI, MC, MC') AFL, insert(t[NONCE], N, MAP), s N) .

  eq gen(learnMessage(TI, MC sessionId(SID?), MC') AFL, MAP, N)
   = (v[N] := getSessionId(v[MAP[t[MC']]])) ; gen(learnMessage(TI, MC, MC') AFL, insert(t[SID?], N, MAP), s N) .

  eq gen(learnMessage(TI, MC certificate-request-context(NONCE?), MC') AFL, MAP, N)
   = (v[N] := getCertificateContext(v[MAP[t[MC']]])) ; gen(learnMessage(TI, MC, MC') AFL, insert(t[NONCE?], N, MAP), s N) .

  eq gen(learnMessage(TI, MC, MC') AFL, MAP, N)
   = gen(AFL, MAP, N) [owise] .  
endfm

fmod FORMAL-INITIALIZE-SCENARIO is
  protecting SCENARIO-GENERATOR .

  var TI : TId .
  var AFL : List{FormalAction} .
  var N : Nat .
  var MAP : Map{TLSTerm,Nat} .

  var PV : ProtocolVersion .
  var PVL : List{ProtocolVersion} .
  var CSL : List{CipherSuite} .
  var CML : List{CompressionMethod} .
  var NGL : List{NamedGroup} .
  var SAL : List{SignatureAlgorithm} .
  var EML : List{PreSharedKeyExchangeMode} .
  var B : Bool .

  --- Initialize operations
  eq gen(initializePV(TI, PV) AFL, MAP, N) = initializePV(c[PV]) ; gen(AFL, MAP, N) . 
  eq gen(initializeCS(TI, CSL) AFL, MAP, N) = initializeCS(c[CSL]) ; gen(AFL, MAP, N) .
  eq gen(initializeCM(TI, CML) AFL, MAP, N) = initializeCM(c[CML]) ; gen(AFL, MAP, N) . 
  eq gen(initializeNC(TI, NGL) AFL, MAP, N) = initializeNG(c[NGL]) ; gen(AFL, MAP, N) .
  eq gen(initializeNG(TI, NGL) AFL, MAP, N) = initializeNG(c[NGL]) ; gen(AFL, MAP, N) .
  eq gen(initializeSV(TI, PVL) AFL, MAP, N) = initializeSV(c[PVL]) ; gen(AFL, MAP, N) .
  eq gen(initializeSA(TI, SAL) AFL, MAP, N) = initializeSA(c[SAL]) ; gen(AFL, MAP, N) .
  eq gen(initializeEM(TI, EML) AFL, MAP, N) = initializeEM(c[EML]) ; gen(AFL, MAP, N) .
  eq gen(initializeKS(TI, NGL) AFL, MAP, N) = initializeKS(c[NGL]) ; gen(AFL, MAP, N) .
  eq gen(initializeNST(TI, B) AFL, MAP, N) = initializeNST(c[B]) ; gen(AFL, MAP, N) . 
  eq gen(initializeCR(TI, B) AFL, MAP, N) = initializeCR(c[B]) ; gen(AFL, MAP, N) .
  eq gen(initializeED(TI, B) AFL, MAP, N) = initializeED(c[B]) ; gen(AFL, MAP, N) .
  eq gen(initializePCA(TI, B) AFL, MAP, N) = initializePCA(c[B]) ; gen(AFL, MAP, N) .
  eq gen(initializeKU(TI, B) AFL, MAP, N) = initializeKU(c[B]) ; gen(AFL, MAP, N) .
endfm

fmod FORMAL-SCENARIO-GENERATOR is
  protecting SCENARIO-GENERATOR .
  protecting PROCESS-MESSAGE-GENERATOR .
  protecting FORMAL-INITIALIZE-SCENARIO .

  vars T1 T2 : TId .
  vars SRANDOM CRANDOM NONCE : Nonce .

  var TI : TId .
  var CERT : Certificate .
  var AFL : List{FormalAction} .
  var N : Nat .
  var MAP : Map{TLSTerm,Nat} .
  vars MC MC' MC'' EMC : MsgContent .
  var KEY : Key .
  var PV : ProtocolVersion . 
  var DESC : AlertDescription .
  vars SID? NONCE? : Nonce? .
  var PSK : Nonce .

  --- Initial configuration
  eq gen(acceptF(TI) AFL, MAP, N)
   = accept(TI) ; gen(AFL, MAP, N) .

  eq gen(connectF(TI) AFL, MAP, N)
   = connect(TI) ; gen(AFL, MAP, N) .

  eq gen(closeF(TI) AFL, MAP, N)
   = close(TI) ; gen(AFL, MAP, N) .


  eq gen(genCertificatePrivateKey(KEY) AFL, MAP, N)
   = (v[N] := genCertificatePrivateKey(prvkey-path)) ; gen(AFL, insert(t[KEY], N, MAP), s N) .

  eq gen(setUpPSK(TI, PSK) AFL, MAP, N)
   = (setUpPSK(TI, v[MAP[t[PSK]]])) ; gen(AFL, MAP, N) .


  --- Network communication
 ceq gen(send(T2,MC) AFL, MAP, N)
   = (send(T2,v[MAP[t[MC]]])) ; gen(AFL, MAP, N) 
  if $hasMapping(MAP,t[MC]) .

 ceq gen(send(T2,MC) AFL, MAP, N)
   = (send(T2,v[MAP[t[MC]]])) ; gen(AFL, MAP, N) 
  if not $hasMapping(MAP,t[MC]) .

  eq gen(recv(T2,MC) AFL, MAP, N)
   = (v[N] := recv(T2)) ; updateContext(T2, v[N], false) ; gen(AFL, insert(t[MC], N, MAP), s N) .

  --- TLS 1.2 operation
  eq gen(buildClientHelloV2(MC, EMC, TI) AFL, MAP, N)
   = gen(buildRandom(MC) buildSessionId(MC) buildClientHelloBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

  eq gen(buildServerHelloV2(MC, EMC, TI) AFL, MAP, N)
   = gen(buildRandom(MC) buildSessionId(MC) buildServerHelloBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

  eq gen(buildClientCertificateV2(MC, EMC, TI) AFL, MAP, N)
   = gen(getCertificate(MC) buildCertificateBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

  eq gen(buildServerCertificateV2(MC, EMC, TI) AFL, MAP, N)
   = gen(getCertificate(MC) buildCertificateBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

  eq gen(buildCertificateRequestV2(MC, EMC, TI) AFL, MAP, N)
   = gen(buildCertificateRequestBodyV2(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

  eq gen(buildServerHelloDoneV2(MC, EMC, TI) AFL, MAP, N)
   = gen(buildServerHelloDoneBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

  eq gen(buildServerKeyExchangeV2(MC, EMC, TI) AFL, MAP, N)
   = gen(buildServerKeyExchangeBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

  eq gen(buildClientKeyExchangeV2(MC, EMC, TI) AFL, MAP, N)
   = gen(buildClientKeyExchangeBody(TI, addSameRecord(EMC, MC)) buildRecord(TI, addSameRecord(EMC, MC)) updateContext(TI, addSameRecord(EMC, MC), true) encryptOrPlain(addSameRecord(EMC, MC), EMC, TI)  send(TI, EMC) AFL, MAP, N) .

