fmod ASYM-KEY-TYPE is

  sort AsymKeyType .

  op dss : -> AsymKeyType [ctor] .
  op ecdsa : -> AsymKeyType [ctor] .
  op eddsa : -> AsymKeyType [ctor] .
  op dsa : -> AsymKeyType [ctor] .
  op rsa : -> AsymKeyType [ctor] .
  ops ed25519 ed448 : -> AsymKeyType [ctor] .
endfm

fmod SYM-KEY-TYPE is

  sort SymKeyType .

  op aes128 : -> SymKeyType [ctor] .
  op aes256 : -> SymKeyType [ctor] .
  op des : -> SymKeyType [ctor] .
  op rc4 : -> SymKeyType [ctor] .
endfm

fmod CURVE-TYPE is

  sort CurveType .

  op namedcurve : -> CurveType [ctor] .
  op unknowncurve : -> CurveType [ctor] .
endfm


fmod NAMED-CURVE is

  sort NamedCurve .

  op secp160k1 : -> NamedCurve [ctor] .
  op secp160r1 : -> NamedCurve [ctor] .
  op secp160r2 : -> NamedCurve [ctor] .
  op secp192k1 : -> NamedCurve [ctor] .
  op secp192r1 : -> NamedCurve [ctor] .
  op secp224r1 : -> NamedCurve [ctor] .
  op secp224k1 : -> NamedCurve [ctor] .
  op secp256r1 : -> NamedCurve [ctor] .
  op secp256k1 : -> NamedCurve [ctor] .
  op secp384r1 : -> NamedCurve [ctor] .
  op secp521r1 : -> NamedCurve [ctor] .
endfm

fmod FINITE-FIELD is

  sort FiniteField .

  op ffdhe2048 : -> FiniteField [ctor] .
  op ffdhe3072 : -> FiniteField [ctor] .
  op ffdhe4096 : -> FiniteField [ctor] .
  op ffdhe6144 : -> FiniteField [ctor] .
  op ffdhe8192 : -> FiniteField [ctor] .
endfm

fmod NAMED-GROUP is
  including NAMED-CURVE .
  including FINITE-FIELD .

  sort NamedGroup .
  subsort NamedCurve FiniteField < NamedGroup .
endfm

view NamedGroup from TRIV to NAMED-GROUP is
  sort Elt to NamedGroup .
endv

--- [Note] The KeyExchangeAlgorithm is not the actual cipher used for
--- encryption or signature; it 'denotes' the method used to derive the symmetric key.
fmod CIPHER-KEYEXCHANGE is

  sort KeyExchangeAlgorithm .

  op psk : -> KeyExchangeAlgorithm [ctor] .
  op dhepsk : -> KeyExchangeAlgorithm [ctor] .
  op ecdhepsk : -> KeyExchangeAlgorithm [ctor] .
  op dh : -> KeyExchangeAlgorithm [ctor] .
  op ecdh : -> KeyExchangeAlgorithm [ctor] .
  op dhe : -> KeyExchangeAlgorithm [ctor] .
  op ecdhe : -> KeyExchangeAlgorithm [ctor] .
  op rsaKE : -> KeyExchangeAlgorithm [ctor] .
endfm

--- [Note] In the case of RSA, it refers to the RSA-PKCS used for authentication
fmod CIPHER-AUTHENTICATION is
  including ASYM-KEY-TYPE .

  sort AuthenticationAlgorithm .
  subsort AsymKeyType < AuthenticationAlgorithm .

  op anon : -> AuthenticationAlgorithm [ctor] .
endfm

fmod CIPHER-RECORD-ENCRYPTION is
  including SYM-KEY-TYPE .

  sort EncryptionAlgorithm .
  subsort SymKeyType < EncryptionAlgorithm .

  op nullE : -> EncryptionAlgorithm .
endfm

fmod BLOCK-CIPHER-MODE is

  sort BlockCipherMode .

  op nullB : -> BlockCipherMode [ctor] .
  op cbc : -> BlockCipherMode [ctor] .
  op ccm : -> BlockCipherMode [ctor] .
  op gcm : -> BlockCipherMode [ctor] .
  op ccm8 : -> BlockCipherMode [ctor] .
endfm

fmod CIPHER-HASH is

  sort HashAlgorithm .

  op md5 : -> HashAlgorithm [ctor] .
  op sha : -> HashAlgorithm [ctor] .
  op sha224 : -> HashAlgorithm [ctor] .
  op sha384 : -> HashAlgorithm [ctor] .
  op sha256 : -> HashAlgorithm [ctor] .
  op sha512 : -> HashAlgorithm [ctor] .
  op intrinsic : -> HashAlgorithm [ctor] .
endfm


