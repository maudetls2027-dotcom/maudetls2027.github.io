view CipherSuite from TRIV to CIPHER-SUITE is
  sort Elt to CipherSuite .
endv

fmod CIPHER-SUITE-OPERATION is
  protecting NAT .
  protecting CIPHER-SUITE .
  protecting CIPHER-KEYEXCHANGE .
  protecting CIPHER-AUTHENTICATION .
  protecting CIPHER-RECORD-ENCRYPTION .
  protecting BLOCK-CIPHER-MODE .
  protecting CIPHER-HASH .
  
  op keyC  : CipherSuite -> KeyExchangeAlgorithm .
  op authC : CipherSuite -> AuthenticationAlgorithm .
  op encrC : CipherSuite -> EncryptionAlgorithm .
  op modeC : CipherSuite -> BlockCipherMode .
  op hashC : CipherSuite -> HashAlgorithm .
  op prfC : CipherSuite -> HashAlgorithm .
  op verifyDataLengthC : CipherSuite -> Nat .
  op validVerifyDataLengthC : CipherSuite -> Bool .
  var CS : CipherSuite .

  eq prfC(CS) = hashC(CS) .
  eq verifyDataLengthC(CS) = 12 [owise] .
  eq validVerifyDataLengthC(CS) = verifyDataLengthC(CS) >= 12 .

  -----------------------------
  --- KeyExchange Algorithm ---
  -----------------------------
  eq keyC(TLS-DHE-RSA-WITH-3DES-EDE-CBC-SHA) = dhe .
  eq keyC(TLS-DHE-RSA-WITH-AES-256-CBC-SHA) = dhe .
  eq keyC(TLS-DHE-RSA-WITH-AES-128-CBC-SHA) = dhe .
  eq keyC(TLS-DH-anon-WITH-AES-128-CBC-SHA) = dh .
  eq keyC(TLS-RSA-WITH-AES-256-CBC-SHA) = rsaKE .
  eq keyC(TLS-RSA-WITH-AES-128-CBC-SHA) = rsaKE .
  eq keyC(TLS-RSA-WITH-NULL-MD5) = rsaKE .
  eq keyC(TLS-RSA-WITH-NULL-SHA) = rsaKE .
  eq keyC(TLS-PSK-WITH-AES-256-CBC-SHA) = psk .
  eq keyC(TLS-PSK-WITH-AES-128-CBC-SHA256) = psk .
  eq keyC(TLS-PSK-WITH-AES-256-CBC-SHA384) = psk .
  eq keyC(TLS-PSK-WITH-AES-128-CBC-SHA) = psk .
  eq keyC(TLS-PSK-WITH-NULL-SHA256) = psk .
  eq keyC(TLS-PSK-WITH-NULL-SHA384) = psk .
  eq keyC(TLS-PSK-WITH-NULL-SHA) = psk .

  eq keyC(TLS-ECDHE-RSA-WITH-AES-256-CBC-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-RSA-WITH-AES-128-CBC-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-256-CBC-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-128-CBC-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-RSA-WITH-RC4-128-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-RC4-128-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-RSA-WITH-3DES-EDE-CBC-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-3DES-EDE-CBC-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-RSA-WITH-AES-128-CBC-SHA256) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-128-CBC-SHA256) = ecdhe .
  eq keyC(TLS-ECDHE-RSA-WITH-AES-256-CBC-SHA384) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-256-CBC-SHA384) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-NULL-SHA) = ecdhe .
  eq keyC(TLS-ECDHE-PSK-WITH-NULL-SHA256) = ecdhepsk .
  eq keyC(TLS-ECDHE-PSK-WITH-AES-128-CBC-SHA256) = ecdhepsk .

  eq keyC(TLS-ECDH-RSA-WITH-AES-256-CBC-SHA) = ecdh .
  eq keyC(TLS-ECDH-RSA-WITH-AES-128-CBC-SHA) = ecdh .
  eq keyC(TLS-ECDH-ECDSA-WITH-AES-256-CBC-SHA) = ecdh .
  eq keyC(TLS-ECDH-ECDSA-WITH-AES-128-CBC-SHA) = ecdh .
  eq keyC(TLS-ECDH-RSA-WITH-RC4-128-SHA) = ecdh .
  eq keyC(TLS-ECDH-ECDSA-WITH-RC4-128-SHA) = ecdh .
  eq keyC(TLS-ECDH-RSA-WITH-3DES-EDE-CBC-SHA) = ecdh .
  eq keyC(TLS-ECDH-ECDSA-WITH-3DES-EDE-CBC-SHA) = ecdh .
  eq keyC(TLS-ECDH-RSA-WITH-AES-128-CBC-SHA256) = ecdh .
  eq keyC(TLS-ECDH-ECDSA-WITH-AES-128-CBC-SHA256) = ecdh .
  eq keyC(TLS-ECDH-RSA-WITH-AES-256-CBC-SHA384) = ecdh .
  eq keyC(TLS-ECDH-ECDSA-WITH-AES-256-CBC-SHA384) = ecdh .

  eq keyC(TLS-DHE-RSA-WITH-AES-256-CBC-SHA256) = dhe .
  eq keyC(TLS-DHE-RSA-WITH-AES-128-CBC-SHA256) = dhe .
  eq keyC(TLS-RSA-WITH-AES-256-CBC-SHA256) = rsaKE .
  eq keyC(TLS-RSA-WITH-AES-128-CBC-SHA256) = rsaKE .
  eq keyC(TLS-RSA-WITH-NULL-SHA256) = rsaKE .
  eq keyC(TLS-DHE-PSK-WITH-AES-128-CBC-SHA256) = dhepsk .
  eq keyC(TLS-DHE-PSK-WITH-NULL-SHA256) = dhepsk .

  eq keyC(TLS-DHE-PSK-WITH-AES-256-CBC-SHA384) = dhepsk .
  eq keyC(TLS-DHE-PSK-WITH-NULL-SHA384) = dhepsk .

  eq keyC(TLS-RSA-WITH-AES-128-GCM-SHA256) = rsaKE .
  eq keyC(TLS-RSA-WITH-AES-256-GCM-SHA384) = rsaKE .
  eq keyC(TLS-DHE-RSA-WITH-AES-128-GCM-SHA256) = dhe .
  eq keyC(TLS-DHE-RSA-WITH-AES-256-GCM-SHA384) = dhe .
  eq keyC(TLS-DH-anon-WITH-AES-256-GCM-SHA384) = dh .
  eq keyC(TLS-PSK-WITH-AES-128-GCM-SHA256) = psk .
  eq keyC(TLS-PSK-WITH-AES-256-GCM-SHA384) = psk .
  eq keyC(TLS-DHE-PSK-WITH-AES-128-GCM-SHA256) = dhepsk .
  eq keyC(TLS-DHE-PSK-WITH-AES-256-GCM-SHA384) = dhepsk .

  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-128-GCM-SHA256) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-256-GCM-SHA384) = ecdhe .
  eq keyC(TLS-ECDH-ECDSA-WITH-AES-128-GCM-SHA256) = ecdh .
  eq keyC(TLS-ECDH-ECDSA-WITH-AES-256-GCM-SHA384) = ecdh .
  eq keyC(TLS-ECDHE-RSA-WITH-AES-128-GCM-SHA256) = ecdhe .
  eq keyC(TLS-ECDHE-RSA-WITH-AES-256-GCM-SHA384) = ecdhe .
  eq keyC(TLS-ECDH-RSA-WITH-AES-128-GCM-SHA256) = ecdh .
  eq keyC(TLS-ECDH-RSA-WITH-AES-256-GCM-SHA384) = ecdh .

  eq keyC(TLS-RSA-WITH-AES-128-CCM-8) = rsaKE .
  eq keyC(TLS-RSA-WITH-AES-256-CCM-8) = rsaKE .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-128-CCM) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-128-CCM-8) = ecdhe .
  eq keyC(TLS-ECDHE-ECDSA-WITH-AES-256-CCM-8) = ecdhe .
  eq keyC(TLS-PSK-WITH-AES-128-CCM) = psk .
  eq keyC(TLS-PSK-WITH-AES-256-CCM) = psk .
  eq keyC(TLS-PSK-WITH-AES-128-CCM-8) = psk .
  eq keyC(TLS-PSK-WITH-AES-256-CCM-8) = psk .
  eq keyC(TLS-DHE-PSK-WITH-AES-128-CCM) = dhepsk .
  eq keyC(TLS-DHE-PSK-WITH-AES-256-CCM) = dhepsk .


  --------------------------------
  --- Authentication Algorithm ---
  --------------------------------
  eq authC(TLS-DHE-RSA-WITH-3DES-EDE-CBC-SHA) = rsa .
  eq authC(TLS-DHE-RSA-WITH-AES-256-CBC-SHA) = rsa .
  eq authC(TLS-DHE-RSA-WITH-AES-128-CBC-SHA) = rsa .
  eq authC(TLS-DH-anon-WITH-AES-128-CBC-SHA) = anon .
  eq authC(TLS-RSA-WITH-AES-256-CBC-SHA) = rsa .
  eq authC(TLS-RSA-WITH-AES-128-CBC-SHA) = rsa .
  eq authC(TLS-RSA-WITH-NULL-MD5) = rsa .
  eq authC(TLS-RSA-WITH-NULL-SHA) = rsa .
  eq authC(TLS-PSK-WITH-AES-256-CBC-SHA) = anon .
  eq authC(TLS-PSK-WITH-AES-128-CBC-SHA256) = anon .
  eq authC(TLS-PSK-WITH-AES-256-CBC-SHA384) = anon .
  eq authC(TLS-PSK-WITH-AES-128-CBC-SHA) = anon .
  eq authC(TLS-PSK-WITH-NULL-SHA256) = anon .
  eq authC(TLS-PSK-WITH-NULL-SHA384) = anon .
  eq authC(TLS-PSK-WITH-NULL-SHA) = anon .

  eq authC(TLS-ECDHE-RSA-WITH-AES-256-CBC-SHA) = rsa .
  eq authC(TLS-ECDHE-RSA-WITH-AES-128-CBC-SHA) = rsa .
  eq authC(TLS-ECDHE-ECDSA-WITH-AES-256-CBC-SHA) = ecdsa .
  eq authC(TLS-ECDHE-ECDSA-WITH-AES-128-CBC-SHA) = ecdsa .
  eq authC(TLS-ECDHE-RSA-WITH-RC4-128-SHA) = rsa .
  eq authC(TLS-ECDHE-ECDSA-WITH-RC4-128-SHA) = ecdsa .
  eq authC(TLS-ECDHE-RSA-WITH-3DES-EDE-CBC-SHA) = rsa .
  eq authC(TLS-ECDHE-ECDSA-WITH-3DES-EDE-CBC-SHA) = ecdsa .
  eq authC(TLS-ECDHE-RSA-WITH-AES-128-CBC-SHA256) = rsa .
  eq authC(TLS-ECDHE-ECDSA-WITH-AES-128-CBC-SHA256) = ecdsa .
  eq authC(TLS-ECDHE-RSA-WITH-AES-256-CBC-SHA384) = rsa .
  eq authC(TLS-ECDHE-ECDSA-WITH-AES-256-CBC-SHA384) = ecdsa .
  eq authC(TLS-ECDHE-ECDSA-WITH-NULL-SHA) = ecdsa .
  eq authC(TLS-ECDHE-PSK-WITH-NULL-SHA256) = anon .
