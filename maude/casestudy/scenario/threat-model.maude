  eq genThreatStrat(changeContent(server-finished-v2, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(server-finished-v2), upTerm(MMS)]]] := 'buildMServerFinishedV2 [none] {empty} [none].) genThreatStrat(SACT) .

