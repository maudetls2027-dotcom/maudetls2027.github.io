  eq genThreatStrat(wrongProcess(encrypted-extension-v3) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(encrypted-extension-v3)]]] := 'processMEncryptedExtensionV3 [none] {empty} [none].) genThreatStrat(SACT) .
