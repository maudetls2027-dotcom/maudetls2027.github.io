   = (sd 'wp[['wrongProcess[upTerm(client-finished-v2)]]] := 'processMClientFinishedV2 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(wrongProcess(server-finished-v2) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(server-finished-v2)]]] := 'processMServerFinishedV2 [none] {empty} [none].) genThreatStrat(SACT) .

  eq genThreatStrat(wrongProcess(client-hello-v3) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(client-hello-v3)]]] := 'processMClientHelloV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(wrongProcess(hello-retry-request-v3) -> SACT) 
