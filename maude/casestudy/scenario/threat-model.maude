  eq filterVS(buildServerHelloV3(MC, TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC)) filterVS(AFL, OIDL) .
  eq filterVS(buildEncryptedExtensionV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildCertificateRequestV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerCertificateV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerCertificateVerifyV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerFinishedV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildNewSessionTicketV3(MC, MC', PSK, TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildPostClientAuthenticationV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerKeyUpdateRequestV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .

  eq filterVS(errorClientHelloV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientCertificateV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientCertificateVerifyV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientFinishedV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientKeyUpdateRequestV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorHelloRetryRequestV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerHelloV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorEncryptedExtensionV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorCertificateRequestV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerCertificateV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerCertificateVerifyV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerFinishedV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorPostClientAuthenticationV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerKeyUpdateRequestV3(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .


  eq filterVS(buildMClientHelloV3(MC, TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC)) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientCertificateV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientCertificateV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientCertificateVerifyV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientFinishedV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMHelloRetryRequestV3(MC, TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC)) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerHelloV3(MC, TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC)) filterVS(AFL, OIDL) .
  eq filterVS(buildMEncryptedExtensionV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMCertificateRequestV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerCertificateV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerCertificateVerifyV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerFinishedV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .

  eq filterVS(AF AFL, TI OIDL) = filterVS(AFL, OIDL) [owise] .
  eq filterVS(nil, nil) = nil .

  op unwrap : MsgContent -> MsgContent .
  eq unwrap(MC encrypt(KEY, MC')) = MC MC' .
  eq unwrap(MC) = MC [owise] .
endfm

smod RUN-SCENARIO is
  protecting GEN-THREAT-MODULE .
  protecting MODIFY-MESSAGE-AND-OBJECT .
  protecting SCENARIO-GENERATOR .
  protecting FORMAL-ACTION-FILTER .
  protecting EXECUTE-SCENARIO-STRATEGY .
  protecting LIST{ScenarioResult} .

  var CONF : Configuration .
  var CWA : ConfWithAction .
  vars SACT : ScenarioAction .
  var ACT : ScenarioActionItem .
  var MODULE : Module .
  var RESULT : Term .
  var TYPE : Type .
  vars SCEN1 SCEN2 : Scen .
  var TI : TId .
  var N : Nat .
  vars TCONF TCONF' : TLSConfiguration .
  var VISUAL : List{FormalAction} .
  var HT : HandshakeType .
  var MMS : Set{MessageModification} .

  sort ConfWithAction? .
  subsort ConfWithAction < ConfWithAction? .
  op errorConf : -> ConfWithAction? [ctor] .

  op runScenario : Configuration ScenarioAction -> List{ScenarioResult} .
  op runScenario : Configuration ScenarioAction Nat -> List{ScenarioResult} .
  eq runScenario(CONF, SACT) = runScenario(CONF, SACT, 0) .

 ceq runScenario(CONF, SACT, N) 
   = (ScenarioStart SCEN1 
      ConfigStart   SCEN2)
	 runScenario(CONF, SACT, s N)
  if MODULE := genThreatModule(SACT)
  /\ {RESULT, TYPE} := metaSrewrite(MODULE, upTerm({CONF | nil : nil}), 'execute[[upTerm(SACT)]], breadthFirst, N) 
  /\ CWA := downTerm(RESULT, errorConf) 
  /\ SCEN1 := gen(filterTT(actions(getTesterId(SACT), CWA))) 
  /\ SCEN2 := gen(filterTG(actions(getTargetId(SACT), CWA))) .

 ceq runScenario(CONF, SACT, N) = nil
  if MODULE := genThreatModule(SACT)
  /\ failure == metaSrewrite(MODULE, upTerm({CONF | nil : nil}), 'execute[[upTerm(SACT)]], breadthFirst, N) .


  op runScenarioWithVisual : Configuration ScenarioAction -> List{ScenarioResult} .
  op runScenarioWithVisual : Configuration ScenarioAction Nat -> List{ScenarioResult} .
  eq runScenarioWithVisual(CONF, SACT) = runScenarioWithVisual(CONF, SACT, 0) .

 ceq runScenarioWithVisual(CONF, SACT, N) 
   = (ScenarioStart SCEN1 
      ConfigStart   SCEN2 
	  VisualStart   VISUAL)
	 runScenarioWithVisual(CONF, SACT, s N)
  if MODULE := genThreatModule(SACT)
  /\ {RESULT, TYPE} := metaSrewrite(MODULE, upTerm({CONF | nil : nil}), 'execute[[upTerm(SACT)]], breadthFirst, N) 
  /\ CWA := downTerm(RESULT, errorConf) 
  /\ SCEN1 := gen(filterTT(actions(getTesterId(SACT), CWA))) 
  /\ SCEN2 := gen(filterTG(actions(getTargetId(SACT), CWA))) 
  /\ VISUAL := filterVS(actions((getTesterId(SACT), getTargetId(SACT)), CWA), ids(CWA)) .

 ceq runScenarioWithVisual(CONF, SACT, N) = nil
  if MODULE := genThreatModule(SACT)
  /\ failure == metaSrewrite(MODULE, upTerm({CONF | nil : nil}), 'execute[[upTerm(SACT)]], breadthFirst, N) .

  op getTesterId : ScenarioAction -> TId .
  eq getTesterId(init(TCONF tester(TI) TCONF') -> SACT) = TI .

  op getTargetId : ScenarioAction -> TId .
  eq getTargetId(init(TCONF target(TI) TCONF') -> SACT) = TI .

endsm
