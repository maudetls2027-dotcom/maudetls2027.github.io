  eq genThreatStrat(changeContent(server-certificate-verify-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(server-certificate-verify-v3), upTerm(MMS)]]] := 'buildMServerCertificateVerifyV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(server-finished-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(server-finished-v3), upTerm(MMS)]]] := 'buildMServerFinishedV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(client-certificate-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(client-certificate-v3), upTerm(MMS)]]] := 'buildMClientCertificateV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(client-certificate-verify-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(client-certificate-verify-v3), upTerm(MMS)]]] := 'buildMClientCertificateVerifyV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(client-finished-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(client-finished-v3), upTerm(MMS)]]] := 'buildMClientFinishedV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(second-client-certificate-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(second-client-certificate-v3), upTerm(MMS)]]] := 'buildMClientCertificateV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(second-client-certificate-verify-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(second-client-certificate-verify-v3), upTerm(MMS)]]] := 'buildMClientCertificateVerifyV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(second-client-finished-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(second-client-finished-v3), upTerm(MMS)]]] := 'buildMClientFinishedV3 [none] {empty} [none].) genThreatStrat(SACT) .



  eq genThreatStrat(wrongProcess(client-hello-v2) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(client-hello-v2)]]] := 'processMClientHelloV2 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(wrongProcess(server-hello-v2) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(server-hello-v2)]]] := 'processMServerHelloV2 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(wrongProcess(certificate-request-v2) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(certificate-request-v2)]]] := 'processMCertificateRequestV2 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(wrongProcess(server-certificate-v2) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(server-certificate-v2)]]] := 'processMServerCertificateV2 [none] {empty} [none].) genThreatStrat(SACT) .
