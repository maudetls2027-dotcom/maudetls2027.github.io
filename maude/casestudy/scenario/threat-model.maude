  eq genThreatStrat(wrongProcess(server-certificate-verify-v3) -> SACT) 
   = (sd 'wp[['wrongProcess[upTerm(server-certificate-verify-v3)]]] := 'processMServerCertificateVerifyV3 [none] {empty} [none].) genThreatStrat(SACT) .
