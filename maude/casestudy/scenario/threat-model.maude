   = (sd 'wp[['wrongProcess[upTerm(client-finished-v3)]]] := 'processMClientFinishedV3 [none] {empty} [none].) genThreatStrat(SACT) .

  eq genThreatStrat(reorder(TI, HTY1, HTY2) -> SACT)
   = (sd 'ord[['reorder[upTerm(TI), upTerm(HTY1), upTerm(HTY2)]]] :=  'reorderMsg [none] {empty} [none] .) genThreatStrat(SACT) .

  eq genThreatStrat(none) = none .

  op ruleTerm : Qid Qid -> Rule .
 ceq ruleTerm(MID, RID) = RULE
  if (RULE RULES) := upRls(MID, true)
  /\ checkLabel(RULE, RID) .
  
  op checkLabel : Rule Qid -> Bool .
  eq checkLabel(rl T1 => T2 [label(RID) AS] ., RID) = true .
  eq checkLabel(crl T1 => T2 if COND [label(RID) AS] ., RID) = true .
  eq checkLabel(RULE, RID) = false [owise] .

  op modify : RuleSet List{MessageModification} -> RuleSet .
  eq modify(RULE RULES, MML) = modify2(RULE, MML) modify(RULES, MML) .
  eq modify(none, MML) = none .

  op modify2 : Rule List{MessageModification} -> RuleSet .
  eq modify2(crl T1 => T2 if COND [AS] ., MM MML) 
   = crl T1 => 'modifyObj[T2, upTerm(MM)] if COND [changeLabel(AS)] .
     modify2(crl T1 => T2 if COND [AS] ., MML) .
  eq modify2(RULE, nil) = none .

  --- op modify2 : Rule List{MessageModification} -> RuleSet .
  --- eq modify2(crl T1 => T2 if COND /\ 'MC:MsgContent := T3 /\ COND' [AS] ., MM MML) 
  ---  = crl T1 => 'modifyObj[T2] if COND /\ 'MC:MsgContent := 'modifyMsg[T3, upTerm(MM)] /\ COND' [changeLabel(AS)] .
  ---    modify2(crl T1 => T2 if COND /\ 'MC:MsgContent := T3 /\ COND' [AS] ., MML) .
  --- eq modify2(RULE, nil) = none .

  op modify3 : Rule -> Rule .
  eq modify3(crl T1 => T2 if COND /\ 'not_[T3] = 'true.Bool [AS] .)
   = (crl T1 => T2 if COND [changeLabel(AS)] .) .

  op modify4 : Rule TId HandshakeType HandshakeType -> Rule .
  eq modify4(rl T1 => T2 [AS] ., TI, HTY1, HTY2)
   = (rl T1 => 'changeOrder[T2, upTerm(TI), upTerm(HTY1), upTerm(HTY2)] [changeLabel(AS)] .) .

  op changeLabel : AttrSet -> AttrSet .
  eq changeLabel(label('buildClientHelloV2) print(QL:QidList) AS) = label('buildMClientHelloV2) print('"buildMClientHelloV2") AS .
  eq changeLabel(label('buildServerHelloV2) print(QL:QidList) AS) = label('buildMServerHelloV2) print('"buildMServerHelloV2") AS .
  eq changeLabel(label('buildServerCertificateV2) print(QL:QidList) AS) = label('buildMServerCertificateV2) print('"buildMServerCertificateV2") AS .
  eq changeLabel(label('buildServerKeyExchangeV2) print(QL:QidList) AS) = label('buildMServerKeyExchangeV2) print('"buildMServerKeyExchangeV2") AS .
  eq changeLabel(label('buildCertificateRequestV2) print(QL:QidList) AS) = label('buildMCertificateRequestV2) print('"buildMCertificateRequestV2") AS .
  eq changeLabel(label('buildServerHelloDoneV2) print(QL:QidList) AS) = label('buildMServerHelloDoneV2) print('"buildMServerHelloDoneV2") AS .
  eq changeLabel(label('buildClientCertificateV2) print(QL:QidList) AS) = label('buildMClientCertificateV2) print('"buildMClientCertificateV2") AS .
  eq changeLabel(label('buildClientKeyExchangeV2) print(QL:QidList) AS) = label('buildMClientKeyExchangeV2) print('"buildMClientKeyExchangeV2") AS .
  eq changeLabel(label('buildClientCertificateVerifyV2) print(QL:QidList) AS) = label('buildMClientCertificateVerifyV2) print('"buildMClientCertificateVerifyV2") AS .
  eq changeLabel(label('buildClientChangeCipherSpecV2) print(QL:QidList) AS) = label('buildMClientChangeCipherSpecV2) print('"buildMClientChangeCipherSpecV2") AS .
  eq changeLabel(label('buildClientFinishedV2) print(QL:QidList) AS) = label('buildMClientFinishedV2) print('"buildMClientFinishedV2") AS .
  eq changeLabel(label('buildServerChangeCipherSpecV2) print(QL:QidList) AS) = label('buildMServerChangeCipherSpecV2) print('"buildMServerChangeCipherSpecV2") AS .
  eq changeLabel(label('buildServerFinishedV2) print(QL:QidList) AS) = label('buildMServerFinishedV2) print('"buildMServerFinishedV2") AS .

  eq changeLabel(label('buildClientHelloV3) print(QL:QidList) AS) = label('buildMClientHelloV3) print('"buildMClientHelloV3") AS .
  eq changeLabel(label('buildSecondClientHelloV3) print(QL:QidList) AS) = label('buildMSecondClientHelloV3) print('"buildMSecondClientHelloV3") AS .
  eq changeLabel(label('buildHelloRetryRequestV3) print(QL:QidList) AS) = label('buildMHelloRetryRequestV3) print('"buildMHelloRetryRequestV3") AS .
  eq changeLabel(label('buildServerHelloV3) print(QL:QidList) AS) = label('buildMServerHelloV3) print('"buildMServerHelloV3") AS .
  eq changeLabel(label('buildEncryptedExtensionV3) print(QL:QidList) AS) = label('buildMEncryptedExtensionV3) print('"buildMEncryptedExtensionV3") AS .
  eq changeLabel(label('buildCertificateRequestV3) print(QL:QidList) AS) = label('buildMCertificateRequestV3) print('"buildMCertificateRequestV3") AS .
  eq changeLabel(label('buildServerCertificateV3) print(QL:QidList) AS) = label('buildMServerCertificateV3) print('"buildMServerCertificateV3") AS .
  eq changeLabel(label('buildServerCertificateVerifyV3) print(QL:QidList) AS) = label('buildMServerCertificateVerifyV3) print('"buildMServerCertificateVerifyV3") AS .
  eq changeLabel(label('buildServerFinishedV3) print(QL:QidList) AS) = label('buildMServerFinishedV3) print('"buildMServerFinishedV3") AS .
  eq changeLabel(label('buildClientCertificateV3) print(QL:QidList) AS) = label('buildMClientCertificateV3) print('"buildMClientCertificateV3") AS .
  eq changeLabel(label('buildClientCertificateVerifyV3) print(QL:QidList) AS) = label('buildMClientCertificateVerifyV3) print('"buildMClientCertificateVerifyV3") AS .
  eq changeLabel(label('buildClientFinishedV3) print(QL:QidList) AS) = label('buildMClientFinishedV3) print('"buildMClientFinishedV3") AS .
  eq changeLabel(label('processClientHelloV2) print(QL:QidList) AS) = label('processMClientHelloV2) print('"processMClientHelloV2") AS .
  eq changeLabel(label('processServerHelloV2) print(QL:QidList) AS) = label('processMServerHelloV2) print('"processMServerHelloV2") AS .
  eq changeLabel(label('processServerCertificateV2) print(QL:QidList) AS) = label('processMServerCertificateV2) print('"processMServerCertificateV2") AS .
  eq changeLabel(label('processServerKeyExchangeV2) print(QL:QidList) AS) = label('processMServerKeyExchangeV2) print('"processMServerKeyExchangeV2") AS .
  eq changeLabel(label('processCertificateRequestV2) print(QL:QidList) AS) = label('processMCertificateRequestV2) print('"processMCertificateRequestV2") AS .
  eq changeLabel(label('processServerHelloDoneV2) print(QL:QidList) AS) = label('processMServerHelloDoneV2) print('"processMServerHelloDoneV2") AS .
  eq changeLabel(label('processClientCertificateV2) print(QL:QidList) AS) = label('processMClientCertificateV2) print('"processMClientCertificateV2") AS .
  eq changeLabel(label('processClientKeyExchangeV2) print(QL:QidList) AS) = label('processMClientKeyExchangeV2) print('"processMClientKeyExchangeV2") AS .
  eq changeLabel(label('processCertificateVerifyV2) print(QL:QidList) AS) = label('processMCertificateVerifyV2) print('"processMClientCertificateVerifyV2") AS .
  eq changeLabel(label('processClientChangeCipherSpecV2) print(QL:QidList) AS) = label('processMClientChangeCipherSpecV2) print('"processMClientChangeCipherSpecV2") AS .
  eq changeLabel(label('processClientFinishedV2) print(QL:QidList) AS) = label('processMClientFinishedV2) print('"processMClientFinishedV2") AS .
  eq changeLabel(label('processServerChangeCipherSpecV2) print(QL:QidList) AS) = label('processMServerChangeCipherSpecV2) print('"processMServerChangeCipherSpecV2") AS .
  eq changeLabel(label('processServerFinishedV2) print(QL:QidList) AS) = label('processMServerFinishedV2) print('"processMServerFinishedV2") AS .

  eq changeLabel(label('processClientHelloV3) print(QL:QidList) AS) = label('processMClientHelloV3) print('"processMClientHelloV3") AS .
  eq changeLabel(label('processHelloRetryRequestV3) print(QL:QidList) AS) = label('processMHelloRetryRequestV3) print('"processMHelloRetryRequestV3") AS .
  eq changeLabel(label('processServerHelloV3) print(QL:QidList) AS) = label('processMServerHelloV3) print('"processMServerHelloV3") AS .
  eq changeLabel(label('processEncryptedExtensionV3) print(QL:QidList) AS) = label('processMEncryptedExtensionV3) print('"processMEncryptedExtensionV3") AS .
  eq changeLabel(label('processCertificateRequestV3) print(QL:QidList) AS) = label('processMCertificateRequestV3) print('"processMCertificateRequestV3") AS .
  eq changeLabel(label('processServerCertificateV3) print(QL:QidList) AS) = label('processMServerCertificateV3) print('"processMServerCertificateV3") AS .
  eq changeLabel(label('processServerCertificateVerifyV3) print(QL:QidList) AS) = label('processMServerCertificateVerifyV3) print('"processMServerCertificateVerifyV3") AS .
  eq changeLabel(label('processServerFinishedV3) print(QL:QidList) AS) = label('processMServerFinishedV3) print('"processMServerFinishedV3") AS .
  eq changeLabel(label('processClientCertificateV3) print(QL:QidList) AS) = label('processMClientCertificateV3) print('"processMClientCertificateV3") AS .
  eq changeLabel(label('processClientCertificateVerifyV3) print(QL:QidList) AS) = label('processMClientCertificateVerifyV3) print('"processMClientCertificateVerifyV3") AS .
  eq changeLabel(label('processClientFinishedV3) print(QL:QidList) AS) = label('processMClientFinishedV3) print('"processMClientFinishedV3") AS .

  eq changeLabel(label('sendMsg) print(QL:QidList) AS) = label('reorderMsg) print('"Reorder Message") AS .

  eq changeLabel(AS) = AS [owise] .


  op getId : Object -> TId .
  eq getId(< TI:TId : C:TLS | ATTS:AttributeSet >) = TI:TId .
  
  op getNonceCtr : Object -> Nat .
  eq getNonceCtr(< TI:TId : C:TLS | nonceCtr : N:Nat, ATTS:AttributeSet >) = N:Nat .
endsm

fmod FORMAL-ACTION-FILTER is
  protecting LIST{FormalAction} .
  
  vars TI TI' : TId .
  var OIDL : List{TId} .
  var AF : FormalAction .
  var AFL : List{FormalAction} .
  var PV : ProtocolVersion .
  var PVL : List{ProtocolVersion} .
  var CSL : List{CipherSuite} .
  var CML : List{CompressionMethod} .
  var NGL : List{NamedGroup} .
  var SAL : List{SignatureAlgorithm} .
  var EML : List{PreSharedKeyExchangeMode} .
  var PSK : Nonce .
  var B : Bool .
  var CERT : Certificate .
  var KEY : Key .
  vars MC MC' MC'' : MsgContent .

  op filterTT : List{FormalAction} -> List{FormalAction} .
  eq filterTT(initializePV(TI, PV) AFL)        = filterTT(AFL) .  
  eq filterTT(initializeCS(TI, CSL) AFL)       = filterTT(AFL) .
  eq filterTT(initializeCM(TI, CML) AFL)       = filterTT(AFL) .
  eq filterTT(initializeNC(TI, NGL) AFL)       = filterTT(AFL) .
  eq filterTT(initializeNG(TI, NGL) AFL)       = filterTT(AFL) .
  eq filterTT(initializeSV(TI, PVL) AFL)       = filterTT(AFL) .
  eq filterTT(initializeSA(TI, SAL) AFL)       = filterTT(AFL) .
  eq filterTT(initializeEM(TI, EML) AFL)       = filterTT(AFL) .
  eq filterTT(initializeKS(TI, NGL) AFL)       = filterTT(AFL) .
  eq filterTT(initializeNST(TI, B) AFL)        = filterTT(AFL) .
  eq filterTT(initializeCR(TI, B) AFL)         = filterTT(AFL) .
  eq filterTT(initializeED(TI, B) AFL)         = filterTT(AFL) .
  eq filterTT(initializePCA(TI, B) AFL)        = filterTT(AFL) .
  eq filterTT(initializeKU(TI, B) AFL)         = filterTT(AFL) .
  eq filterTT(AF AFL) = AF filterTT(AFL) [owise] .
  eq filterTT(nil) = nil .

  op filterTG : List{FormalAction} -> List{FormalAction} .
  eq filterTG(connectF(TI) AFL) = connectF(TI) filterTG(AFL) .
  eq filterTG(acceptF(TI) AFL) = acceptF(TI) filterTG(AFL) .
  eq filterTG(closeF(TI) AFL) = closeF(TI) filterTG(AFL) .
  eq filterTG(genCertificatePrivateKey(KEY) AFL) = genCertificatePrivateKey(KEY) filterTG(AFL) .
  eq filterTG(initializePV(TI, PV) AFL)        = initializePV(TI, PV) filterTG(AFL) .  
  eq filterTG(initializeCS(TI, CSL) AFL)       = initializeCS(TI, CSL) filterTG(AFL) .
  eq filterTG(initializeCM(TI, CML) AFL)       = initializeCM(TI, CML) filterTG(AFL) .
  eq filterTG(initializeNC(TI, NGL) AFL)       = initializeNC(TI, NGL) filterTG(AFL) .
  eq filterTG(initializeNG(TI, NGL) AFL)       = initializeNG(TI, NGL) filterTG(AFL) .
  eq filterTG(initializeSV(TI, PVL) AFL)       = initializeSV(TI, PVL) filterTG(AFL) .
  eq filterTG(initializeSA(TI, SAL) AFL)       = initializeSA(TI, SAL) filterTG(AFL) .
  eq filterTG(initializeEM(TI, EML) AFL)       = initializeEM(TI, EML) filterTG(AFL) .
  eq filterTG(initializeKS(TI, NGL) AFL)       = initializeKS(TI, NGL) filterTG(AFL) .
  eq filterTG(initializeNST(TI, B) AFL)        = initializeNST(TI, B) filterTG(AFL) .
  eq filterTG(initializeCR(TI, B) AFL)         = initializeCR(TI, B) filterTG(AFL) .
  eq filterTG(initializeED(TI, B) AFL)         = initializeED(TI, B) filterTG(AFL) .
  eq filterTG(initializePCA(TI, B) AFL)        = initializePCA(TI, B) filterTG(AFL) .
  eq filterTG(initializeKU(TI, B) AFL)         = initializeKU(TI, B) filterTG(AFL) .
  eq filterTG(AF AFL) = filterTG(AFL) [owise] .
  eq filterTG(nil) = nil .

  op filterVS : List{FormalAction} List{TId} -> List{FormalAction} .
  eq filterVS(buildClientHelloV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientCertificateV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientKeyExchangeV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientCertificateVerifyV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientChangeCipherSpecV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientFinishedV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerHelloV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerCertificateV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerKeyExchangeV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildCertificateRequestV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerHelloDoneV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerChangeCipherSpecV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildServerFinishedV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .

  eq filterVS(errorClientHelloV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientCertificateV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorCertificateRequestV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientKeyExchangeV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorCertificateVerifyV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientChangeCipherSpecV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorClientFinishedV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerHelloV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerCertificateV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerKeyExchangeV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerHelloDoneV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerChangeCipherSpecV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .
  eq filterVS(errorServerFinishedV2(MC, MC', MC'', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC'')) filterVS(AFL, OIDL) .

  eq filterVS(buildMClientHelloV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientCertificateV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientKeyExchangeV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientCertificateVerifyV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientChangeCipherSpecV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMClientFinishedV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerHelloV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerCertificateV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerKeyExchangeV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMCertificateRequestV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerHelloDoneV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerChangeCipherSpecV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildMServerFinishedV2(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .

  eq filterVS(buildClientHelloV3(MC, TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC)) filterVS(AFL, OIDL) .
  eq filterVS(buildEarlyDataV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientCertificateV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientCertificateV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientCertificateVerifyV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientFinishedV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
  eq filterVS(buildClientKeyUpdateRequestV3(MC, MC', TI) AFL, TI' OIDL) = send(TI',TI,unwrap(MC')) filterVS(AFL, OIDL) .
