  eq genThreatStrat(changeContent(second-client-hello-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(second-client-hello-v3), upTerm(MMS)]]] := 'buildMSecondClientHelloV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(hello-retry-request-v3, MMS) -> SACT) 
   = (sd 'mb[['changeContent[upTerm(hello-retry-request-v3), upTerm(MMS)]]] := 'buildMHelloRetryRequestV3 [none] {empty} [none].) genThreatStrat(SACT) .
  eq genThreatStrat(changeContent(server-hello-v3, MMS) -> SACT) 
