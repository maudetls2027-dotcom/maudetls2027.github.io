                     isupported-versions(N2 . SI, (TLS-13 nil))
                     isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                     isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                     ipsk-key-exchange-modes(N1 . CI, psk-ke)
                     ipsk-key-exchange-modes(N2 . SI, psk-ke) .

  op initConf53-4 : -> TLSConfiguration .
  eq initConf53-4 = iversion(N1 . CI, TLS-13)
                   iversion(N2 . SI, TLS-13)
                   icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                   icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
                   icompressions(N1 . CI, no-compression)
                   icompressions(N2 . SI, no-compression)
                   icertificates(N1 . CI, cert1(N1 . CI))
                   icertificates(N2 . SI, cert1(N2 . SI))
                   ipublicKeys(N1 . CI, pubKey1(CA))
                   ipublicKeys(N2 . SI, pubKey1(CA))
                   iprivateKeys(N1 . CI, prvKey1(N1 . CI))
                   iprivateKeys(N2 . SI, prvKey1(N2 . SI))
                   isupported-versions(N1 . CI, (TLS-13 nil))
                   isupported-versions(N2 . SI, (TLS-13 nil))
                   isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                   isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                   isupported-groups(N1 . CI, (secp256r1 nil))
                   isupported-groups(N2 . SI, (secp256r1 nil))
                   icertificateRequest(N2 . SI)
                   ikey-shares(N1 . CI, (secp256r1 nil))
                   ikey-shares(N2 . SI, (secp256r1 nil)) 
                   ipsk-key-exchange-modes(N1 . CI, (psk-dhe-ke))
                   ipsk-key-exchange-modes(N2 . SI, (psk-dhe-ke)) .

  --- In order to use PSKs, clients MUST also send a "psk_key_exchange_modes" extension.
  --- A client MUST provide a "psk_key_exchange_modes" extension if it offers a "pre_shared_key" extension. If clients offer
  --- "pre_shared_key" without a "psk_key_exchange_modes" extension, servers MUST abort the handshake.
  op scen53 : -> ScenarioAction .
  eq scen53 = init(initConf53-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, delete(v[psk-key-exchange-modes])}) ->
              assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI) ->
			  init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) .				   

  op scen54 : -> ScenarioAction .
  eq scen54 = init(initConf53-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, delete(v[key-shares])}) ->
              assert(((N1 . CI) . errorLog) == v[illegal-parameter]) -> close(N1 . CI, N2 . SI) ->
			  init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) .

  --- [Additional Check] Client does not send supported groups.
  op scen55 : -> ScenarioAction .
  eq scen55 = init(initConf53-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, delete(v[supported-groups])}) ->
              assert(((N1 . CI) . errorLog) == v[missing-extension]) -> close(N1 . CI, N2 . SI) ->
			  init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) . 

  --- [Additional Check] Client sends supported groups with different key_shares.
  op scen56 : -> ScenarioAction .
  eq scen56 = init(initConf53-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {supported-groups, replace(*(1), *(1))}) ->
              assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI) -> 
			  init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) .

  --- [Additional Check] Client sends cipher suites for TLS 1.2
  op scen57 : -> ScenarioAction .
  eq scen57 = init(initConf53-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {cipher-suites, replace(*(1), *(1))}) ->
              assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI) -> 
			  init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) .

  --- [Additional Check] legacy_version field MUST be set to 0x0303, which is the version number for TLS 1.2.
  op scen58 : -> ScenarioAction .
  eq scen58 = init(initConf53-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {version, replace(*(1), *(1))}) ->
              assert(((N1 . CI) . errorLog) == v[protocol-version]) -> close(N1 . CI, N2 . SI) -> 
			  init(initConf53-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) .

  --- [Additional Check] For every TLS 1.3 ClientHello, this vector MUST contain exactly one byte, set to zero
  op scen59 : -> ScenarioAction .
  eq scen59 = init(initConf53-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
