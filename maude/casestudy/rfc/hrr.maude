  op scen35 : -> ScenarioAction .
  eq scen35 = init(initConf tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(second-client-hello-v3, {extensions, add(v[key-shares, *(1)])}) ->
