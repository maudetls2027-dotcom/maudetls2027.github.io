  eq scen28 = init(initConf tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(second-client-hello-v3, {extensions, delete(v[signature-algorithms])}) ->
              assert(((N1 . CI) . errorLog) == v[missing-extension])  -> close(N1 . CI, N2 . SI) .

  op scen29 : -> ScenarioAction .
