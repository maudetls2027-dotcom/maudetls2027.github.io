  op scen25 : -> ScenarioAction .
  eq scen25 = init(initConf tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(second-client-hello-v3, {signature-algorithms, replace(*(1), v[{ecdsa,sha224}])}) ->
              assert(((N1 . CI) . errorLog) == v[illegal-parameter]) -> close(N1 . CI, N2 . SI)  .

  op scen26 : -> ScenarioAction .
  eq scen26 = init(initConf tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(second-client-hello-v3, {signature-algorithms, replace(*(1), v[{dsa,md5}])}) ->
              assert(((N1 . CI) . errorLog) == v[illegal-parameter]) -> close(N1 . CI, N2 . SI)  .

  op scen27 : -> ScenarioAction .
  eq scen27 = init(initConf tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(second-client-hello-v3, {signature-algorithms, replace(*(1), v[{dsa,sha224}])}) ->
