smod TEST-STRATEGY is
  protecting LINK-OBJECT .
  protecting CONNECT-V3-API .
  protecting ACCEPT-V3-API .
  protecting CONFIGURATION-WITH-ACTION .
  protecting FORMAL-SCENARIO-GENERATOR .
  protecting INTERNAL-FORMAL-SCENARIO-GENERATOR .
  protecting TLS-INITIAL-SYSTEM .
  protecting RUN-SCENARIO .
  protecting MODIFY-MESSAGE-AND-OBJECT .
  protecting TLS-NORMAL-BEHAVIOR-STRATEGY-V3 .

  -----------------------------------
  --- TLS 1.3 (RFC 8446) PSK Mode ---
  -----------------------------------

  --- Servers MUST NOT send a KeyShareEntry when using the "psk_ke" PskKeyExchangeMode.
  --- psk_ke:  PSK-only key establishment.  In this mode, the server MUST NOT supply a "key_share" value.
  op initConf1-1 : -> TLSConfiguration .
  eq initConf1-1 = iversion(N1 . CI, TLS-13)
                   iversion(N2 . SI, TLS-13)
                   icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                   icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
                   icompressions(N1 . CI, no-compression)
                   icompressions(N2 . SI, no-compression)
                   icertificates(N1 . CI, cert1(N1 . CI))
                   icertificates(N2 . SI, cert1(N2 . SI))
                   ipublicKeys(N1 . CI, pubKey1(CA))
                   ipublicKeys(N2 . SI, pubKey1(CA))
                   iprivateKeys(N1 . CI, prvKey1(N1 . CI))
                   iprivateKeys(N2 . SI, prvKey1(N2 . SI))
                   isupported-versions(N1 . CI, (TLS-13 nil))
                   isupported-versions(N2 . SI, (TLS-13 nil))
                   isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                   isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                   isupported-groups(N1 . CI, (secp256r1 nil))
                   isupported-groups(N2 . SI, (secp256r1 nil))
                   icertificateRequest(N2 . SI)
                   ikey-shares(N1 . CI, (secp256r1 nil))
                   ikey-shares(N2 . SI, (secp256r1 nil)) 
				   ipsk-key-exchange-modes(N1 . CI, (psk-dhe-ke))
				   ipsk-key-exchange-modes(N2 . SI, (psk-dhe-ke))
                   inewSessionTicketReq(N2 . SI)
                   inewSessionTicketWait(N1 . CI) .

  op initConf1-2 : -> TLSConfiguration .
  eq initConf1-2 = iversion(N1 . CI, TLS-13)
                     iversion(N2 . SI, TLS-13)
                     icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                     icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
    	             icompressions(N1 . CI, no-compression)
    	             icompressions(N2 . SI, no-compression)
                     isupported-versions(N1 . CI, (TLS-13 nil))
                     isupported-versions(N2 . SI, (TLS-13 nil))
                     isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                     isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                     isupported-groups(N1 . CI, (secp256r1 nil))
                     isupported-groups(N2 . SI, (secp256r1 nil))
                     ikey-shares(N1 . CI, (secp256r1 nil))
                     ikey-shares(N2 . SI, (secp256r1 nil)) 
                     ipsk-key-exchange-modes(N1 . CI, psk-dhe-ke)  
                     ipsk-key-exchange-modes(N2 . SI, psk-dhe-ke) .

  op initConf1-3 : -> TLSConfiguration .
  eq initConf1-3 = iversion(N1 . CI, TLS-13)
                     iversion(N2 . SI, TLS-13)
                     icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                     icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
    	             icompressions(N1 . CI, no-compression)
    	             icompressions(N2 . SI, no-compression)
                     isupported-versions(N1 . CI, (TLS-13 nil))
                     isupported-versions(N2 . SI, (TLS-13 nil))
                     isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                     isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                     isupported-groups(N1 . CI, (secp521r1 secp256r1 nil))
                     isupported-groups(N2 . SI, (secp256r1 nil))
                     ikey-shares(N1 . CI, (secp521r1 nil))
                     ikey-shares(N2 . SI, (secp256r1 nil)) 
                     ipsk-key-exchange-modes(N1 . CI, psk-dhe-ke)  
                     ipsk-key-exchange-modes(N2 . SI, psk-dhe-ke) .

  op initConf1-4 : -> TLSConfiguration .
  eq initConf1-4 = iversion(N1 . CI, TLS-13)
                     iversion(N2 . SI, TLS-13)
                     icipherSuites(N1 . CI, TLS-AES-128-CCM-SHA256)
                     icipherSuites(N2 . SI, TLS-AES-128-CCM-SHA256)
    	             icompressions(N1 . CI, no-compression)
    	             icompressions(N2 . SI, no-compression)
                     isupported-versions(N1 . CI, (TLS-13 nil))
                     isupported-versions(N2 . SI, (TLS-13 nil))
                     isignature-algorithms(N1 . CI, ({ecdsa,sha256} nil))
                     isignature-algorithms(N2 . SI, ({ecdsa,sha256} nil))
                     ipsk-key-exchange-modes(N1 . CI, psk-ke)  
                     ipsk-key-exchange-modes(N2 . SI, psk-ke) .

  -----------------------
  --- PSK-DHE-KE Mode ---
  -----------------------
  --- In order to use PSKs, clients MUST also send a "psk_key_exchange_modes" extension.
  --- A client MUST provide a "psk_key_exchange_modes" extension if it offers a "pre_shared_key" extension. If clients offer
  --- "pre_shared_key" without a "psk_key_exchange_modes" extension, servers MUST abort the handshake.
  op scen1 : -> ScenarioAction .
  eq scen1 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) -> 
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, delete(v[psk-key-exchange-modes])}) ->
             assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI)  .

  op scen2 : -> ScenarioAction .
  eq scen2 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, delete(v[key-shares])}) ->
			 assert(((N1 . CI) . errorLog) == v[missing-extension]) -> close(N1 . CI, N2 . SI) .

  op scen3 : -> ScenarioAction .
  eq scen3 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, delete(v[supported-groups])}) ->
			 assert(((N1 . CI) . errorLog) == v[missing-extension]) -> close(N1 . CI, N2 . SI) .

  op scen4 : -> ScenarioAction .
  eq scen4 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, delete(v[supported-versions])}) ->
			 assert(((N1 . CI) . errorLog) == v[protocol-version]) -> close(N1 . CI, N2 . SI) .

  op scen5 : -> ScenarioAction .
  eq scen5 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) -> 
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, add(v[psk-key-exchange-modes, *(1)])}) ->
             assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI)  .

  op scen6 : -> ScenarioAction .
  eq scen6 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, add(v[key-shares, *(1)])}) ->
			 assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI) .

  op scen7 : -> ScenarioAction .
  eq scen7 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, add(v[supported-groups, *(1)])}) ->
			 assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI) .

  op scen8 : -> ScenarioAction .
  eq scen8 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {extensions, add(v[supported-versions, *(1)])}) ->
			 assert(((N1 . CI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI) .

  op scen9 : -> ScenarioAction .
  eq scen9 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {supported-groups, replace(*(1), *(1))}) ->
			 assert(((N1 . CI) . errorLog) == v[illegal-parameter]) -> close(N1 . CI, N2 . SI) .

  op scen10 : -> ScenarioAction .
  eq scen10 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {supported-versions, replace(*(1), *(1))}) ->
			  assert(((N1 . CI) . errorLog) == v[protocol-version]) -> close(N1 . CI, N2 . SI) .

  op scen11 : -> ScenarioAction .
  eq scen11 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {psk-key-exchange-modes, replace(*(1), v[psk-ke])}) ->
			  assert(((N1 . CI) . errorLog) == v[illegal-parameter]) -> close(N1 . CI, N2 . SI) .

  op scen12 : -> ScenarioAction .
  eq scen12 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
