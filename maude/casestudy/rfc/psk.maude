  op scen14 : -> ScenarioAction .
  eq scen14 = init(initConf1-1 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
             init(initConf1-2 tester(N1 . CI) target(N2 . SI)) -> connect(N1 . CI, N2 . SI) -> changeContent(client-hello-v3, {compression-methods, add(*(1))}) ->
			 assert(((N1 . CI) . errorLog) == v[illegal-parameter]) -> close(N1 . CI, N2 . SI) .


  op scen15 : -> ScenarioAction .
  eq scen15 = init(initConf1-1 tester(N2 . SI) target(N1 . CI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf1-3 tester(N2 . SI) target(N1 . CI)) -> connect(N1 . CI, N2 . SI) -> changeContent(hello-retry-request-v3, {extensions, delete(v[supported-versions])}) ->
              assert(((N2 . SI) . errorLog) == v[protocol-version]) -> close(N1 . CI, N2 . SI) .

  op scen16 : -> ScenarioAction .
  eq scen16 = init(initConf1-1 tester(N2 . SI) target(N1 . CI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf1-3 tester(N2 . SI) target(N1 . CI)) -> connect(N1 . CI, N2 . SI) -> changeContent(hello-retry-request-v3, {extensions, delete(v[key-shares-groups])}) ->
              assert(((N2 . SI) . errorLog) == v[illegal-parameter]) -> close(N1 . CI, N2 . SI) .

  op scen17 : -> ScenarioAction .
  eq scen17 = init(initConf1-1 tester(N2 . SI) target(N1 . CI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
              init(initConf1-3 tester(N2 . SI) target(N1 . CI)) -> connect(N1 . CI, N2 . SI) -> changeContent(hello-retry-request-v3, {extensions, add(v[supported-versions, *(1)])}) ->
              assert(((N2 . SI) . errorLog) == v[handshake-failure]) -> close(N1 . CI, N2 . SI) .

  op scen18 : -> ScenarioAction .
  eq scen18 = init(initConf1-1 tester(N2 . SI) target(N1 . CI)) -> connect(N1 . CI, N2 . SI) -> close(N1 . CI, N2 . SI) ->
